            await loadS2Options();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to update.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false; this.textContent = 'Save';
        }
    });

    // ── Init ──────────────────────────────────────────────────────
    loadFYs();
    loadItrTypes();
    loadReturnOutcomes();
    loadS2Options();
    loadSources();
    loadPaidTos();
    loadModeOfPayments();
})();
</script>
