        } catch (e) {
            errEl.textContent = e.message || 'Failed to add type.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false;
            this.innerHTML = '<iconify-icon icon="ic:baseline-plus" class="icon text-xl line-height-1"></iconify-icon>Add Type';
        }
    });

    document.getElementById('itrType_input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') document.getElementById('itrType_addBtn').click();
    });

    window.openEditItrType = function (id) {
        const t = allItrTypes.find(x => x.id === id);
        if (!t) return;
        document.getElementById('editItrType_id').value = t.id;
        document.getElementById('editItrType_name').value = t.name;
        document.getElementById('editItrType_error').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('editItrTypeModal')).show();
    };

    document.getElementById('editItrType_saveBtn').addEventListener('click', async function () {
        const id = document.getElementById('editItrType_id').value;
        const name = document.getElementById('editItrType_name').value.trim();
        const errEl = document.getElementById('editItrType_error');
        if (!name) { errEl.textContent = 'Type name cannot be empty.'; errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');
        this.disabled = true; this.textContent = 'Saving...';
        try {
            const res = await fetch(`/api/itr-types/${id}`, {
                method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name })
            });
            if (!res.ok) throw new Error((await res.json()).message);
            bootstrap.Modal.getInstance(document.getElementById('editItrTypeModal')).hide();
            showToast('Type updated.', 'success');
            await loadItrTypes();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to update.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false; this.textContent = 'Save';
        }
    });

    // ════════════════════════════════════════
    //  SOURCES
    // ════════════════════════════════════════
    async function loadSources() {
        const res = await fetch('/api/sources');
        allSources = await res.json();
        renderSources();
    }

    function renderSources() {
        const tbody = document.getElementById('src_tableBody');
        if (!allSources.length) {
            tbody.innerHTML = '<tr><td colspan="3" class="text-center py-20 text-secondary-light">No sources found. Add one above.</td></tr>';
            return;
        }
        tbody.innerHTML = allSources.map((s, i) => `
            <tr>
                <td>${String(i + 1).padStart(2, '0')}</td>
                <td><span class="fw-medium text-primary-light">${escHtml(s.name)}</span></td>
                <td class="text-center">
                    <div class="d-flex align-items-center gap-10 justify-content-center">
                        <button type="button"
                            class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="Edit" onclick="openEditSrc('${s.id}')">
                            <iconify-icon icon="lucide:edit" class="menu-icon"></iconify-icon>
                        </button>
                        <button type="button"
                            class="bg-danger-focus text-danger-600 bg-hover-danger-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="Delete" onclick="openDeleteConfirm('src', '${s.id}', '${escHtml(s.name)}')">
                            <iconify-icon icon="fluent:delete-24-regular" class="menu-icon"></iconify-icon>
                        </button>
                    </div>
                </td>
            </tr>`).join('');
    }

    // Add Source
    document.getElementById('src_addBtn').addEventListener('click', async function () {
        const name = document.getElementById('src_input').value.trim();
        const errEl = document.getElementById('src_error');
        if (!name) {
            errEl.textContent = 'Please enter a source name.';
            errEl.classList.remove('d-none');
            return;
        }
        errEl.classList.add('d-none');
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="text-lg"></iconify-icon>Adding...';
        try {
            const res = await fetch('/api/sources', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name })
            });
