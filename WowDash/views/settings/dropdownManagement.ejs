<script>
(function () {
    let allFYs = [];
    let allItrTypes = [];
    let allReturnOutcomes = [];
    let allSources = [];
    let allPaidTos = [];
    let allModeOfPayments = [];
    let allS2Options = [];
    let pendingDelete = null; // { type: 'fy'|'src'|'pt'|'mop'|'s2', id }

    // ── Helpers ──────────────────────────────────────────────────
    function escHtml(str) {
        return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function showToast(msg, type) {
        const div = document.createElement('div');
        div.className = `alert alert-${type === 'error' ? 'danger' : 'success'} position-fixed top-0 end-0 m-24 shadow-sm`;
        div.style.cssText = 'min-width:280px;z-index:9999;';
        div.textContent = msg;
        document.body.appendChild(div);
        setTimeout(() => div.remove(), 3000);
    }

    // ════════════════════════════════════════
    //  FINANCIAL YEARS
    // ════════════════════════════════════════
    async function loadFYs() {
        const res = await fetch('/api/financial-years');
        allFYs = await res.json();
        renderFYs();
    }

    function renderFYs() {
        const tbody = document.getElementById('fy_tableBody');
        if (!allFYs.length) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-20 text-secondary-light">No financial years found. Add one above.</td></tr>';
            return;
        }
        tbody.innerHTML = allFYs.map((fy, i) => `
            <tr>
                <td>${String(i + 1).padStart(2, '0')}</td>
                <td><span class="fw-medium text-primary-light">${escHtml(fy.name)}</span></td>
                <td class="text-center">
                    <span class="bg-success-focus text-success-600 border border-success-main px-16 py-4 radius-4 fw-medium text-sm">${escHtml(fy.status)}</span>
                </td>
                <td class="text-center">
                    <div class="d-flex align-items-center gap-10 justify-content-center">
                        <button type="button"
                            class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="Edit" onclick="openEditFy('${fy.id}')">
                            <iconify-icon icon="lucide:edit" class="menu-icon"></iconify-icon>
                        </button>
                        <button type="button"
                            class="bg-danger-focus text-danger-600 bg-hover-danger-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="Delete" onclick="openDeleteConfirm('fy', '${fy.id}', '${escHtml(fy.name)}')">
                            <iconify-icon icon="fluent:delete-24-regular" class="menu-icon"></iconify-icon>
                        </button>
                    </div>
                </td>
            </tr>`).join('');
    }

    // Add FY
    document.getElementById('fy_addBtn').addEventListener('click', async function () {
        const name = document.getElementById('fy_input').value.trim();
        const errEl = document.getElementById('fy_error');
        if (!name) {
            errEl.textContent = 'Please enter a financial year (e.g. 2025-26).';
            errEl.classList.remove('d-none');
            return;
        }
        errEl.classList.add('d-none');
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="text-lg"></iconify-icon>Adding...';
        try {
            const res = await fetch('/api/financial-years', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name })
            });
            if (!res.ok) throw new Error((await res.json()).message);
            document.getElementById('fy_input').value = '';
            showToast('Financial Year added.', 'success');
            await loadFYs();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to add FY.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false;
            this.innerHTML = '<iconify-icon icon="ic:baseline-plus" class="icon text-xl line-height-1"></iconify-icon>Add FY';
        }
    });

    // Allow Enter key in FY input
    document.getElementById('fy_input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') document.getElementById('fy_addBtn').click();
    });

    // Edit FY
    window.openEditFy = function (id) {
        const fy = allFYs.find(f => f.id === id);
        if (!fy) return;
        document.getElementById('editFy_id').value = fy.id;
        document.getElementById('editFy_name').value = fy.name;
        document.getElementById('editFy_error').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('editFyModal')).show();
    };

    document.getElementById('editFy_saveBtn').addEventListener('click', async function () {
        const id = document.getElementById('editFy_id').value;
        const name = document.getElementById('editFy_name').value.trim();
        const errEl = document.getElementById('editFy_error');
        if (!name) { errEl.textContent = 'FY name cannot be empty.'; errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');
        this.disabled = true; this.textContent = 'Saving...';
        try {
            const res = await fetch(`/api/financial-years/${id}`, {
                method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name })
            });
            if (!res.ok) throw new Error((await res.json()).message);
