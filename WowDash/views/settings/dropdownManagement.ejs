    document.getElementById('src_input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') document.getElementById('src_addBtn').click();
    });

    // Edit Source
    window.openEditSrc = function (id) {
        const s = allSources.find(x => x.id === id);
        if (!s) return;
        document.getElementById('editSrc_id').value = s.id;
        document.getElementById('editSrc_name').value = s.name;
        document.getElementById('editSrc_error').classList.add('d-none');
