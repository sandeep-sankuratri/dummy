            await loadReturnOutcomes();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to update.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false; this.textContent = 'Save';
        }
    });

    // ════════════════════════════════════════
    //  ITR TYPES
    // ════════════════════════════════════════
