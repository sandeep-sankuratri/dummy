            await loadReturnOutcomes();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to add outcome.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false;
            this.innerHTML = '<iconify-icon icon="ic:baseline-plus" class="icon text-xl line-height-1"></iconify-icon>Add Outcome';
        }
    });

    document.getElementById('ro_input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') document.getElementById('ro_addBtn').click();
    });

    window.openEditRo = function (id) {
        const r = allReturnOutcomes.find(x => x.id === id);
        if (!r) return;
        document.getElementById('editRo_id').value = r.id;
        document.getElementById('editRo_name').value = r.name;
        document.getElementById('editRo_color').value = r.color || '#3B82F6';
        document.getElementById('editRo_error').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('editRoModal')).show();
    };

    document.getElementById('editRo_saveBtn').addEventListener('click', async function () {
        const id = document.getElementById('editRo_id').value;
        const name = document.getElementById('editRo_name').value.trim();
        const color = document.getElementById('editRo_color').value;
        const errEl = document.getElementById('editRo_error');
        if (!name) { errEl.textContent = 'Outcome name cannot be empty.'; errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');
        this.disabled = true; this.textContent = 'Saving...';
        try {
            const res = await fetch(`/api/return-outcomes/${id}`, {
                method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, color })
            });
