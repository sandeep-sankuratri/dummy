            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false; this.textContent = 'Save';
        }
    });

    // ════════════════════════════════════════
    //  SHARED DELETE CONFIRMATION
    // ════════════════════════════════════════
    window.openDeleteConfirm = function (type, id, label) {
        pendingDelete = { type, id };
        document.getElementById('deleteConfirm_msg').textContent =
            `Are you sure you want to delete "${label}"?`;
        const warningDiv = document.getElementById('deleteConfirm_warning');
        if (warningDiv) warningDiv.remove();
        new bootstrap.Modal(document.getElementById('deleteConfirmModal')).show();
    };

    document.getElementById('deleteConfirm_btn').addEventListener('click', async function () {
        if (!pendingDelete) return;
        const { type, id } = pendingDelete;
        const url = type === 'fy' ? `/api/financial-years/${id}` : type === 'itrtype' ? `/api/itr-types/${id}` : type === 'ro' ? `/api/return-outcomes/${id}` : type === 'src' ? `/api/sources/${id}` : type === 'pt' ? `/api/paid-to/${id}` : type === 's2' ? `/api/itr-status2/${id}` : `/api/mode-of-payment/${id}`;
        this.disabled = true; this.textContent = 'Deleting...';
        try {
            const res = await fetch(url, { method: 'DELETE' });
            if (res.status === 409) {
                const data = await res.json();
                const msgEl = document.getElementById('deleteConfirm_msg');
                const warningDiv = document.getElementById('deleteConfirm_warning');
                if (warningDiv) warningDiv.remove();
                const warning = document.createElement('div');
                warning.id = 'deleteConfirm_warning';
                warning.className = 'alert alert-warning text-sm text-start mt-12 mb-0';
                warning.style.cssText = 'line-height:1.5;';
                warning.innerHTML = '<iconify-icon icon="lucide:alert-triangle" style="font-size:1rem;vertical-align:-3px;margin-right:4px;"></iconify-icon>' + escHtml(data.message || 'This item is in use and cannot be deleted.');
                msgEl.parentNode.insertBefore(warning, msgEl.nextSibling.nextSibling);
                return;
            }
            if (!res.ok) throw new Error('Delete failed');
            bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal')).hide();
            showToast('Deleted successfully.', 'success');
            pendingDelete = null;
            if (type === 'fy') await loadFYs();
            else if (type === 'itrtype') await loadItrTypes();
            else if (type === 'ro') await loadReturnOutcomes();
            else if (type === 'src') await loadSources();
            else if (type === 'pt') await loadPaidTos();
            else if (type === 's2') await loadS2Options();
            else await loadModeOfPayments();
        } catch (e) {
            showToast('Failed to delete.', 'error');
            pendingDelete = null;
        } finally {
            this.disabled = false; this.textContent = 'Delete';
        }
    });

