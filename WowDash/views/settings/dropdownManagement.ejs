    // ════════════════════════════════════════
    //  ITR STATUS 2 (CALLER / PREPARER / COMMON)
    // ════════════════════════════════════════
    async function loadS2Options() {
        const res = await fetch('/api/itr-status2');
        allS2Options = await res.json();
        renderS2Caller();
        renderS2Preparer();
        renderS2Common();
    }

    function colorDot(color) {
        const c = color || '#9CA3AF';
        return `<span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:${escHtml(c)};flex-shrink:0;border:1px solid rgba(0,0,0,.1);"></span>`;
    }

    function renderS2Tab(opts, tbodyId, role) {
        const tbody = document.getElementById(tbodyId);
        const filtered = opts.filter(o => o.role === role);
        if (!filtered.length) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-20 text-secondary-light">No entries found. Add one above.</td></tr>';
            return;
        }
        tbody.innerHTML = filtered.map((o, i) => `
            <tr>
                <td>${String(i + 1).padStart(2, '0')}</td>
                <td><span class="fw-medium text-primary-light">${escHtml(o.name)}</span></td>
                <td class="text-center">${colorDot(o.color)}</td>
                <td class="text-center">
                    <div class="d-flex align-items-center gap-10 justify-content-center">
                        <button type="button"
                            class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            onclick="openEditS2('${escHtml(o.id)}','${escHtml(o.name)}','${escHtml(o.color||'#3B82F6')}')">
                            <iconify-icon icon="lucide:edit" class="menu-icon"></iconify-icon>
                        </button>
                        <button type="button"
                            class="bg-danger-focus text-danger-600 bg-hover-danger-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            onclick="openDeleteConfirm('s2','${escHtml(o.id)}','${escHtml(o.name)}')">
                            <iconify-icon icon="fluent:delete-24-regular" class="menu-icon"></iconify-icon>
                        </button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    function renderS2Caller()   { renderS2Tab(allS2Options, 's2c_tableBody', 'caller'); }
    function renderS2Preparer() { renderS2Tab(allS2Options, 's2p_tableBody', 'preparer'); }
    function renderS2Common()   { renderS2Tab(allS2Options, 's2o_tableBody', 'common'); }

    async function addS2Option(role, inputId, colorId, errorId) {
        const input  = document.getElementById(inputId);
        const colorEl = document.getElementById(colorId);
        const errEl  = document.getElementById(errorId);
        const name   = input.value.trim();
        const color  = colorEl ? colorEl.value : '#3B82F6';
        if (!name) { errEl.textContent = 'Status name is required.'; errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');
        try {
            const res = await fetch('/api/itr-status2', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, role, color })
            });
            if (!res.ok) throw new Error((await res.json()).message);
            input.value = '';
            colorEl.value = '#3B82F6';
            showToast('Added successfully.', 'success');
            await loadS2Options();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to add.';
            errEl.classList.remove('d-none');
        }
    }

    document.getElementById('s2c_addBtn').addEventListener('click', () => addS2Option('caller',   's2c_input', 's2c_color', 's2c_error'));
    document.getElementById('s2p_addBtn').addEventListener('click', () => addS2Option('preparer', 's2p_input', 's2p_color', 's2p_error'));
    document.getElementById('s2o_addBtn').addEventListener('click', () => addS2Option('common',   's2o_input', 's2o_color', 's2o_error'));

    window.openEditS2 = function(id, name, color) {
        document.getElementById('editS2_id').value = id;
        document.getElementById('editS2_name').value = name;
        document.getElementById('editS2_color').value = color || '#3B82F6';
        document.getElementById('editS2_error').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('editS2Modal')).show();
    };

    document.getElementById('editS2_saveBtn').addEventListener('click', async function () {
        const id    = document.getElementById('editS2_id').value;
        const name  = document.getElementById('editS2_name').value.trim();
        const color = document.getElementById('editS2_color').value;
        const errEl = document.getElementById('editS2_error');
        if (!name) { errEl.textContent = 'Name cannot be empty.'; errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');
        this.disabled = true; this.textContent = 'Saving...';
        try {
