    <style>
        /* Only active-page gets the brand highlight; open/expanded dropdowns should not */
        .sidebar-menu li.dropdown.open > a,
        .sidebar-menu li.dropdown.dropdown-open > a {
            background-color: transparent !important;
            color: var(--text-secondary-light) !important;
        }
        .sidebar-menu li.dropdown.open > a:hover,
        .sidebar-menu li.dropdown.dropdown-open > a:hover {
            color: var(--text-secondary-light) !important;
        }
        /* Remove top padding gap between parent menu item and submenu items */
