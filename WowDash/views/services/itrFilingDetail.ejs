<!-- ══ ADD PAYMENT MODAL ══════════════════════════════════════ -->
<div class="modal fade" id="addPaymentModal" tabindex="-1" aria-labelledby="addPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content radius-12">
            <div class="modal-header border-bottom py-16 px-24">
                <h6 class="modal-title fw-semibold d-flex align-items-center gap-8" id="addPaymentModalLabel">
                    <iconify-icon icon="lucide:credit-card" class="text-primary-600 text-lg"></iconify-icon>
                    <span id="modalTitle">Add Payment</span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-24 py-20">
                <div class="d-flex flex-column gap-16">

                    <!-- Fee -->
                    <div class="d-flex flex-column gap-6">
                        <label class="text-xs fw-bold text-neutral-700 d-block" style="letter-spacing:.01em;">Fee (₹)</label>
                        <input id="modalFeeInput" type="number" min="0" step="0.01"
                               class="form-control radius-8 text-sm" style="height:40px;"
                               placeholder="Enter fee amount" data-testid="modal-input-fee">
                    </div>

                    <!-- Discount -->
                    <div class="d-flex flex-column gap-6">
                        <label class="text-xs fw-bold text-neutral-700 d-block" style="letter-spacing:.01em;">Discount</label>
                        <div class="d-flex gap-8 align-items-center">
                            <input id="modalDiscountInput" type="number" min="0" step="0.01"
                                   class="form-control radius-8 text-sm flex-fill" style="height:40px;"
                                   placeholder="0" data-testid="modal-input-discount">
                            <div class="d-flex radius-8 overflow-hidden border" style="flex-shrink:0;">
                                <input type="radio" class="btn-check" name="discountType" id="discTypeFixed" value="fixed" checked>
                                <label class="btn btn-sm btn-outline-secondary border-0 text-xs px-14 py-0 d-flex align-items-center" style="height:40px;border-radius:0;" for="discTypeFixed">₹ Fixed</label>
                                <input type="radio" class="btn-check" name="discountType" id="discTypePercent" value="percent">
                                <label class="btn btn-sm btn-outline-secondary border-0 border-start text-xs px-14 py-0 d-flex align-items-center" style="height:40px;border-radius:0;" for="discTypePercent">% Off</label>
                            </div>
                        </div>
                    </div>

                    <!-- Final Fee (auto-calculated) -->
                    <div class="radius-8 px-16 py-12 d-flex justify-content-between align-items-center gap-12" style="background:#f0fdf4;border:1.5px solid #86efac;">
                        <div class="d-flex align-items-center gap-8" style="white-space:nowrap;flex-shrink:0;">
                            <iconify-icon icon="lucide:badge-check" style="font-size:1rem;color:#16a34a;"></iconify-icon>
                            <span class="text-sm fw-semibold" style="color:#15803d;">Final Fee</span>
                        </div>
                        <span id="modalFinalFee" class="fw-bold" style="white-space:nowrap;font-size:1rem;color:#16a34a;" data-testid="modal-text-final-fee">₹ 0.00</span>
                    </div>

                    <!-- Payment Handled By -->
                    <div class="d-flex flex-column gap-6">
                        <label class="text-xs fw-bold text-neutral-700 d-block" style="letter-spacing:.01em;">
                            Payment Handled By <span class="text-danger-600">*</span>
                        </label>
                        <select id="modalHandledBy" class="form-select radius-8 text-sm" data-testid="modal-select-handled-by">
                            <option value="">— Select employee —</option>
                        </select>
                    </div>

                    <!-- Remarks -->
                    <div class="d-flex flex-column gap-6">
                        <label class="text-xs fw-bold text-neutral-700 d-block" style="letter-spacing:.01em;">Remarks <span class="text-secondary-light fw-normal">(optional)</span></label>
                        <textarea id="modalRemarksInput" rows="3" maxlength="300"
                                  class="form-control radius-8 text-sm"
                                  placeholder="Add any notes or remarks..." data-testid="modal-input-remarks"></textarea>
                    </div>

                    <div id="modalPayError" class="text-danger-600 text-xs d-none"></div>
                </div>
            </div>
            <div class="modal-footer border-top py-14 px-24 d-flex gap-10 justify-content-end">
                <button type="button" class="btn btn-light radius-8 text-sm py-8 px-20" data-bs-dismiss="modal">Cancel</button>
                <button id="modalSubmitBtn" type="button" class="btn btn-primary radius-8 text-sm py-8 px-24" data-testid="modal-button-submit">
                    Submit
                </button>
            </div>
        </div>
    </div>
</div>

