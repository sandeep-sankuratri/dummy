                        </div>
                        <div id="cp_imgThumb" class="mt-4 d-none">
                            <img id="cp_thumbImg" src="" alt="Preview" style="max-height:70px;max-width:100%;border-radius:6px;object-fit:contain;">
                        </div>
                    </div>
                </div>

                <!-- Remarks -->
                <div class="mb-4">
                    <label class="form-label fw-semibold text-primary-light text-sm mb-6">
                        Remarks <span class="text-secondary-light fw-normal">(optional)</span>
                    </label>
                    <textarea id="cp_remarks" class="form-control radius-8" rows="2" placeholder="e.g. Paid via UPI / Cash..."></textarea>
                </div>
            </div>
            <div class="modal-footer px-24 py-14 border-top d-flex justify-content-between gap-12">
                <button type="button" class="border border-danger-600 bg-hover-danger-200 text-danger-600 text-md px-24 py-10 radius-8 flex-fill" data-bs-dismiss="modal">Cancel</button>
