        }
        errEl.classList.add('d-none');
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="text-md"></iconify-icon>Assigning...';
        try {
            const res = await fetch('/api/itr-filings/' + filingId, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    preparer: selectedPreparer,
                    assignedBy: actingName,
                    selectedIncomeHeads: filingData.selectedIncomeHeads,
                    incomeData: filingData.incomeData,
                }),
            });
            if (!res.ok) throw new Error();
            filingData = await res.json();
            // Post info-request FIRST so the Activity Log is fresh when renderAssignSection loads it
            await fetch('/api/itr-filings/' + filingId + '/info-requests', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'preparer_assigned',
                    message: 'Tax Preparer Assigned (' + selectedPreparer + ')',
                    senderName: actingName,
                    senderRole: activeRole || 'caller'
                })
            });
            renderTracker(filingData);
            renderFilingInfo(filingData);
            renderAssignSection(filingData);
            bootstrap.Modal.getInstance(document.getElementById('assignPreparerModal')).hide();
        } catch (e) {
            errEl.textContent = 'Failed to assign. Please try again.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false;
            this.innerHTML = '<iconify-icon icon="lucide:user-check" class="text-md"></iconify-icon>Assign';
        }
    });

    // ── Initial load ──────────────────────────────────────────────────
    async function loadFiling() {
        try {
            const [filingRes, s2Res] = await Promise.all([
                fetch('/api/itr-filings/' + filingId),
                fetch('/api/itr-status2')
            ]);
            if (!filingRes.ok) throw new Error();
            filingData = await filingRes.json();
            if (s2Res.ok) { try { s2Options = await s2Res.json(); } catch (_) {} }
            clientData = filingData.client;

            // Header
            document.getElementById('pageHeaderTitle').textContent = 'ITR Filing — ' + (clientData ? clientData.name : '');
            const fyBadge = document.getElementById('headerFyBadge');
            fyBadge.textContent = 'FY ' + filingData.financialYear;
            fyBadge.classList.remove('d-none');

            renderTracker(filingData);
            if (clientData) renderClientView(clientData);
            renderFilingInfo(filingData);
            renderAssignSection(filingData);
            renderIncomeSelector(filingData.selectedIncomeHeads || []);
            renderIncomeSections(filingData);
            initIncomeNotes(filingData);
            initDeductions(filingData);
            initReturnDetails(filingData);
            showEl('loadingState', false);
            showEl('mainContent', true);
        } catch (e) {
            showEl('loadingState', false);
            showEl('errorState', true);
        }
    }

    // ── Return Details ────────────────────────────────────────────────
    async function initReturnDetails(data) {
        const itrTypeSel    = document.getElementById('rd_itrType');
        const filingTypeSel = document.getElementById('rd_filingType');
        const outcomeSel    = document.getElementById('rd_returnOutcome');
        const savingEl      = document.getElementById('rd_saving');
        const savedEl       = document.getElementById('rd_saved');

        // Populate ITR Type dropdown from API
        try {
            const res = await fetch('/api/itr-types');
            if (res.ok) {
                const types = await res.json();
                types.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t.name;
                    opt.textContent = t.name;
                    itrTypeSel.appendChild(opt);
                });
            }
        } catch (_) {}

        // Populate Return Outcome dropdown from API (and build color map)
        try {
            const res = await fetch('/api/return-outcomes');
            if (res.ok) {
                const outcomes = await res.json();
                outcomes.forEach(o => {
                    const opt = document.createElement('option');
                    opt.value = o.name;
                    opt.textContent = o.name;
                    outcomeSel.appendChild(opt);
                    if (o.color) rdOutcomeColorMap[o.name] = o.color;
                });
                // Re-render badges now that color map is ready
                renderReturnDetailsBadges(data);
            }
        } catch (_) {}

        // Set saved values
        if (data.itrType)      itrTypeSel.value    = data.itrType;
        if (data.filingType)   filingTypeSel.value  = data.filingType;
        if (data.returnOutcome) outcomeSel.value    = data.returnOutcome;

        const rdLogEl = document.getElementById('rd_log');
        function renderRdLogEntry(fieldLabel, newValue, changedAt) {
            const d = new Date(changedAt);
            const timeStr = d.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:true });
            const dateStr = d.toLocaleDateString('en-IN', { day:'2-digit', month:'short' });
            const entry = document.createElement('div');
            entry.style.cssText = 'font-size:.65rem;color:#64748b;display:flex;justify-content:space-between;align-items:center;padding:2px 0;border-bottom:1px solid #f8fafc;';
            entry.innerHTML = `<span><span style="color:#475569;font-weight:600;">${fieldLabel}</span> → ${newValue || '<em style=\'color:#94a3b8;\'>cleared</em>'}</span><span style="color:#94a3b8;white-space:nowrap;margin-left:8px;">${dateStr}, ${timeStr}</span>`;
            return entry;
        }
        async function loadRdLogs() {
            try {
                const res = await fetch('/api/itr-filings/' + filingId + '/return-detail-logs');
                if (!res.ok) return;
                const logs = await res.json();
                if (!logs.length) return;
                rdLogEl.innerHTML = '';
                logs.forEach(log => rdLogEl.appendChild(renderRdLogEntry(log.fieldLabel, log.newValue, log.changedAt)));
                rdLogEl.classList.remove('d-none');
                var showAllLink = document.getElementById('rd_log_showAll');
                if (showAllLink && rdLogEl.scrollHeight > rdLogEl.clientHeight) showAllLink.classList.remove('d-none');
            } catch (_) {}
        }
        async function appendRdLog(fieldLabel, newValue) {
            if (!rdLogEl) return;
            try {
                const res = await fetch('/api/itr-filings/' + filingId + '/return-detail-logs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fieldLabel, newValue })
                });
                if (res.ok) {
                    const log = await res.json();
                    rdLogEl.prepend(renderRdLogEntry(log.fieldLabel, log.newValue, log.changedAt));
                    rdLogEl.classList.remove('d-none');
                }
            } catch (_) {}
        }
        loadRdLogs();

        let rdSaveTimer = null;
        async function saveReturnDetails(fieldLabel, newValue) {
            savingEl.classList.remove('d-none');
            savedEl.classList.add('d-none');
            try {
                const res = await fetch('/api/itr-filings/' + filingId + '/return-details', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        itrType:       itrTypeSel.value    || null,
                        filingType:    filingTypeSel.value  || null,
                        returnOutcome: outcomeSel.value    || null,
                    })
                });
                if (res.ok) {
                    const updated = await res.json();
                    filingData.itrType      = updated.itrType;
                    filingData.filingType   = updated.filingType;
                    filingData.returnOutcome = updated.returnOutcome;
                    renderReturnDetailsBadges(filingData);
                    appendRdLog(fieldLabel, newValue);
                }
            } catch (_) {}
            savingEl.classList.add('d-none');
            savedEl.classList.remove('d-none');
            clearTimeout(rdSaveTimer);
            rdSaveTimer = setTimeout(() => savedEl.classList.add('d-none'), 2500);
        }

        itrTypeSel.addEventListener('change', function () {
            filingData.itrType = itrTypeSel.value || null;
            renderReturnDetailsBadges(filingData);
            saveReturnDetails('ITR Type', itrTypeSel.value);
        });
        filingTypeSel.addEventListener('change', function () {
            filingData.filingType = filingTypeSel.value || null;
            renderReturnDetailsBadges(filingData);
            saveReturnDetails('Filing Type', filingTypeSel.value);
        });
        outcomeSel.addEventListener('change', function () {
            filingData.returnOutcome = outcomeSel.value || null;
            renderReturnDetailsBadges(filingData);
            saveReturnDetails('Return Outcome', outcomeSel.value);
        });

        document.getElementById('rd_resetBtn').addEventListener('click', async function () {
            itrTypeSel.value    = '';
            filingTypeSel.value = '';
            outcomeSel.value    = '';
            filingData.itrType       = null;
            filingData.filingType    = null;
            filingData.returnOutcome = null;
            renderReturnDetailsBadges(filingData);
            await saveReturnDetails('Reset', '');
        });
    }

    // ── Income Notes ─────────────────────────────────────────────────
    function initIncomeNotes(data) {
        const ta         = document.getElementById('incomeNotesArea');
        const statusEl   = document.getElementById('incomeNotesSaveStatus');
        if (!ta) return;
        ta.value = (data.incomeData && data.incomeData._notes) || '';
        let debounceTimer = null;
        ta.addEventListener('input', function () {
            statusEl.textContent = 'Saving…';
            statusEl.classList.remove('d-none');
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(async () => {
                const notes = ta.value;
                if (!filingData.incomeData) filingData.incomeData = {};
                filingData.incomeData._notes = notes;
                try {
                    const res = await fetch('/api/itr-filings/' + filingId, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            preparer: filingData.preparer,
                            selectedIncomeHeads: filingData.selectedIncomeHeads,
                            incomeData: filingData.incomeData,
                        }),
                    });
                    if (res.ok) {
                        statusEl.textContent = 'Saved';
                        setTimeout(() => statusEl.classList.add('d-none'), 1500);
                    } else {
                        statusEl.textContent = 'Save failed';
                    }
                } catch (_) {
                    statusEl.textContent = 'Save failed';
                }
            }, 800);
        });
    }

    loadFiling();

    // ── Deductions ───────────────────────────────────────────────────
    function renderDeductionDocs(docs) {
        const list     = document.getElementById('deductionDocList');
        const countBdg = document.getElementById('deductionDocCount');
        countBdg.textContent = docs.length + ' doc' + (docs.length !== 1 ? 's' : '');
        if (!docs.length) {
            list.innerHTML = '<p class="text-secondary-light mb-0" style="font-size:.72rem">No documents uploaded yet.</p>';
            return;
        }
        list.innerHTML = docs.map(d => `
            <div class="doc-item d-flex align-items-center justify-content-between gap-10" data-ded-doc-id="${d.id}">
                <div class="d-flex align-items-center gap-8 overflow-hidden">
                    <iconify-icon icon="${mimeIcon(d.mimeType)}" class="text-lg text-secondary-light flex-shrink-0"></iconify-icon>
                    <div class="overflow-hidden">
                        <div class="fw-medium text-xs text-truncate" style="max-width:160px">${escHtml(d.name)}</div>
                        <div class="text-secondary-light" style="font-size:.65rem">${fmtFileSize(d.size)} · ${fmtDateTime(d.uploadedAt)}</div>
                    </div>
                </div>
                <div class="d-flex gap-6 flex-shrink-0">
                    <button type="button" class="btn btn-primary-light btn-sm radius-6 px-8 py-4 ded-download-btn" data-doc-id="${d.id}" title="Download">
                        <iconify-icon icon="lucide:download" class="text-xs"></iconify-icon>
                    </button>
                    <button type="button" class="btn btn-outline-danger-600 btn-sm radius-6 px-8 py-4 ded-delete-btn" data-doc-id="${d.id}" title="Delete">
                        <iconify-icon icon="lucide:trash-2" class="text-xs"></iconify-icon>
                    </button>
                </div>
            </div>`).join('');
    }

    function initDeductions(data) {
        const ded = data.deductions || { notes: '', documents: [] };
        document.getElementById('deductionNotes').value = ded.notes || '';
        renderDeductionDocs(ded.documents || []);
    }

    // Notes auto-save (debounced)
    let dedNotesTimer = null;
    document.getElementById('deductionNotes').addEventListener('input', function () {
        clearTimeout(dedNotesTimer);
        dedNotesTimer = setTimeout(async () => {
            const notes  = this.value;
            const saved  = document.getElementById('deductionSaved');
            const curDed = filingData.deductions || { notes: '', documents: [] };
            try {
                const res = await fetch('/api/itr-filings/' + filingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        preparer: filingData.preparer,
                        selectedIncomeHeads: filingData.selectedIncomeHeads,
                        incomeData: filingData.incomeData,
                        deductions: { ...curDed, notes },
                    }),
                });
                if (res.ok) {
                    filingData = await res.json();
                    saved.classList.remove('d-none');
                    setTimeout(() => saved.classList.add('d-none'), 2000);
                }
            } catch (_) {}
        }, 700);
    });

    // ── Deduction pending-upload helpers ──────────────────────────────
    function renderDedPendingPanel() {
        const panel    = document.getElementById('deductionPendingPanel');
        const listEl   = document.getElementById('deductionPendingList');
        const uploadBtn = document.getElementById('deductionDoUploadBtn');
        if (!dedPendingUploads.length) {
            panel.classList.add('d-none');
            listEl.innerHTML = '';
            return;
        }
        panel.classList.remove('d-none');
        listEl.innerHTML = '';
        dedPendingUploads.forEach((item, i) => {
            const row = document.createElement('div');
            row.className = 'd-flex align-items-center gap-8 p-8 radius-8 mb-6';
            row.style.cssText = 'background:#f8fafc;border:1px solid #e2e8f0;';
            row.innerHTML =
                `<iconify-icon icon="${mimeIconFromName(item.customName)}" class="text-secondary-light flex-shrink-0" style="font-size:1rem;"></iconify-icon>` +
                `<input type="text" class="form-control form-control-sm text-xs flex-grow-1 ded-pending-name-input" value="${escHtml(item.customName)}" data-idx="${i}" style="height:26px;min-width:0;" title="Rename before uploading">` +
                `<span class="text-xs text-secondary-light flex-shrink-0" style="white-space:nowrap;">${fmtFileSize(item.file.size)}</span>` +
                `<button type="button" class="btn radius-6 px-6 ded-remove-pending-btn flex-shrink-0" data-idx="${i}" style="background:#fee2e2;color:#dc2626;height:26px;border:none;font-size:.75rem;">` +
                `<iconify-icon icon="lucide:x" style="font-size:.75rem;vertical-align:middle;"></iconify-icon></button>`;
            listEl.appendChild(row);
        });
        uploadBtn.textContent = 'Upload ' + dedPendingUploads.length + ' file' + (dedPendingUploads.length > 1 ? 's' : '');
    }

    // Sync name edits in the pending panel
    document.getElementById('deductionPendingList').addEventListener('input', function (e) {
        const inp = e.target.closest('.ded-pending-name-input');
        if (!inp) return;
        const idx = parseInt(inp.dataset.idx);
        if (dedPendingUploads[idx]) dedPendingUploads[idx].customName = inp.value;
    });

    // Remove a pending file
    document.getElementById('deductionPendingList').addEventListener('click', function (e) {
        const btn = e.target.closest('.ded-remove-pending-btn');
        if (!btn) return;
        const idx = parseInt(btn.dataset.idx);
        dedPendingUploads.splice(idx, 1);
        renderDedPendingPanel();
    });

    // Deduction doc upload — queue files instead of uploading immediately
    document.getElementById('deductionDocUpload').addEventListener('change', function () {
        const files = Array.from(this.files);
        this.value = '';
        if (!files.length) return;
        files.forEach(f => dedPendingUploads.push({ file: f, customName: f.name }));
        renderDedPendingPanel();
    });

    // Do upload when user clicks the Upload button
    document.getElementById('deductionDoUploadBtn').addEventListener('click', async function () {
        const items = [...dedPendingUploads];
        if (!items.length) return;

        // Sync names from inputs one last time
        document.querySelectorAll('.ded-pending-name-input').forEach(inp => {
            const idx = parseInt(inp.dataset.idx);
            if (dedPendingUploads[idx]) dedPendingUploads[idx].customName = inp.value;
        });

        // Hide pending panel, show progress
        document.getElementById('deductionPendingPanel').classList.add('d-none');
        const progWrap = document.getElementById('deductionUploadProgress');
        const progList = document.getElementById('deductionProgList');
        progList.innerHTML = '';
        progWrap.classList.remove('d-none');

        const rowEls = items.map((item, i) => {
            const row = document.createElement('div');
            row.className = 'p-8 radius-8';
            row.style.cssText = 'background:#f8fafc;border:1px solid #e2e8f0;';
            row.innerHTML =
                `<div class="d-flex align-items-center justify-content-between gap-8 mb-6">` +
                `<div class="d-flex align-items-center gap-6 overflow-hidden">` +
                `<iconify-icon icon="${mimeIconFromName(item.customName)}" class="text-secondary-light flex-shrink-0" style="font-size:1rem;"></iconify-icon>` +
                `<span class="text-xs fw-medium text-truncate" style="max-width:160px;">${escHtml(item.customName)}</span>` +
                `</div>` +
                `<span class="text-xs text-secondary-light flex-shrink-0" id="dedProgStatus_${i}">Waiting…</span>` +
                `</div>` +
                `<div class="progress" style="height:4px;border-radius:2px;background:#e2e8f0;">` +
                `<div id="dedProgBar_${i}" class="progress-bar" role="progressbar" style="width:0%;background:#2563eb;transition:width .25s;"></div>` +
                `</div>`;
            progList.appendChild(row);
            return row;
        });

        function setBar(i, pct) {
            const el = document.getElementById('dedProgBar_' + i);
            if (el) el.style.width = pct + '%';
        }
        function setStatus(i, text, color) {
            const el = document.getElementById('dedProgStatus_' + i);
            if (el) { el.textContent = text; if (color) el.style.color = color; }
        }

        dedPendingUploads = [];

        for (let i = 0; i < items.length; i++) {
            const item = items[i];
            if (item.file.size > 10 * 1024 * 1024) {
                setBar(i, 100);
                const bar = document.getElementById('dedProgBar_' + i);
                if (bar) bar.style.background = '#dc2626';
                setStatus(i, 'Exceeds 10 MB', '#dc2626');
                continue;
            }
            setStatus(i, 'Reading…'); setBar(i, 20);
            try {
                const data = await readFileAsBase64(item.file);
                setBar(i, 50); setStatus(i, 'Uploading…');
                const res = await fetch('/api/itr-filings/' + filingId + '/deductions/documents', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: item.customName || item.file.name, size: item.file.size, mimeType: item.file.type, data }),
                });
                if (!res.ok) throw new Error((await res.json()).message);
                const doc = await res.json();
                setBar(i, 100); setStatus(i, 'Done ✓', '#16a34a');
                if (rowEls[i]) rowEls[i].style.borderColor = '#bbf7d0';
                if (!filingData.deductions) filingData.deductions = { notes: '', documents: [] };
                filingData.deductions.documents = [...(filingData.deductions.documents || []), doc];
            } catch (err) {
                setBar(i, 100);
                const bar = document.getElementById('dedProgBar_' + i);
                if (bar) bar.style.background = '#dc2626';
                setStatus(i, 'Failed', '#dc2626');
            }
        }
        renderDeductionDocs(filingData.deductions?.documents || []);
        setTimeout(() => progWrap.classList.add('d-none'), 1200);
    });

    // Deduction doc download / delete
    document.addEventListener('click', async function (e) {
        const dlBtn  = e.target.closest('.ded-download-btn');
        const delBtn = e.target.closest('.ded-delete-btn');

        if (dlBtn) {
            const docId = dlBtn.dataset.docId;
            const doc   = (filingData.deductions?.documents || []).find(d => d.id === docId);
            if (doc?.data) {
                const a = document.createElement('a');
                a.href = 'data:' + doc.mimeType + ';base64,' + doc.data;
                a.download = doc.name;
                a.click();
            }
        }

        if (delBtn) {
            const docId = delBtn.dataset.docId;
            const doc   = (filingData.deductions?.documents || []).find(d => d.id === docId);
            document.getElementById('deleteDocModalName').textContent = doc ? doc.name : docId;
            pendingDocDelete = async function () {
                delBtn.disabled = true;
                try {
                    const res = await fetch('/api/itr-filings/' + filingId + '/deductions/documents/' + docId, { method: 'DELETE' });
                    if (!res.ok) throw new Error();
                    if (filingData.deductions) {
                        filingData.deductions.documents = (filingData.deductions.documents || []).filter(d => d.id !== docId);
                        renderDeductionDocs(filingData.deductions.documents);
                    }
                } catch (_) { alert('Failed to delete document.'); delBtn.disabled = false; }
            };
            new bootstrap.Modal(document.getElementById('deleteDocModal')).show();
        }
    });

    // ── Payment Panel ────────────────────────────────────────────────
    (function initPayment() {
        // Panel elements
        const finalFeeBox   = document.getElementById('payFinalFeeBox');
        const elFinalFee    = document.getElementById('payFinalFee');
        const elTotalPaid   = document.getElementById('payTotalPaid');
        const elBalance     = document.getElementById('payBalance');
        const entryList     = document.getElementById('payEntryList');
        const entryEmpty    = document.getElementById('payEntryEmpty');
        const actionBar     = document.getElementById('payActionBar');
        const openModalBtn  = document.getElementById('payOpenModalBtn');
        const editBtn       = document.getElementById('payEditBtn');
        const deleteAllBtn  = document.getElementById('payDeleteAllBtn');
        const feeLogWrap    = document.getElementById('payFeeLogWrap');
        const feeLogEl      = document.getElementById('payFeeLog');
        const historyWrap   = document.getElementById('payHistoryWrap');

        // Modal elements
        const modalFeeInput      = document.getElementById('modalFeeInput');
        const modalDiscountInput = document.getElementById('modalDiscountInput');
        const modalFinalFee      = document.getElementById('modalFinalFee');
        const modalRemarksInput  = document.getElementById('modalRemarksInput');
        const modalHandledBy     = document.getElementById('modalHandledBy');
        const modalSubmitBtn     = document.getElementById('modalSubmitBtn');
        const modalPayError      = document.getElementById('modalPayError');
        const modalTitle         = document.getElementById('modalTitle');

        // Handled-by display elements
        const payHandledByRow    = document.getElementById('payHandledByRow');
        const payHandledByName   = document.getElementById('payHandledByName');
        const payStatusBadge     = document.getElementById('payStatusBadge');
        const payCollectFeeBtn   = document.getElementById('payCollectFeeBtn');

        // Load all employees into the "handled by" dropdown once
        (async function loadHandledByOptions() {
            try {
                const res = await fetch('/api/employees');
                const emps = await res.json();
                const active = emps.filter(e => e.status === 'Active' || !e.status);
                modalHandledBy.innerHTML = '<option value="">— Select employee —</option>' +
                    active.map(e => `<option value="${escHtml(e.name)}">${escHtml(e.name)}${e.designation ? ' (' + escHtml(e.designation) + ')' : ''}</option>`).join('');
            } catch (_) {}
        })();

        // localStorage keys for this filing
        const LS_SET_KEY = 'payFeeSet_' + filingId;
        const LS_LOG_KEY = 'payFeeLog_' + filingId;

        let currentFee = 0;
        let currentDiscount = 0;

        function fmt(n) {
            return '₹ ' + Number(n).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function fmtTime(iso) {
            const d = new Date(iso);
            return d.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) +
                   ', ' + d.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:true });
        }

        function getFeeLog() {
            try { return JSON.parse(localStorage.getItem(LS_LOG_KEY) || '[]'); } catch(_) { return []; }
        }

        function pushFeeLog(entry) {
            const log = getFeeLog();
            log.push(entry);
            localStorage.setItem(LS_LOG_KEY, JSON.stringify(log));
        }

        function renderFeeLog() {
            const log = getFeeLog();
            if (log.length === 0) { feeLogWrap.classList.add('d-none'); return; }
            feeLogWrap.classList.remove('d-none');
            feeLogEl.innerHTML = '';
            [...log].reverse().forEach(entry => {
                const div = document.createElement('div');
                div.className = 'radius-8 px-12 py-10 border';
                div.style.cssText = 'background:#f8fafc;';
                div.innerHTML =
                    // Row 1: action badge + timestamp
                    `<div class="d-flex justify-content-between align-items-center mb-8">` +
                    `<span class="badge text-xs fw-semibold px-8 py-4 radius-6" style="background:#e0f2fe;color:#0369a1;">${entry.action}</span>` +
                    `<span style="font-size:.68rem;color:#94a3b8;white-space:nowrap;">${fmtTime(entry.timestamp)}</span>` +
                    `</div>` +
                    // Row 2: Fee
                    `<div class="d-flex justify-content-between align-items-center py-4 border-bottom">` +
                    `<span style="font-size:.73rem;color:#64748b;">Fee</span>` +
                    `<span style="font-size:.73rem;font-weight:600;color:#334155;">${fmt(entry.fee)}</span>` +
                    `</div>` +
                    // Row 3: Discount (only if present)
                    (entry.discount > 0
                        ? `<div class="d-flex justify-content-between align-items-center py-4 border-bottom">` +
                          `<span style="font-size:.73rem;color:#64748b;">Discount</span>` +
                          `<span style="font-size:.73rem;font-weight:600;color:#334155;">${entry.discountLabel}</span>` +
                          `</div>`
                        : '') +
                    // Row 4: Final Fee (highlighted)
                    `<div class="d-flex justify-content-between align-items-center pt-6">` +
                    `<span style="font-size:.75rem;font-weight:700;color:#15803d;">Final Fee</span>` +
                    `<span style="font-size:.78rem;font-weight:700;color:#15803d;">${fmt(entry.finalFee)}</span>` +
                    `</div>` +
                    // Row 5: Remarks (only if present)
                    (entry.remarks
                        ? `<div class="mt-6 pt-6 border-top" style="font-size:.72rem;color:#94a3b8;font-style:italic;">"${entry.remarks}"</div>`
                        : '');
                feeLogEl.appendChild(div);
            });
        }

        function calcFinalFee() {
            const fee      = parseFloat(modalFeeInput.value) || 0;
            const disc     = parseFloat(modalDiscountInput.value) || 0;
            const isPercent = document.getElementById('discTypePercent').checked;
            const discAmt  = isPercent ? (fee * disc / 100) : disc;
            return Math.max(0, fee - discAmt);
        }

        function updateModalFinalFee() {
            modalFinalFee.textContent = fmt(calcFinalFee());
        }

        modalFeeInput.addEventListener('input', updateModalFinalFee);
        modalDiscountInput.addEventListener('input', updateModalFinalFee);
        document.getElementById('discTypeFixed').addEventListener('change', updateModalFinalFee);
        document.getElementById('discTypePercent').addEventListener('change', updateModalFinalFee);

        function markFeeSet() {
            localStorage.setItem(LS_SET_KEY, '1');
            actionBar.classList.add('d-none');
            editBtn.classList.remove('d-none');
            if (deleteAllBtn) deleteAllBtn.classList.remove('d-none');
            finalFeeBox.classList.remove('d-none');
            historyWrap.classList.remove('d-none');
        }

        function isFeeSet() {
            return localStorage.getItem(LS_SET_KEY) === '1';
        }

        function renderSummary(data) {
            currentFee      = data.fee || 0;
            currentDiscount = data.discount || 0;
            elFinalFee.textContent  = fmt(data.finalFee);
            elTotalPaid.textContent = fmt(data.totalPaid);
            if (data.handledBy) {
                payHandledByName.textContent = data.handledBy;
                payHandledByRow.classList.remove('d-none');
            } else {
                payHandledByRow.classList.add('d-none');
            }
            const refunded = data.totalRefunded || 0;
            const refundedRow = document.getElementById('payRefundedRow');
            const elRefunded  = document.getElementById('payTotalRefunded');
            if (refunded > 0) {
                elRefunded.textContent = '- ' + fmt(refunded);
                refundedRow.classList.remove('d-none');
            } else {
                refundedRow.classList.add('d-none');
            }
            const bal       = data.balance;
            const finalFee  = data.finalFee || 0;
            const totalPaid = data.totalPaid || 0;
            elBalance.textContent = fmt(bal);
            elBalance.className = 'text-xs fw-bold ' + (bal > 0 ? 'text-danger-600' : 'text-success-600');

            // ── Payment status badge ──────────────────────────────────
            // Only show badge when a fee has been explicitly saved
            const feeIsSet = data.fee > 0 || isFeeSet();
            if (feeIsSet) {
                const badges = {
                    FREE: {
                        bg: '#eef2ff', border: '#c7d2fe', color: '#3730a3',
                        dot: '#818cf8',
                        icon: `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
                        label: 'Free',
                    },
                    PAID: {
                        bg: '#f0fdf4', border: '#86efac', color: '#15803d',
                        dot: '#22c55e',
                        icon: `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
                        label: 'Paid',
                    },
                    PARTIAL: {
                        bg: '#fffbeb', border: '#fcd34d', color: '#92400e',
                        dot: '#f59e0b',
                        icon: `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>`,
                        label: 'Partial',
                    },
                    UNPAID: {
                        bg: '#fff1f2', border: '#fca5a5', color: '#be123c',
                        dot: '#f43f5e',
                        icon: `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
                        label: 'Unpaid',
                    },
                };
                let key;
                if (finalFee === 0)                          key = 'FREE';
                else if (bal <= 0 && totalPaid >= finalFee)  key = 'PAID';
                else if (totalPaid > 0 && bal > 0)           key = 'PARTIAL';
                else                                          key = 'UNPAID';

                const b = badges[key];
                payStatusBadge.style.cssText =
                    `display:inline-flex;align-items:center;gap:5px;padding:4px 10px;` +
                    `border-radius:100px;font-size:.72rem;font-weight:600;letter-spacing:.02em;` +
                    `background:${b.bg};border:1px solid ${b.border};color:${b.color};`;
                payStatusBadge.innerHTML =
                    `<span style="color:${b.color};">${b.icon}</span>` +
                    `${b.label}`;
                payStatusBadge.classList.remove('d-none');
            } else {
                payStatusBadge.classList.add('d-none');
            }

            // ── Collect Fee button visibility ─────────────────────────
            if (payCollectFeeBtn) {
                if (feeIsSet && (finalFee === 0 || bal <= 0)) {
                    payCollectFeeBtn.classList.add('d-none');
                } else {
                    payCollectFeeBtn.classList.remove('d-none');
                }
            }
        }

        function renderEntries(entries) {
            const cards = entryList.querySelectorAll('.pay-entry-card');
            cards.forEach(c => c.remove());
            if (entries.length === 0) { entryEmpty.classList.remove('d-none'); return; }
            entryEmpty.classList.add('d-none');
            [...entries].reverse().forEach((e, revIdx) => {
                const displayNum = entries.length - revIdx;
                const isRefund = e.type === 'refund';
                const card = document.createElement('div');
                card.className = 'pay-entry-card radius-8 overflow-hidden';
                card.style.cssText = isRefund
                    ? 'border:1px solid #fecaca;font-size:.78rem;'
                    : 'border:1px solid #e2e8f0;font-size:.78rem;';

                // Header row: serial + badge + amount + timestamp
                const hdrBg     = isRefund ? 'background:#fff1f2;border-bottom:1px solid #fecaca;' : 'background:#f0fdf4;border-bottom:1px solid #bbf7d0;';
                const amtColor  = isRefund ? '#dc2626' : '#16a34a';
                const amtPrefix = isRefund ? '- ' : '';
                const badge     = isRefund
                    ? `<span class="badge text-xs fw-semibold px-6 py-2 radius-4" style="background:#fee2e2;color:#b91c1c;font-size:.62rem;letter-spacing:.04em;">REFUND</span>`
                    : `<span class="badge text-xs fw-semibold px-6 py-2 radius-4" style="background:#dcfce7;color:#15803d;font-size:.62rem;letter-spacing:.04em;">CREDIT</span>`;
                let html =
                    `<div class="d-flex justify-content-between align-items-center px-12 py-8" style="${hdrBg}">` +
                    `<div class="d-flex align-items-center gap-8">` +
                    `<span class="text-xs fw-bold text-secondary-light" style="min-width:18px;">#${displayNum}</span>` +
                    badge +
                    `<span class="fw-bold" style="font-size:.85rem;white-space:nowrap;color:${amtColor};">${amtPrefix}${fmt(e.amount)}</span>` +
                    `</div>` +
                    `<div class="d-flex align-items-center gap-6">` +
                    `<span style="font-size:.65rem;color:#94a3b8;white-space:nowrap;">${fmtTime(e.timestamp)}</span>` +
                    `<button class="pay-delete-entry-btn btn btn-xs" data-entry-id="${e.id}" style="padding:2px 4px;border:none;background:transparent;color:#ef4444;line-height:1;flex-shrink:0;" title="Delete entry" data-testid="button-delete-entry-${e.id}">` +
                    `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>` +
                    `</button>` +
                    `</div>` +
                    `</div>`;

                // Detail rows
                const rows = [];
                if (isRefund) {
                    if (e.refundedTo)    rows.push(['Refund From', 'lucide:user-check',        '#ef4444', e.refundedTo]);
                    if (e.modeOfPayment) rows.push(['Mode',        'mdi:credit-card-outline',  '#f97316', e.modeOfPayment]);
                    if (e.note && e.note !== 'Refund') rows.push(['Remarks', 'lucide:message-square', '#8b5cf6', e.note]);
                } else {
                    if (e.paidTo)        rows.push(['Paid To',     'lucide:user-check',        '#3b82f6', e.paidTo]);
                    if (e.modeOfPayment) rows.push(['Mode',        'mdi:credit-card-outline',  '#10b981', e.modeOfPayment]);
                    if (e.note)          rows.push(['Remarks',     'lucide:message-square',    '#8b5cf6', e.note]);
                }

                if (rows.length) {
                    html += `<div class="px-12 py-8 d-flex flex-column gap-6">`;
                    rows.forEach(([label, icon, color, value]) => {
                        html +=
                            `<div class="d-flex align-items-start gap-8">` +
                            `<iconify-icon icon="${icon}" style="font-size:.8rem;color:${color};margin-top:1px;flex-shrink:0;"></iconify-icon>` +
                            `<span style="color:#94a3b8;min-width:52px;flex-shrink:0;">${label}</span>` +
                            `<span class="fw-medium text-primary-light" style="word-break:break-word;">${value}</span>` +
                            `</div>`;
                    });
                    html += `</div>`;
                }

                // Proof (only for non-refund entries)
                if (!isRefund && e.proofFileData) {
                    const isImg = e.proofFileName && /\.(png|jpg|jpeg|gif|webp)$/i.test(e.proofFileName);
                    html += `<div class="px-12 pb-10" style="border-top:1px solid #f1f5f9;">`;
                    html += `<div class="text-xs text-secondary-light mb-4 mt-6" style="letter-spacing:.03em;text-transform:uppercase;font-size:.65rem;">Payment Proof</div>`;
                    html += isImg
                        ? `<img src="${e.proofFileData}" alt="Proof" style="max-width:100%;max-height:100px;border-radius:6px;object-fit:contain;">`
                        : `<a href="${e.proofFileData}" download="${e.proofFileName || 'proof'}" class="d-flex align-items-center gap-6 text-primary-600" style="text-decoration:none;font-size:.75rem;"><iconify-icon icon="lucide:download" class="text-sm"></iconify-icon>${e.proofFileName || 'Download Proof'}</a>`;
                    html += `</div>`;
                }

                card.innerHTML = html;
                entryList.appendChild(card);

                // Attach delete button directly (reliable vs event delegation on dynamic content)
                const delEntryBtn = card.querySelector('.pay-delete-entry-btn');
                if (delEntryBtn) {
                    delEntryBtn.addEventListener('click', function(ev) {
                        ev.stopPropagation();
                        window._pendingDeleteEntryId = this.dataset.entryId;
                        const entryModal = document.getElementById('deleteEntryModal');
                        (bootstrap.Modal.getInstance(entryModal) || new bootstrap.Modal(entryModal)).show();
                    });
                }
            });
        }

        async function loadPayment() {
            try {
                const r = await fetch(`/api/itr-filings/${filingId}/payment`);
                if (!r.ok) return;
                const data = await r.json();
                renderSummary(data);
                renderEntries(data.entries);
                // Show fee panel if server has fee data OR localStorage flag is set
                if (data.fee > 0 || isFeeSet()) {
                    markFeeSet();
                }
                // Show refund button only when there is remaining refundable amount
                const refundBtn = document.getElementById('payRefundBtn');
                if (refundBtn) {
                    const paid     = data.totalPaid     || 0;
                    const refunded = data.totalRefunded || 0;
                    if (paid > 0 && paid > refunded) {
                        refundBtn.classList.remove('d-none');
                    } else {
                        refundBtn.classList.add('d-none');
                    }
                }
            } catch (_) {}
        }

        function openModal(isEdit) {
            modalTitle.textContent = isEdit ? 'Edit Payment' : 'Add Payment';
            modalPayError.classList.add('d-none');
            if (isEdit) {
                modalFeeInput.value      = currentFee > 0 ? currentFee : '';
                modalDiscountInput.value = currentDiscount > 0 ? currentDiscount : '';
                document.getElementById('discTypeFixed').checked = true;
                updateModalFinalFee();
            } else {
                modalFeeInput.value      = '';
                modalDiscountInput.value = '';
                modalFinalFee.textContent = fmt(0);
                document.getElementById('discTypeFixed').checked = true;
            }
            modalRemarksInput.value = '';
            modalHandledBy.value = '';
            new bootstrap.Modal(document.getElementById('addPaymentModal')).show();
        }

        openModalBtn.addEventListener('click', () => openModal(false));
        editBtn.addEventListener('click',      () => openModal(true));

        // Submit from modal
        modalSubmitBtn.addEventListener('click', async () => {
            modalPayError.classList.add('d-none');
            const fee      = parseFloat(modalFeeInput.value) || 0;
            const discVal  = parseFloat(modalDiscountInput.value) || 0;
            const isPercent = document.getElementById('discTypePercent').checked;
            const discount = isPercent ? (fee * discVal / 100) : discVal;
            const finalFee = Math.max(0, fee - discount);
            const remarks  = modalRemarksInput.value.trim();
            const handledBy = modalHandledBy.value.trim();
            const isEdit   = modalTitle.textContent === 'Edit Payment';

            if (fee < 0 || discVal < 0) {
                modalPayError.textContent = 'Values cannot be negative.';
                modalPayError.classList.remove('d-none');
                return;
            }

            if (!handledBy) {
                modalPayError.textContent = 'Please select who handled this payment.';
                modalPayError.classList.remove('d-none');
                return;
            }

            modalSubmitBtn.disabled = true;
            try {
                const pr = await fetch(`/api/itr-filings/${filingId}/payment`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fee, discount, handledBy })
                });
                if (!pr.ok) {
                    const e = await pr.json();
                    modalPayError.textContent = e.message || 'Failed to save fee.';
                    modalPayError.classList.remove('d-none');
                    return;
                }

                // Add fee log entry
                pushFeeLog({
                    action: isEdit ? 'Fee Edited' : 'Fee Set',
                    timestamp: new Date().toISOString(),
                    fee,
                    discount,
                    discountLabel: isPercent ? `${discVal}%` : fmt(discount),
                    finalFee,
                    remarks
                });

                bootstrap.Modal.getInstance(document.getElementById('addPaymentModal')).hide();
                markFeeSet();
                renderFeeLog();
                await loadPayment();
            } catch (_) {
                modalPayError.textContent = 'Network error.';
                modalPayError.classList.remove('d-none');
            } finally {
                modalSubmitBtn.disabled = false;
            }
        });

        // ── Collect Payment ──────────────────────────────────────────
        let cpFileData = null;
        let cpFileName = null;

        function cpGetModal() {
            return bootstrap.Modal.getOrCreateInstance(document.getElementById('collectPaymentModal'));
        }

        const cpAmountEl    = document.getElementById('cp_amount');
        const cpRemainingEl = document.getElementById('cp_remaining');
        const cpErrorEl     = document.getElementById('cp_error');
        const cpSubmitBtn   = document.getElementById('cp_submitBtn');
        const cpFileInput   = document.getElementById('cp_fileInput');
        const cpUploadBox   = document.getElementById('cp_uploadBox');
        const cpFilePreview = document.getElementById('cp_filePreview');
        const cpFileNameEl  = document.getElementById('cp_fileName');
        const cpFileIcon    = document.getElementById('cp_fileIcon');
        const cpImgThumb    = document.getElementById('cp_imgThumb');
        const cpThumbImg    = document.getElementById('cp_thumbImg');
        const cpFileRemove  = document.getElementById('cp_fileRemove');
        const cpPaidToSel   = document.getElementById('cp_paidTo');
        const cpModeSel     = document.getElementById('cp_modeOfPayment');

        function cpReset() {
            cpAmountEl.value = '';
            document.getElementById('cp_remarks').value = '';
            cpPaidToSel.value = '';
            cpModeSel.value = '';
            cpErrorEl.classList.add('d-none');
            cpFileData = null; cpFileName = null;
            cpFilePreview.classList.add('d-none');
            cpImgThumb.classList.add('d-none');
            cpThumbImg.src = '';
            cpFileInput.value = '';
            cpRemainingEl.textContent = '₹ 0.00';
            cpRemainingEl.className = 'text-xs fw-bold text-danger-600';
            cpSubmitBtn.disabled = false;
            cpSubmitBtn.innerHTML = '<iconify-icon icon="lucide:check-circle" class="me-4"></iconify-icon>Save Payment';
        }

        async function cpLoadPaidTo() {
            try {
                const res = await fetch('/api/paid-to');
                const items = await res.json();
                cpPaidToSel.innerHTML = '<option value="">— Select recipient —</option>' +
                    items.map(p => `<option value="${p.name}">${p.name}</option>`).join('');
            } catch (_) {}
        }

        async function cpLoadModeOfPayment() {
            try {
                const res = await fetch('/api/mode-of-payment');
                const items = await res.json();
                cpModeSel.innerHTML = '<option value="">— Select mode —</option>' +
                    items.map(m => `<option value="${m.name}">${m.name}</option>`).join('');
            } catch (_) {}
        }

        document.getElementById('payCollectFeeBtn').addEventListener('click', async () => {
            cpReset();
            // Mirror balance summary into modal header strip
            const r = await fetch(`/api/itr-filings/${filingId}/payment`);
            if (r.ok) {
                const d = await r.json();
                document.getElementById('cp_finalFee').textContent  = fmt(d.finalFee);
                document.getElementById('cp_totalPaid').textContent = fmt(d.totalPaid);
                document.getElementById('cp_balance').textContent   = fmt(d.balance);
                cpAmountEl.dataset.balance = d.balance;
            }
            await Promise.all([cpLoadPaidTo(), cpLoadModeOfPayment()]);
            cpGetModal().show();
        });

        // Live remaining-balance calculation
        cpAmountEl.addEventListener('input', () => {
            const bal = parseFloat(cpAmountEl.dataset.balance) || 0;
            const amt = parseFloat(cpAmountEl.value) || 0;
            const rem = bal - amt;
            cpRemainingEl.textContent = fmt(rem);
            cpRemainingEl.className = 'text-xs fw-bold ' + (rem <= 0 ? 'text-success-600' : 'text-danger-600');
        });

        // File upload
        cpUploadBox.addEventListener('click', () => cpFileInput.click());
        cpUploadBox.addEventListener('dragover', e => { e.preventDefault(); cpUploadBox.style.background = '#f0f9ff'; });
        cpUploadBox.addEventListener('dragleave', () => { cpUploadBox.style.background = '#f8fafc'; });
        cpUploadBox.addEventListener('drop', e => {
            e.preventDefault(); cpUploadBox.style.background = '#f8fafc';
            if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
        });
        cpFileInput.addEventListener('change', () => { if (cpFileInput.files[0]) handleFile(cpFileInput.files[0]); });
        cpFileRemove.addEventListener('click', () => {
            cpFileData = null; cpFileName = null;
            cpFilePreview.classList.add('d-none');
            cpImgThumb.classList.add('d-none');
            cpThumbImg.src = '';
            cpFileInput.value = '';
        });

        function handleFile(file) {
            if (file.size > 5 * 1024 * 1024) {
                cpErrorEl.textContent = 'File exceeds 5 MB limit.';
                cpErrorEl.classList.remove('d-none');
                return;
            }
            cpErrorEl.classList.add('d-none');
            cpFileName = file.name;
            const isImg = /\.(png|jpg|jpeg|gif|webp)$/i.test(file.name);
            cpFileIcon.setAttribute('icon', isImg ? 'lucide:image' : 'lucide:file-check');
            cpFileNameEl.textContent = file.name;
            cpFilePreview.classList.remove('d-none');
            const reader = new FileReader();
            reader.onload = ev => {
                cpFileData = ev.target.result;
                if (isImg) {
                    cpThumbImg.src = cpFileData;
                    cpImgThumb.classList.remove('d-none');
                }
            };
            reader.readAsDataURL(file);
        }

        // Submit
        cpSubmitBtn.addEventListener('click', async () => {
            const amount = parseFloat(cpAmountEl.value);
            if (!amount || amount <= 0) {
                cpErrorEl.textContent = 'Please enter a valid amount.';
                cpErrorEl.classList.remove('d-none');
                return;
            }
            if (!cpPaidToSel.value) {
                cpErrorEl.textContent = 'Please select who the payment was paid to.';
                cpErrorEl.classList.remove('d-none');
                cpPaidToSel.focus();
                return;
            }
            if (!cpModeSel.value) {
                cpErrorEl.textContent = 'Please select a mode of payment.';
                cpErrorEl.classList.remove('d-none');
                cpModeSel.focus();
                return;
            }
            cpErrorEl.classList.add('d-none');
            cpSubmitBtn.disabled = true;
            cpSubmitBtn.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Saving...';
            try {
                const body = {
                    amount,
                    paidTo: cpPaidToSel.value || undefined,
                    modeOfPayment: cpModeSel.value || undefined,
                    note: document.getElementById('cp_remarks').value.trim() || undefined,
                    proofFileName: cpFileName || undefined,
                    proofFileData: cpFileData || undefined,
                };
                const res = await fetch(`/api/itr-filings/${filingId}/payment/entries`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                if (!res.ok) throw new Error((await res.json()).message || 'Failed to save.');
                cpGetModal().hide();
                await loadPayment();
            } catch (e) {
                cpErrorEl.textContent = e.message || 'Network error.';
                cpErrorEl.classList.remove('d-none');
                cpSubmitBtn.disabled = false;
                cpSubmitBtn.innerHTML = '<iconify-icon icon="lucide:check-circle" class="me-4"></iconify-icon>Save Payment';
            }
        });

        // ── Refund Modal ──────────────────────────────────────────────
        (function initRefund() {
            const rfAmountEl  = document.getElementById('rf_amount');
            const rfPaidToSel = document.getElementById('rf_paidTo');
            const rfRemarksEl = document.getElementById('rf_remarks');
            const rfErrorEl   = document.getElementById('rf_error');
            const rfSubmitBtn = document.getElementById('rf_submitBtn');
            const rfTotalPaid = document.getElementById('rf_totalPaid');
            const rfBalance   = document.getElementById('rf_balance');

            function getModal() {
                return new bootstrap.Modal(document.getElementById('refundModal'), { backdrop: 'static' });
            }
            let rfModal       = null;
            let rfMaxAmount   = 0;

            async function rfLoadPaidTo() {
                try {
                    const res   = await fetch('/api/paid-to');
                    const items = await res.json();
                    rfPaidToSel.innerHTML = '<option value="">— Select —</option>' +
                        items.map(p => `<option value="${p.name}">${p.name}</option>`).join('');
                } catch (_) {}
            }

            function rfReset() {
                rfAmountEl.value      = '';
                rfPaidToSel.innerHTML = '<option value="">— Select —</option>';
                rfRemarksEl.value     = '';
                rfErrorEl.textContent = '';
                rfErrorEl.classList.add('d-none');
                rfSubmitBtn.disabled  = false;
                rfSubmitBtn.innerHTML = '<iconify-icon icon="lucide:undo-2" class="text-sm me-4"></iconify-icon>Issue Refund';
            }

            document.getElementById('payRefundBtn').addEventListener('click', async () => {
                rfReset();
                rfMaxAmount = 0;
                try {
                    const r = await fetch(`/api/itr-filings/${filingId}/payment`);
                    if (r.ok) {
                        const d = await r.json();
                        const alreadyRefunded = d.totalRefunded || 0;
                        rfMaxAmount = Math.max(0, (d.totalPaid || 0) - alreadyRefunded);
                        rfTotalPaid.textContent = fmt(d.totalPaid);
                        rfBalance.textContent   = fmt(d.totalRefunded || 0);
                        rfAmountEl.max = rfMaxAmount;
                    }
                } catch (_) {}
                await rfLoadPaidTo();
                rfModal = getModal();
                rfModal.show();
            });

            rfSubmitBtn.addEventListener('click', async () => {
                const amount = parseFloat(rfAmountEl.value);
                const from   = rfPaidToSel.value.trim();

                if (!amount || amount <= 0) {
                    rfErrorEl.textContent = 'Please enter a valid refund amount.';
                    rfErrorEl.classList.remove('d-none');
                    rfAmountEl.focus();
                    return;
                }
                if (amount > rfMaxAmount) {
                    rfErrorEl.textContent = rfMaxAmount <= 0
                        ? 'No refundable amount remaining — the full paid amount has already been refunded.'
                        : `Cannot exceed remaining refundable amount: ${fmt(rfMaxAmount)}.`;
                    rfErrorEl.classList.remove('d-none');
                    rfAmountEl.focus();
                    return;
                }
                if (!from) {
                    rfErrorEl.textContent = 'Please select who the refund is issued from.';
                    rfErrorEl.classList.remove('d-none');
                    rfPaidToSel.focus();
                    return;
                }
                rfErrorEl.classList.add('d-none');
                rfSubmitBtn.disabled  = true;
                rfSubmitBtn.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Saving...';
                try {
                    const res = await fetch(`/api/itr-filings/${filingId}/payment/refunds`, {
                        method:  'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body:    JSON.stringify({
                            amount,
                            refundedTo: from,
                            reason:     rfRemarksEl.value.trim() || undefined,
                        }),
                    });
                    if (!res.ok) throw new Error((await res.json()).message || 'Failed to save refund.');
                    if (rfModal) { rfModal.hide(); rfModal = null; }
                    await loadPayment();
                } catch (err) {
                    rfErrorEl.textContent = err.message || 'Network error. Please try again.';
                    rfErrorEl.classList.remove('d-none');
                    rfSubmitBtn.disabled  = false;
                    rfSubmitBtn.innerHTML = '<iconify-icon icon="lucide:undo-2" class="text-sm me-4"></iconify-icon>Issue Refund';
                }
            });
        })();

        // ── Confirm: delete all payment data ──────────────────────────
        document.getElementById('deletePaymentConfirmBtn').addEventListener('click', async function() {
            this.disabled = true;
            this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Deleting...';
            try {
                const res = await fetch(`/api/itr-filings/${filingId}/payment`, { method: 'DELETE' });
                if (!res.ok) throw new Error('Failed');
                const m = bootstrap.Modal.getInstance(document.getElementById('deletePaymentModal'));
                if (m) m.hide();
                localStorage.removeItem('payFeeSet_' + filingId);
                localStorage.removeItem('payFeeLog_' + filingId);
                window.location.reload();
            } catch {
                this.disabled = false;
                this.innerHTML = '<iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon>Delete All';
                alert('Failed to delete payment data. Please try again.');
            }
        });

        // ── Confirm: delete single entry ───────────────────────────────
        document.getElementById('deleteEntryConfirmBtn').addEventListener('click', async function() {
            const entryId = window._pendingDeleteEntryId;
            if (!entryId) return;
            this.disabled = true;
            this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Deleting...';
            try {
                const res = await fetch(`/api/itr-filings/${filingId}/payment/entries/${entryId}`, { method: 'DELETE' });
                if (!res.ok) throw new Error('Failed');
                const m = bootstrap.Modal.getInstance(document.getElementById('deleteEntryModal'));
                if (m) m.hide();
                window._pendingDeleteEntryId = null;
                this.disabled = false;
                this.innerHTML = '<iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon>Delete';
                await loadPayment();
            } catch {
                this.disabled = false;
                this.innerHTML = '<iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon>Delete';
                alert('Failed to delete entry. Please try again.');
            }
        });

        renderFeeLog();
        loadPayment();
    })();

    // ── Confirm: delete document (income or deduction) ─────────────
    document.getElementById('deleteDocConfirmBtn').addEventListener('click', async function () {
        if (typeof pendingDocDelete !== 'function') return;
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Deleting...';
        const modal = bootstrap.Modal.getInstance(document.getElementById('deleteDocModal'));
        await pendingDocDelete();
        pendingDocDelete = null;
        if (modal) modal.hide();
        this.disabled = false;
        this.innerHTML = '<iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon>Delete';
    });

    // ── Delete Filing ─────────────────────────────────────────────
    (function initDeleteFiling() {
        const delBtn        = document.getElementById('deleteFilingBtn');
        const delPanInput   = document.getElementById('del_panInput');
        const delErrorEl    = document.getElementById('del_error');
        const delConfirmBtn = document.getElementById('del_confirmBtn');

        delBtn.addEventListener('click', () => {
            delPanInput.value      = '';
            delErrorEl.textContent = '';
            delErrorEl.classList.add('d-none');
            delConfirmBtn.disabled  = false;
            delConfirmBtn.innerHTML = '<iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon>Delete Permanently';
            new bootstrap.Modal(document.getElementById('deleteFilingModal')).show();
        });

        delConfirmBtn.addEventListener('click', async () => {
            const pan = delPanInput.value.trim().toUpperCase();
            if (!pan) {
                delErrorEl.textContent = 'Please enter the client PAN to confirm.';
                delErrorEl.classList.remove('d-none');
                delPanInput.focus();
                return;
            }
            delErrorEl.classList.add('d-none');
            delConfirmBtn.disabled  = true;
            delConfirmBtn.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Deleting...';
            try {
                const res = await fetch(`/api/itr-filings/${filingId}`, {
                    method:  'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ pan }),
                });
                if (!res.ok) {
                    const err = await res.json();
                    throw new Error(err.message || 'Deletion failed.');
                }
                // Redirect to filing list after successful deletion
                window.location.href = '/services/itr-individual';
            } catch (err) {
                delErrorEl.textContent = err.message || 'Network error. Please try again.';
                delErrorEl.classList.remove('d-none');
                delConfirmBtn.disabled  = false;
                delConfirmBtn.innerHTML = '<iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon>Delete Permanently';
            }
        });
    })();


})();
</script>
