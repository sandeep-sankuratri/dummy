                    <select id="cp_paidTo" class="form-select radius-8">
                        <option value="">— Select recipient —</option>
                    </select>
                </div>

                <!-- Mode of Payment -->
                <div class="mb-14">
                    <label class="form-label fw-semibold text-primary-light text-sm mb-6">Mode of Payment <span class="text-danger-600">*</span></label>
                    <select id="cp_modeOfPayment" class="form-select radius-8">
                        <option value="">— Select mode —</option>
                    </select>
                </div>

                <!-- Payment Proof Upload -->
                <div class="mb-14">
                    <label class="form-label fw-semibold text-primary-light text-sm mb-6">
