                        <div class="text-xs text-secondary-light mt-4">Click or drag a file here</div>
                        <div class="text-secondary-light" style="font-size:.68rem;">JPG, PNG, PDF, max 5 MB</div>
                        <input type="file" id="cp_fileInput" accept="image/*,.pdf" class="d-none">
                    </div>
                    <div id="cp_filePreview" class="mt-6 d-none">
                        <div class="d-flex align-items-center gap-8 px-12 py-8 radius-8" style="background:#f0fdf4;border:1px solid #bbf7d0;">
                            <iconify-icon id="cp_fileIcon" icon="lucide:file-check" class="text-success-600 text-lg"></iconify-icon>
                            <span id="cp_fileName" class="text-xs fw-semibold text-success-700 flex-fill" style="word-break:break-all;"></span>
