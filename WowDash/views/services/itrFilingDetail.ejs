    async function submitAction(type, { btnEl, loadingLabel, doneLabel, trackerStatus }) {
        const textEl     = document.getElementById('actionText');
        const senderName = getActiveSenderName();
        if (!senderName) {
            alert('Please select an acting member (Tax Preparer, Caller, or Manager) before submitting.');
            return;
        }
        const notifyChk  = document.getElementById('notifyPreparerChk');
        const shouldNotify = notifyChk && notifyChk.checked && filingData && filingData.preparer;
        const notifyInfo   = shouldNotify ? 'Tax Preparer Notified - ' + filingData.preparer : null;
        btnEl.disabled = true;
        btnEl.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="text-sm"></iconify-icon>' + loadingLabel;
        try {
            if (type === 'estimate' || type === 'revised_estimate') {
                const payload = { type, preparedAt: new Date().toISOString(), remarks: textEl.value.trim(), senderName, senderRole: activeRole,
                    files: actionAttachments.map(({fileName,fileSize,fileMimeType,fileData}) => ({fileName,fileSize,fileMimeType,fileData})) };
                const res = await fetch('/api/itr-filings/' + filingId + '/estimate', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Server returned ' + res.status);
                estimatesStored.push(await res.json());
                renderActivityLog();
                updateEstimateButtonLabel();
            } else {
                const payload = { message: textEl.value.trim(), type, senderName, senderRole: activeRole,
                    files: actionAttachments.map(({fileName,fileSize,fileMimeType,fileData}) => ({fileName,fileSize,fileMimeType,fileData})) };
                const res = await fetch('/api/itr-filings/' + filingId + '/info-requests', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Server returned ' + res.status);
                const saved = await res.json();
                allInfoRequests.push(saved);
                renderActivityLog();
            }
            // If notify is ticked, also add a notify_preparer entry to the Action History
            if (shouldNotify) {
                const notifyRes = await fetch('/api/itr-filings/' + filingId + '/info-requests', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type: 'notify_preparer', message: notifyInfo, senderName: senderName || 'System', senderRole: activeRole || 'system' })
                });
                if (notifyRes.ok) {
                    allInfoRequests.push(await notifyRes.json());
                    renderActivityLog();
                }
                notifyChk.checked = false;
            }
            clearActionForm();
            clearActingMember();
            await pushTrackerStatus(trackerStatus, null, senderName, notifyInfo);
        } catch (err) {
            console.error('submitAction error:', err);
            alert('Failed to save. Please try again.');
        } finally {
            btnEl.disabled = false;
            btnEl.innerHTML = doneLabel;
        }
    }

