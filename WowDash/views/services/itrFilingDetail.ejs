    // ── File attach button ──
    document.getElementById('actionFileBtn').addEventListener('click', function () {
        document.getElementById('actionFile').click();
    });

    document.getElementById('actionFile').addEventListener('change', async function () {
        const files = Array.from(this.files || []);
        if (!files.length) return;
        const inputEl = this;
        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            const label = files.length > 1 ? `Reading file ${i + 1} of ${files.length}…` : 'Reading file…';
            setActionUploadProgress(5, label);
            try {
                const fileData = await new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onprogress = ev => {
                        if (ev.lengthComputable)
                            setActionUploadProgress(Math.round(5 + (ev.loaded / ev.total) * 90), label);
                    };
                    reader.onload = ev => resolve(ev.target.result);
                    reader.onerror = () => reject(new Error('Read failed'));
                    reader.readAsDataURL(file);
                });
                setActionUploadProgress(null);
                addAttachment({ fileName: file.name, fileSize: file.size, fileMimeType: file.type, fileData });
            } catch (_) {
                setActionUploadProgress(null);
                alert('Could not read "' + file.name + '". Skipping.');
            }
        }
        inputEl.value = '';
    });

    // ── Paste image support ──
    (function () {
        let pasteHintTimer = null;
        const pasteBtn = document.getElementById('actionPasteBtn');

        pasteBtn.addEventListener('click', function () {
            pasteBtn.innerHTML = '<iconify-icon icon="lucide:clipboard-paste" style="font-size:.9rem;color:#6366f1;"></iconify-icon><span style="color:#6366f1;">Press Ctrl+V now…</span>';
            clearTimeout(pasteHintTimer);
            pasteHintTimer = setTimeout(() => {
                pasteBtn.innerHTML = '<iconify-icon icon="lucide:clipboard-paste" class="text-secondary-light" style="font-size:.9rem;"></iconify-icon><span class="text-secondary-light">Paste Image</span>';
            }, 4000);
        });

        async function applyPaste(e) {
            const items = (e.clipboardData || window.clipboardData)?.items;
            if (!items) return;
            let found = false;
            for (const item of items) {
                if (item.type.startsWith('image/')) {
                    const blob = item.getAsFile();
                    if (!blob) continue;
                    if (!found) {
                        e.preventDefault();
                        clearTimeout(pasteHintTimer);
                        pasteBtn.innerHTML = '<iconify-icon icon="lucide:clipboard-paste" class="text-secondary-light" style="font-size:.9rem;"></iconify-icon><span class="text-secondary-light">Paste Image</span>';
                    }
                    found = true;
                    const label = 'Reading pasted image…';
                    setActionUploadProgress(5, label);
                    try {
                        const fileData = await new Promise((resolve, reject) => {
                            const reader = new FileReader();
                            reader.onprogress = ev => {
                                if (ev.lengthComputable)
                                    setActionUploadProgress(Math.round(5 + (ev.loaded / ev.total) * 90), label);
                            };
                            reader.onload = ev => resolve(ev.target.result);
                            reader.onerror = () => reject(new Error('Read failed'));
                            reader.readAsDataURL(blob);
                        });
                        setActionUploadProgress(null);
                        addAttachment({ fileName: 'pasted-image.png', fileSize: blob.size, fileMimeType: blob.type || 'image/png', fileData });
                    } catch (_) {
                        setActionUploadProgress(null);
                    }
                }
            }
        }

        document.addEventListener('paste', applyPaste);
    })();

