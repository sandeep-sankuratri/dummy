                    <textarea id="reassignManagerRemarks" class="form-control text-sm" rows="3" placeholder="Reason for reassignment…" style="resize:none;"></textarea>
                </div>
                <div>
                    <label class="form-label text-xs fw-semibold">Acting as <span class="text-danger-600">*</span></label>
                    <select id="reassignManagerActingSelect" class="form-select form-select-sm text-xs">
                        <option value="">Select acting member…</option>
                    </select>
                </div>
                <div id="reassignManagerError" class="text-danger-600 text-xs mt-10 d-none"></div>
            </div>
            <div class="modal-footer border-top py-12 px-24 d-flex flex-nowrap gap-8 justify-content-end">
                <button type="button" class="btn border border-secondary-600 text-sm px-16 py-8 radius-8" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmReassignManagerBtn" class="btn btn-primary text-sm px-16 py-8 radius-8 d-inline-flex align-items-center gap-1">
                    <iconify-icon icon="lucide:check" class="text-md"></iconify-icon>Confirm
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ══ REASSIGN TAX PREPARER MODAL ════════════════════════════ -->
<div class="modal fade" id="reassignPreparerModal" tabindex="-1" aria-labelledby="reassignPreparerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content radius-12">
            <div class="modal-header border-bottom py-16 px-24">
                <h6 class="modal-title fw-semibold d-flex align-items-center gap-8" id="reassignPreparerModalLabel">
                    <iconify-icon icon="lucide:file-check" class="text-primary-600 text-lg"></iconify-icon>
                    Reassign Tax Preparer
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-24 py-16">
                <p class="text-secondary-light text-xs mb-12">Current Tax Preparer: <strong id="reassignPreparerCurrentName">—</strong></p>
                <div class="mb-14">
                    <label class="form-label text-xs fw-semibold">New Tax Preparer</label>
                    <select id="reassignPreparerSelect" class="form-select form-select-sm text-xs">
                        <option value="">Select a Tax Preparer…</option>
                    </select>
                </div>
                <div class="mb-14">
                    <label class="form-label text-xs fw-semibold">Remarks <span class="text-secondary-light fw-normal">(optional)</span></label>
                    <textarea id="reassignPreparerRemarks" class="form-control text-sm" rows="3" placeholder="Reason for reassignment…" style="resize:none;"></textarea>
                </div>
                <div>
                    <label class="form-label text-xs fw-semibold">Acting as <span class="text-danger-600">*</span></label>
                    <select id="reassignPreparerActingSelect" class="form-select form-select-sm text-xs">
                        <option value="">Select acting member…</option>
                    </select>
                </div>
                <div id="reassignPreparerError" class="text-danger-600 text-xs mt-10 d-none"></div>
            </div>
            <div class="modal-footer border-top py-12 px-24 d-flex flex-nowrap gap-8 justify-content-end">
                <button type="button" class="btn border border-secondary-600 text-sm px-16 py-8 radius-8" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmReassignPreparerBtn" class="btn btn-primary text-sm px-16 py-8 radius-8 d-inline-flex align-items-center gap-1" >
                    <iconify-icon icon="lucide:check" class="text-md"></iconify-icon>Confirm
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const filingId = '<%= filingId %>';
    let filingData = null;
    let clientData = null;
    let preparers = [];
    let callers   = [];
    let managers  = [];
    let sources   = [];
    let pendingDocDelete = null;
    let dedPendingUploads = [];

    // ── Income head config ──────────────────────────────────────────
    const INCOME_HEADS = [
        { key: 'Salary',              label: 'Salary',               icon: 'lucide:briefcase',       color: '#4f46e5', fields: [
            {id:'employerName',    label:'Employer Name',               type:'text'},
            {id:'grossSalary',     label:'Gross Salary (₹)',            type:'number'},
            {id:'professionalTax', label:'Professional Tax Paid (₹)',   type:'number'},
            {id:'tdsDeducted',     label:'TDS Deducted (₹)',            type:'number'},
        ]},
        { key: 'Capital Gains',       label: 'Capital Gains',        icon: 'lucide:trending-up',     color: '#17a248', fields: [
            {id:'shortTermGains',  label:'Short Term Capital Gains (₹)', type:'number'},
            {id:'longTermGains',   label:'Long Term Capital Gains (₹)',  type:'number'},
            {id:'taxPaid',         label:'Tax Paid on Capital Gains (₹)',type:'number'},
        ]},
        { key: 'House Property',      label: 'House Property',       icon: 'lucide:home',            color: '#d97706', fields: [
            {id:'propertyAddress', label:'Property Address',             type:'text'},
            {id:'annualValue',     label:'Annual Rental Value (₹)',      type:'number'},
            {id:'municipalTax',    label:'Municipal Tax Paid (₹)',       type:'number'},
            {id:'interestOnLoan',  label:'Interest on Housing Loan (₹)', type:'number'},
        ]},
        { key: 'Business/Profession', label: 'Business / Profession', icon: 'lucide:store',          color: '#0891b2', fields: [
            {id:'businessName',    label:'Business / Profession Name',  type:'text'},
            {id:'grossReceipts',   label:'Gross Receipts / Turnover (₹)',type:'number'},
            {id:'netProfit',       label:'Net Profit / Loss (₹)',        type:'number'},
        ]},
        { key: 'Foreign Income',      label: 'Foreign Income',       icon: 'lucide:globe',           color: '#dc2626', fields: [
            {id:'country',         label:'Country',                      type:'text'},
            {id:'natureOfIncome',  label:'Nature of Income',             type:'text'},
            {id:'amountINR',       label:'Amount (₹)',                   type:'number'},
            {id:'taxPaidAbroad',   label:'Tax Paid Abroad (₹)',          type:'number'},
        ]},
        { key: 'Other Sources',       label: 'Other Sources',        icon: 'lucide:more-horizontal',  color: '#64748b', fields: [
            {id:'description',     label:'Source Description',           type:'text'},
            {id:'amount',          label:'Amount (₹)',                   type:'number'},
        ]},
    ];

    // ── Helpers ─────────────────────────────────────────────────────
    function fmtDateTime(iso) {
        if (!iso) return '—';
        const d = new Date(iso);
        return d.toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'})
             + ', ' + d.toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'});
    }
    function set(id, v) {
        const el = document.getElementById(id);
        if (!el) return;
        const span = el.querySelector('.copy-val');
        if (span) span.textContent = v || '—';
        else el.textContent = v || '—';
    }

    // ── Copy field handler ────────────────────────────────────────────
    const _COPY_SVG  = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
    const _CHECK_SVG = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.copy-btn');
        if (!btn) return;
        let text = '';
        if (btn.id === 'c_itrCopyBtn') {
            text = (clientData && clientData.itrPassword) || '';
        } else {
            const parent = btn.closest('[id^="v_c_"]');
            const valSpan = parent ? parent.querySelector('.copy-val') : null;
            text = valSpan ? valSpan.textContent.trim() : '';
        }
        if (!text || text === '—') return;
        navigator.clipboard.writeText(text).then(() => {
            btn.innerHTML = _CHECK_SVG;
            btn.style.color = '#16a34a';
            setTimeout(() => { btn.innerHTML = _COPY_SVG; btn.style.color = '#cbd5e1'; }, 1500);
        }).catch(() => {});
    });
    function showEl(id, show) { const el = document.getElementById(id); if (!el) return; el.classList.toggle('d-none', !show); }
    function showDFlex(id, show) {
        const el = document.getElementById(id);
        if (!el) return;
        if (show) { el.classList.remove('d-none'); el.classList.add('d-flex'); }
        else       { el.classList.add('d-none');   el.classList.remove('d-flex'); }
    }
    function escHtml(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function fmtFileSize(b) {
        if (!b) return '0 B';
        if (b < 1024) return b + ' B';
        if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
        return (b/1048576).toFixed(1) + ' MB';
    }
    function mimeIcon(t) {
        if (!t) return 'lucide:file';
        if (t.includes('pdf'))   return 'lucide:file-text';
        if (t.includes('image')) return 'lucide:file-image';
        if (t.includes('word') || t.includes('docx')) return 'lucide:file-text';
        if (t.includes('excel') || t.includes('xlsx')) return 'lucide:table';
        return 'lucide:file';
    }

    // ── Progress tracker ─────────────────────────────────────────────
    function getStatusColor(status) {
        const match = s2Options.find(o => o.name.toLowerCase() === (status || '').toLowerCase());
        return match && match.color ? match.color : '#0d9488';
    }

    function renderTracker(data) {
        const history = (data.statusHistory && data.statusHistory.length)
            ? data.statusHistory
            : [{ status: 'Opened', timestamp: data.assignedDate }];

        const tracker = document.getElementById('progressTracker');
        const badge   = document.getElementById('tracker_currentBadge');

        // Current badge = last stage
        const lastStage = history[history.length - 1].status;
        if (badge) {
            badge.textContent = lastStage;
        }

        // Build steps
        tracker.innerHTML = history.map((entry, idx) => {
            const isLast   = idx === history.length - 1;
            const stateClass = isLast ? 't-active' : 't-done';
            const color    = getStatusColor(entry.status);

            // Icon: first step uses a user-check, done steps get a checkmark, active step gets a flag
            let circleInner;
            if (!isLast) {
                circleInner = `<iconify-icon icon="lucide:check" style="font-size:18px"></iconify-icon>`;
            } else if (idx === 0) {
                circleInner = `<iconify-icon icon="lucide:user-check" style="font-size:17px"></iconify-icon>`;
            } else {
                circleInner = `<iconify-icon icon="lucide:flag" style="font-size:17px"></iconify-icon>`;
            }

            const circleStyle = isLast
                ? `background:${color};border-color:${color};box-shadow:0 0 0 4px ${color}28;`
                : `background:${color};border-color:${color};`;

            // updatedBy: dedicated name field; fallback: note when it's a plain name (not a → reassignment)
            const nameToShow = entry.updatedBy || (entry.note && !entry.note.includes('→') ? entry.note : '');
            const updatedByHtml = nameToShow
                ? `<div class="tracker-by"><span style="opacity:.6;font-size:.55rem;letter-spacing:.02em;text-transform:uppercase;">by</span> ${escHtml(nameToShow)}</div>`
                : '';
            const noteHtml = (entry.note && entry.note.includes('→'))
                ? `<div class="tracker-note">${escHtml(entry.note)}</div>`
                : '';
            const meta = (updatedByHtml || noteHtml)
                ? `<div class="tracker-meta">${updatedByHtml}${noteHtml}</div>`
                : '';
            const preparerHtml = entry.preparerName
                ? `<div style="display:flex;align-items:flex-start;justify-content:center;gap:0;background:#eff6ff;border:1px solid #bfdbfe;border-radius:4px;padding:2px 6px;margin-top:3px;font-size:.6rem;color:#1d4ed8;word-break:break-word;line-height:1.4;">
                    <span style="text-align:center;">${escHtml(entry.preparerName)}</span>
                  </div>`
                : '';
            const notifyHtml = entry.notifyInfo
                ? `<div style="display:flex;align-items:flex-start;justify-content:center;gap:0;background:#fff7ed;border:1px solid #fed7aa;border-radius:4px;padding:2px 6px;margin-top:3px;font-size:.6rem;color:#ea580c;word-break:break-word;line-height:1.4;">
                    <span style="text-align:center;">${escHtml(entry.notifyInfo)}</span>
                  </div>`
                : '';
            return `
            <div class="tracker-step ${stateClass}">
                <div class="tracker-line" style="background:${color};"></div>
                <div class="tracker-circle" style="${circleStyle}">${circleInner}</div>
                <div class="tracker-label" style="color:${color};">${escHtml(entry.status)}</div>
                ${preparerHtml}
                ${notifyHtml}
                ${meta}
                <div class="tracker-ts">${fmtDateTime(entry.timestamp)}</div>
            </div>`;
        }).join('');
    }

    // ── Push a status entry and re-render tracker ─────────────────────
    async function pushTrackerStatus(status, note, updatedBy, notifyInfo) {
        try {
            const body = { filingStatus: status };
            if (note)       body.note       = note;
            if (updatedBy)  body.updatedBy  = updatedBy;
            if (notifyInfo) body.notifyInfo  = notifyInfo;
            const res = await fetch('/api/itr-filings/' + filingId + '/status', {
                method:  'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(body),
            });
            if (!res.ok) return;
            filingData = await res.json();
            clientData = filingData.client;
            renderTracker(filingData);
        } catch (_) {}
    }


    // ── Client view / edit ───────────────────────────────────────────
    function renderClientView(c) {
        const initials = (c.name || '?').split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
        document.getElementById('c_avatar').textContent = initials;
        document.getElementById('c_name_banner').textContent = c.name || '—';
        const lnk = document.getElementById('c_profileLink');
        if (lnk) lnk.href = '/clients/view-client/' + c.id;
        set('v_c_name',     c.name);
        set('v_c_email',    c.email);
        set('v_c_mobile',   c.mobile);
        set('v_c_altMobile', c.alternateMobile);
        set('v_c_pan',      c.pan);
        set('v_c_dob',      c.dob ? c.dob.split('-').reverse().join('-') : '');
        set('v_c_aadhar',   c.aadharNo);
        set('v_c_caller',   c.caller);
        set('v_c_source',   c.source);
        set('v_c_remarks',  c.remarks);
        // ITR password view
        const clientPwd = c.itrPassword || '';
        const pwdSpan = document.getElementById('v_c_itrPassword');
        const pwdToggle  = document.getElementById('c_itrToggleBtn');
        const pwdCopyBtn = document.getElementById('c_itrCopyBtn');
        if (clientPwd) {
            pwdSpan.textContent = '••••••••';
            pwdToggle.classList.remove('d-none');
            if (pwdCopyBtn) pwdCopyBtn.classList.remove('d-none');
        } else {
            pwdSpan.textContent = '—';
            pwdToggle.classList.add('d-none');
            if (pwdCopyBtn) pwdCopyBtn.classList.add('d-none');
        }
        // Edit inputs
        document.getElementById('e_c_name').value      = c.name || '';
        document.getElementById('e_c_email').value     = c.email || '';
        document.getElementById('e_c_mobile').value    = c.mobile || '';
        document.getElementById('e_c_altMobile').value = c.alternateMobile || '';
        document.getElementById('e_c_pan').value       = c.pan || '';
        document.getElementById('e_c_dob').value       = c.dob || '';
        document.getElementById('e_c_aadhar').value    = c.aadharNo || '';
        document.getElementById('e_c_itrPassword').value = c.itrPassword || '';
        document.getElementById('e_c_itrPassword').type  = 'password';
        document.getElementById('e_c_remarks').value   = c.remarks || '';
    }

    let clientPwdVisible = false;
    window.toggleClientItrPassword = function () {
        const span = document.getElementById('v_c_itrPassword');
        const icon = document.getElementById('c_itr_eye');
        clientPwdVisible = !clientPwdVisible;
        span.textContent = clientPwdVisible ? (clientData.itrPassword || '') : '••••••••';
        icon.setAttribute('icon', clientPwdVisible ? 'iconamoon:eye-off-light' : 'iconamoon:eye-light');
    };
    window.toggleClientEditPass = function () {
        const inp = document.getElementById('e_c_itrPassword');
        const icon = document.getElementById('c_e_itr_eye');
        const isPass = inp.type === 'password';
        inp.type = isPass ? 'text' : 'password';
        icon.setAttribute('icon', isPass ? 'iconamoon:eye-off-light' : 'iconamoon:eye-light');
    };

    function showClientViewMode() {
        document.querySelectorAll('[id^="v_c_"]').forEach(el => el.classList.remove('d-none'));
        document.querySelectorAll('[id^="e_c_"]').forEach(el => el.classList.add('d-none'));
        showEl('clientViewActions', true);
        showDFlex('clientEditActions', false);
        showEl('clientError', false);
    }

    async function showClientEditMode() {
        await loadCallersSources();
        const cSel = document.getElementById('e_c_caller');
        const sSel = document.getElementById('e_c_source');
        cSel.innerHTML = '<option value="">Select caller</option>';
        callers.forEach(e => {
            const o = document.createElement('option');
            o.value = e.name; o.textContent = e.name;
            if (e.name === clientData.caller) o.selected = true;
            cSel.appendChild(o);
        });
        cSel.disabled = true;
        cSel.title = 'Use the Reassign button to change the caller';
        cSel.style.cssText = 'background:#f1f5f9;color:#94a3b8;cursor:not-allowed;pointer-events:none;border-color:#e2e8f0;';
        sSel.innerHTML = '<option value="">Select source</option>';
        sources.forEach(s => {
            const o = document.createElement('option');
            o.value = s.name; o.textContent = s.name;
            if (s.name === clientData.source) o.selected = true;
            sSel.appendChild(o);
        });
        document.querySelectorAll('[id^="v_c_"]').forEach(el => el.classList.add('d-none'));
        document.querySelectorAll('[id^="e_c_"]').forEach(el => el.classList.remove('d-none'));
        showEl('clientViewActions', false);
        showDFlex('clientEditActions', true);
    }

    document.getElementById('editClientBtn').addEventListener('click', showClientEditMode);
    document.getElementById('cancelClientBtn').addEventListener('click', function () {
        renderClientView(clientData);
        showClientViewMode();
    });
    document.getElementById('saveClientBtn').addEventListener('click', async function () {
        const errEl  = document.getElementById('clientError');
        const name   = document.getElementById('e_c_name').value.trim();
        const mobile = document.getElementById('e_c_mobile').value.trim();
        const pan    = document.getElementById('e_c_pan').value.trim().toUpperCase();
        if (!name || !mobile || !pan) {
            errEl.textContent = 'Name, Mobile and PAN are required.';
            errEl.classList.remove('d-none');
            return;
        }
        errEl.classList.add('d-none');
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="text-md"></iconify-icon>Saving...';
        try {
            const res = await fetch('/api/clients/' + clientData.id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name, mobile, pan,
                    email:           document.getElementById('e_c_email').value.trim(),
                    alternateMobile: document.getElementById('e_c_altMobile').value.trim(),
                    itrPassword:     document.getElementById('e_c_itrPassword').value,
                    dob:             document.getElementById('e_c_dob').value,
                    aadharNo:        document.getElementById('e_c_aadhar').value.trim(),
                    caller:          document.getElementById('e_c_caller').value,
                    source:          document.getElementById('e_c_source').value,
                    remarks:         document.getElementById('e_c_remarks').value.trim(),
                    status:          clientData.status,
                }),
            });
            const data = await res.json();
            if (res.status === 409) { errEl.textContent = data.message; errEl.classList.remove('d-none'); return; }
            if (!res.ok) throw new Error(data.message);
            clientData = data;
            filingData.client = data;
            renderClientView(clientData);
            showClientViewMode();
            set('hdr_caller', clientData.caller || '—');
        } catch (e) {
            errEl.textContent = e.message || 'Failed to save.';
            errEl.classList.remove('d-none');
        } finally {
            this.disabled = false;
            this.innerHTML = '<iconify-icon icon="lucide:save" class="text-md"></iconify-icon>Save';
        }
    });
    document.getElementById('e_c_pan').addEventListener('input', function () { this.value = this.value.toUpperCase(); });

    // ── Filing info (preparer) ────────────────────────────────────────
    function renderFilingInfo(data) {
        const caller = data.caller || (data.client && data.client.caller) || '—';
        set('hdr_caller', caller);
        showEl('hdr_caller_wrap', true);
        set('hdr_preparer_view', data.preparer || '—');
        showEl('hdr_preparer_wrap', true);
        set('hdr_manager', data.manager || '—');
        showEl('hdr_manager_wrap', true);
        renderReturnDetailsBadges(data);
    }

    let rdOutcomeColorMap = {}; // name → hex color, populated by initReturnDetails

    function renderReturnDetailsBadges(data) {
        const strip = document.getElementById('rdStrip');
        if (!strip) return;
        const items = [
            { value: data.itrType,       isOutcome: false, isFilingType: false },
            { value: data.filingType,    isOutcome: false, isFilingType: true  },
            { value: data.returnOutcome, isOutcome: true,  isFilingType: false },
        ].filter(item => item.value);
        if (!items.length) { strip.classList.add('d-none'); strip.classList.remove('d-flex'); return; }
        const filingTypeColors = { 'Planning': '#3B82F6' };
        strip.innerHTML = items.map(item => {
            if (item.isOutcome && rdOutcomeColorMap[item.value]) {
                const c = rdOutcomeColorMap[item.value];
                return `<span style="background:${c};border-radius:6px;padding:2px 10px;font-size:.72rem;font-weight:600;color:#fff;white-space:nowrap;">${item.value}</span>`;
            }
            if (item.isFilingType && filingTypeColors[item.value]) {
                const c = filingTypeColors[item.value];
                return `<span style="background:${c};border-radius:6px;padding:2px 10px;font-size:.72rem;font-weight:600;color:#fff;white-space:nowrap;">${item.value}</span>`;
            }
            return `<span style="border:1px solid #cbd5e1;border-radius:6px;padding:2px 10px;font-size:.72rem;font-weight:600;color:#475569;background:#f8fafc;white-space:nowrap;">${item.value}</span>`;
        }).join('');
        strip.classList.remove('d-none');
        strip.classList.add('d-flex');
    }

    document.getElementById('hdr_cancelBtn').addEventListener('click', function () {
        showEl('hdr_preparer_view', true);
        document.getElementById('hdr_preparer_edit').classList.add('d-none');
        showEl('hdr_saveBtn',   false);
        showEl('hdr_cancelBtn', false);
        document.getElementById('hdr_editError').classList.add('d-none');
    });
    document.getElementById('hdr_saveBtn').addEventListener('click', async function () {
        const preparer = document.getElementById('hdr_preparer_edit').value;
        const errEl = document.getElementById('hdr_editError');
        errEl.classList.add('d-none');
        this.disabled = true;
        this.textContent = 'Saving…';
        try {
            const res = await fetch('/api/itr-filings/' + filingId, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ preparer, selectedIncomeHeads: filingData.selectedIncomeHeads, incomeData: filingData.incomeData }),
            });
            if (!res.ok) throw new Error();
            filingData = await res.json();
            clientData = filingData.client;
            document.getElementById('hdr_preparer_edit').classList.add('d-none');
            showEl('hdr_saveBtn',   false);
            showEl('hdr_cancelBtn', false);
            renderFilingInfo(filingData);
            renderAssignSection(filingData);
        } catch (e) {
            errEl.textContent = 'Failed to save.';
            errEl.classList.remove('d-none');
        }
        this.disabled = false;
        this.textContent = 'Save';
    });

    // ── Income head selector ──────────────────────────────────────────
    function renderIncomeSelector(selectedHeads) {
        document.getElementById('incomeHeadSelector').innerHTML = INCOME_HEADS.map(h => {
            const sel = selectedHeads.includes(h.key);
            return `<span class="income-chip${sel ? ' selected' : ''}" onclick="toggleIncomeHead('${h.key}')">` +
                   `${sel ? '<iconify-icon icon="lucide:check" class="chip-check"></iconify-icon>' : ''}${h.label}</span>`;
        }).join('');
    }

    // ── Income head sections ──────────────────────────────────────────
    function renderIncomeSections(data) {
        const selectedHeads = data.selectedIncomeHeads || [];
        const incomeData    = data.incomeData || {};
        const container     = document.getElementById('incomeHeadSections');

        if (!selectedHeads.length) {
            container.innerHTML = '<p class="text-secondary-light text-xs text-center py-16">No income heads selected. Click a head above to add it.</p>';
            return;
        }

        const sections = INCOME_HEADS
            .filter(h => selectedHeads.includes(h.key))
            .map(h => {
                const docs    = (incomeData[h.key] || {}).documents || [];
                const safeKey = h.key.replace(/[^a-zA-Z0-9]/g, '_');

                const docItems = docs.length
                    ? docs.map(d => `
                    <div class="doc-item d-flex align-items-center justify-content-between gap-10 mb-6" data-doc-id="${d.id}">
                        <div class="d-flex align-items-center gap-8 overflow-hidden">
                            <iconify-icon icon="${mimeIcon(d.mimeType)}" class="text-lg text-secondary-light flex-shrink-0"></iconify-icon>
                            <div class="overflow-hidden">
                                <div class="fw-medium text-xs text-truncate" style="max-width:160px">${escHtml(d.name)}</div>
                                <div class="text-secondary-light" style="font-size:.65rem">${fmtFileSize(d.size)} · ${fmtDateTime(d.uploadedAt)}</div>
                            </div>
                        </div>
                        <div class="d-flex gap-6 flex-shrink-0">
                            <button type="button" class="btn btn-primary-light btn-sm radius-6 px-8 py-4 download-doc-btn" data-head="${h.key}" data-doc-id="${d.id}" title="Download">
                                <iconify-icon icon="lucide:download" class="text-xs"></iconify-icon>
                            </button>
                            <button type="button" class="btn btn-outline-danger-600 btn-sm radius-6 px-8 py-4 delete-doc-btn" data-head="${h.key}" data-doc-id="${d.id}" title="Delete">
                                <iconify-icon icon="lucide:trash-2" class="text-xs"></iconify-icon>
                            </button>
                        </div>
                    </div>`).join('')
                    : '<p class="text-secondary-light mb-0" style="font-size:.72rem">No documents uploaded yet.</p>';

                return `
                <div class="col-md-6" style="margin-bottom:20px">
                <div class="income-head-section h-100" style="--section-color:${h.color}">
                    <div class="d-flex align-items-center justify-content-between gap-10 px-16 py-10" style="background:#fafbfc;">
                        <div class="d-flex align-items-center gap-8">
                            <iconify-icon icon="${h.icon}" style="color:${h.color};font-size:1rem"></iconify-icon>
                            <span class="fw-semibold text-xs">${h.label}</span>
                            <span class="badge text-xs px-6 py-2 radius-6" style="background:#f1f5f9;color:#64748b;">${docs.length} doc${docs.length !== 1 ? 's' : ''}</span>
                        </div>
                        <label class="btn btn-sm radius-6 px-10 py-4 d-flex align-items-center gap-1 mb-0 text-xs" style="cursor:pointer;background:#e8f0fe;color:#2563eb;border:none;">
                            Upload
                            <input type="file" class="d-none doc-upload-input" multiple
                                accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx"
                                data-head="${h.key}">
                        </label>
                    </div>
                    <div class="px-16 py-10" id="docs_${safeKey}">${docItems}</div>
                    <div id="uploadPanel_${safeKey}" class="d-none" style="border-top:1px solid #f1f5f9;"></div>
                </div>
                </div>`;
            });

        container.innerHTML = `<div class="row g-12">${sections.join('')}</div>`;
        // restore any pending-upload panels that survived re-render
        Object.keys(pendingUploads).forEach(h => {
            if ((pendingUploads[h] || []).length) showPendingPanel(h);
        });
    }

    window.toggleIncomeHead = async function (key) {
        if (!filingData) return;
        const heads = [...(filingData.selectedIncomeHeads || [])];
        const idx = heads.indexOf(key);
        if (idx === -1) heads.push(key); else heads.splice(idx, 1);
        filingData.selectedIncomeHeads = heads;
        renderIncomeSelector(heads);
        renderIncomeSections(filingData);
        // auto-save selection
        try {
            const res = await fetch('/api/itr-filings/' + filingId, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ preparer: filingData.preparer, selectedIncomeHeads: heads, incomeData: filingData.incomeData }),
            });
            if (res.ok) filingData = await res.json();
        } catch (_) {}
    };


    // ── Pending uploads state ─────────────────────────────────────────
    const pendingUploads = {}; // { [head]: [{file, customName}] }

    function mimeIconFromName(name) {
        const ext = (name || '').split('.').pop().toLowerCase();
        const map = { pdf:'mdi:file-pdf-box', jpg:'mdi:file-image', jpeg:'mdi:file-image',
                      png:'mdi:file-image', gif:'mdi:file-image', webp:'mdi:file-image',
                      doc:'mdi:file-word', docx:'mdi:file-word',
                      xls:'mdi:file-excel', xlsx:'mdi:file-excel',
                      zip:'mdi:folder-zip', txt:'mdi:file-document' };
        return map[ext] || 'mdi:file-outline';
    }

    function showPendingPanel(head) {
        const safeKey = head.replace(/[^a-zA-Z0-9]/g, '_');
        const panel   = document.getElementById('uploadPanel_' + safeKey);
        if (!panel) return;
        const items = pendingUploads[head] || [];
        if (!items.length) { panel.classList.add('d-none'); panel.innerHTML = ''; return; }
        panel.classList.remove('d-none');
        panel.innerHTML =
            `<div class="px-16 py-10">` +
            `<div class="text-xs fw-semibold text-secondary-light mb-8" style="letter-spacing:.03em;text-transform:uppercase;">Ready to upload</div>` +
            `<div id="pendingList_${safeKey}"></div>` +
            `<button class="btn btn-sm btn-primary radius-6 mt-10 text-xs px-12 do-upload-btn" data-head="${head}" style="height:28px;">` +
            `Upload ${items.length} file${items.length > 1 ? 's' : ''}</button>` +
            `</div>`;
        const listEl = document.getElementById('pendingList_' + safeKey);
        items.forEach((item, i) => {
            const row = document.createElement('div');
            row.className = 'd-flex align-items-center gap-8 p-8 radius-8 mb-6';
            row.style.cssText = 'background:#f8fafc;border:1px solid #e2e8f0;';
            row.innerHTML =
                `<iconify-icon icon="${mimeIconFromName(item.customName)}" class="text-secondary-light flex-shrink-0" style="font-size:1rem;"></iconify-icon>` +
                `<input type="text" class="form-control form-control-sm text-xs flex-grow-1 pending-name-input" value="${escHtml(item.customName)}" data-idx="${i}" data-head="${head}" style="height:26px;min-width:0;" title="Rename before uploading">` +
                `<span class="text-xs text-secondary-light flex-shrink-0" style="white-space:nowrap;">${fmtFileSize(item.file.size)}</span>` +
                `<button type="button" class="btn radius-6 px-6 remove-pending-btn flex-shrink-0" data-idx="${i}" data-head="${head}" style="background:#fee2e2;color:#dc2626;height:26px;border:none;font-size:.75rem;">` +
                `<iconify-icon icon="lucide:x" style="font-size:.75rem;vertical-align:middle;"></iconify-icon></button>`;
            listEl.appendChild(row);
        });
    }

    async function doUpload(head) {
        const items   = pendingUploads[head] || [];
        if (!items.length) return;
        const safeKey = head.replace(/[^a-zA-Z0-9]/g, '_');
        const panel   = document.getElementById('uploadPanel_' + safeKey);
        if (!panel) return;

        panel.innerHTML =
            `<div class="px-16 py-10">` +
            `<div class="text-xs fw-semibold text-secondary-light mb-8" style="letter-spacing:.03em;text-transform:uppercase;">Uploading…</div>` +
            `<div id="progList_${safeKey}"></div>` +
            `</div>`;
        const listEl = document.getElementById('progList_' + safeKey);

        const rowEls = items.map((item, i) => {
            const row = document.createElement('div');
            row.className = 'p-8 radius-8 mb-6';
            row.style.cssText = 'background:#f8fafc;border:1px solid #e2e8f0;';
            row.innerHTML =
                `<div class="d-flex align-items-center justify-content-between gap-8 mb-6">` +
                `<div class="d-flex align-items-center gap-6 overflow-hidden">` +
                `<iconify-icon icon="${mimeIconFromName(item.customName)}" class="text-secondary-light flex-shrink-0" style="font-size:1rem;"></iconify-icon>` +
                `<span class="text-xs fw-medium text-truncate" style="max-width:160px;">${escHtml(item.customName)}</span>` +
                `</div>` +
                `<span class="text-xs text-secondary-light flex-shrink-0" id="progStatus_${safeKey}_${i}">Waiting…</span>` +
                `</div>` +
                `<div class="progress" style="height:4px;border-radius:2px;background:#e2e8f0;">` +
                `<div id="progBar_${safeKey}_${i}" class="progress-bar" role="progressbar" style="width:0%;background:#2563eb;transition:width .25s;"></div>` +
                `</div>`;
            listEl.appendChild(row);
            return row;
        });

        function setBar(idx, pct) {
            const el = document.getElementById('progBar_' + safeKey + '_' + idx);
            if (el) el.style.width = pct + '%';
        }
        function setStatus(idx, text, color) {
            const el = document.getElementById('progStatus_' + safeKey + '_' + idx);
            if (el) { el.textContent = text; if (color) el.style.color = color; }
        }

        for (let i = 0; i < items.length; i++) {
            const item = items[i];
            setStatus(i, 'Reading…'); setBar(i, 20);
            try {
                const b64 = await readFileAsBase64(item.file);
                setBar(i, 50); setStatus(i, 'Uploading…');
                const res = await fetch('/api/itr-filings/' + filingId + '/documents/' + encodeURIComponent(head), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: item.customName, size: item.file.size, mimeType: item.file.type, data: b64 }),
                });
                if (!res.ok) throw new Error((await res.json()).message);
                const doc = await res.json();
                setBar(i, 100); setStatus(i, 'Done ✓', '#16a34a');
                if (rowEls[i]) rowEls[i].style.borderColor = '#bbf7d0';
                if (!filingData.incomeData[head]) filingData.incomeData[head] = { fields: {}, documents: [] };
                if (!filingData.incomeData[head].documents) filingData.incomeData[head].documents = [];
                filingData.incomeData[head].documents.push(doc);
            } catch (err) {
                setBar(i, 100);
                const bar = document.getElementById('progBar_' + safeKey + '_' + i);
                if (bar) bar.style.background = '#dc2626';
                setStatus(i, 'Failed', '#dc2626');
            }
        }
        pendingUploads[head] = [];
        setTimeout(() => renderIncomeSections(filingData), 900);
    }

    // ── Document upload ───────────────────────────────────────────────
    document.addEventListener('change', function (e) {
        const inp = e.target.closest('.doc-upload-input');
        if (!inp) return;
        const head = inp.dataset.head;
        const files = Array.from(inp.files).filter(f => {
            if (f.size > 10 * 1024 * 1024) { alert(f.name + ' exceeds 10 MB limit.'); return false; }
            return true;
        });
        inp.value = '';
        if (!files.length) return;
        if (!pendingUploads[head]) pendingUploads[head] = [];
        files.forEach(f => pendingUploads[head].push({ file: f, customName: f.name }));
        showPendingPanel(head);
    });

    // ── Pending panel interactions ────────────────────────────────────
    document.addEventListener('input', function (e) {
        const inp = e.target.closest('.pending-name-input');
        if (!inp) return;
        const head = inp.dataset.head;
        const idx  = parseInt(inp.dataset.idx, 10);
        if (pendingUploads[head] && pendingUploads[head][idx]) {
            pendingUploads[head][idx].customName = inp.value;
        }
    });
    document.addEventListener('click', function (e) {
        const removeBtn = e.target.closest('.remove-pending-btn');
        const uploadBtn = e.target.closest('.do-upload-btn');
        if (removeBtn) {
            const head = removeBtn.dataset.head;
            const idx  = parseInt(removeBtn.dataset.idx, 10);
            if (pendingUploads[head]) pendingUploads[head].splice(idx, 1);
            showPendingPanel(head);
        }
        if (uploadBtn) {
            doUpload(uploadBtn.dataset.head);
        }
    });

    function readFileAsBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload  = e => resolve(e.target.result.split(',')[1]);
            reader.onerror = reject;
            reader.readAsDataURL(file);
        });
    }

    // ── Document actions (download / delete) ──────────────────────────
    document.addEventListener('click', async function (e) {
        const dlBtn  = e.target.closest('.download-doc-btn');
        const delBtn = e.target.closest('.delete-doc-btn');

        if (dlBtn) {
            const head  = dlBtn.dataset.head;
            const docId = dlBtn.dataset.docId;
            const doc   = ((filingData.incomeData || {})[head]?.documents || []).find(d => d.id === docId);
            if (doc && doc.data) {
                const a = document.createElement('a');
                a.href     = 'data:' + doc.mimeType + ';base64,' + doc.data;
                a.download = doc.name;
                a.click();
            }
        }

        if (delBtn) {
            const head  = delBtn.dataset.head;
            const docId = delBtn.dataset.docId;
            const doc   = ((filingData.incomeData || {})[head]?.documents || []).find(d => d.id === docId);
            document.getElementById('deleteDocModalName').textContent = doc ? doc.name : docId;
            pendingDocDelete = async function () {
                delBtn.disabled = true;
                try {
                    const res = await fetch('/api/itr-filings/' + filingId + '/documents/' + encodeURIComponent(head) + '/' + docId, { method: 'DELETE' });
                    if (!res.ok) throw new Error();
                    if (filingData.incomeData[head]) {
                        filingData.incomeData[head].documents = (filingData.incomeData[head].documents || []).filter(d => d.id !== docId);
                    }
                    renderIncomeSections(filingData);
                } catch (e) { alert('Failed to delete document.'); delBtn.disabled = false; }
            };
            new bootstrap.Modal(document.getElementById('deleteDocModal')).show();
        }
    });

    // ── Load dropdowns ────────────────────────────────────────────────
    async function loadCallersSources() {
        if (callers.length && sources.length) return;
        const [eRes, sRes] = await Promise.all([fetch('/api/employees'), fetch('/api/sources')]);
        callers = (await eRes.json()).filter(e => e.designation === 'Caller' && e.status === 'Active');
        sources = await sRes.json();
    }
    async function loadPreparers() {
        if (preparers.length) return;
        preparers = (await (await fetch('/api/employees')).json()).filter(e => e.designation === 'Tax Preparer' && e.status === 'Active');
    }
    async function loadManagers() {
        if (managers.length) return;
        managers = (await (await fetch('/api/employees')).json()).filter(e => e.designation === 'Manager' && e.status === 'Active');
    }

    // ── Assign Tax Preparer ───────────────────────────────────────────
    function fmtTs(iso) {
        if (!iso) return '';
        const d = new Date(iso);
        return d.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' })
            + ' at '
            + d.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:true });
    }

    function renderAssignSection(data) {
        const section    = document.getElementById('assignPreparerSection');
        section.classList.remove('d-none');

        // ── Tax Preparer panel ──
        const displayEl  = document.getElementById('assignedPreparerDisplay');
        const btnLabel   = document.getElementById('assignBtnLabel');
        const btnIcon    = document.getElementById('assignBtnIcon');
        if (data.preparer) {
            displayEl.textContent = data.preparer;
            displayEl.classList.remove('text-secondary-light');
            displayEl.classList.add('fw-semibold', 'text-success-700');
            btnLabel.textContent = 'Reassign';
            btnIcon.setAttribute('icon', 'lucide:user-cog');
        } else {
            displayEl.textContent = 'Not assigned yet';
            displayEl.classList.remove('fw-semibold', 'text-success-700');
            displayEl.classList.add('text-secondary-light');
            btnLabel.textContent = 'Assign';
            btnIcon.setAttribute('icon', 'lucide:user-plus');
        }

        // ── Caller panel ──
        const callerDisplay = document.getElementById('assignedCallerDisplay');
        const callerName = data.caller || (data.client && data.client.caller) || '—';
        callerDisplay.textContent = callerName;
        if (callerName && callerName !== '—') {
            callerDisplay.classList.remove('text-secondary-light');
            callerDisplay.classList.add('fw-semibold', 'text-primary-light');
        } else {
            callerDisplay.classList.remove('fw-semibold', 'text-primary-light');
            callerDisplay.classList.add('text-secondary-light');
        }

        // ── Manager panel ──
        const mgrDisplay  = document.getElementById('assignedManagerDisplay');
        const mgrBtnLabel = document.getElementById('assignManagerBtnLabel');
        const mgrBtnIcon  = document.getElementById('assignManagerBtnIcon');
        if (data.manager) {
            mgrDisplay.textContent = data.manager;
            mgrDisplay.classList.remove('text-secondary-light');
            mgrDisplay.classList.add('fw-semibold', 'text-success-700');
            mgrBtnLabel.textContent = 'Reassign';
            mgrBtnIcon.setAttribute('icon', 'lucide:user-cog');
        } else {
            mgrDisplay.textContent = 'Not assigned yet';
            mgrDisplay.classList.remove('fw-semibold', 'text-success-700');
            mgrDisplay.classList.add('text-secondary-light');
            mgrBtnLabel.textContent = 'Assign';
            mgrBtnIcon.setAttribute('icon', 'lucide:user-plus');
        }

        loadInfoRequests();
        loadEstimate();
        loadReassignments();
        loadEmployeeDropdowns();
        updateNotifyCheckbox(data);
    }

    // ── Notify Tax Preparer checkbox ──────────────────────────────────
    function updateNotifyCheckbox(data) {
        const nameEl = document.getElementById('notifyPreparerName');
        const chk    = document.getElementById('notifyPreparerChk');
        if (!nameEl || !chk) return;
        nameEl.textContent = (data && data.preparer) ? ' (' + data.preparer + ')' : '';
        chk.checked  = false;
        chk.disabled = false;
    }

    document.getElementById('notifyPreparerChk').addEventListener('change', async function () {
        if (!this.checked) return;

        // Preparer is assigned — notification will be sent when Update is clicked
        if (filingData && filingData.preparer) return;

        // No preparer assigned — uncheck and open assign modal
        this.checked = false;
        await loadPreparers();
        const sel = document.getElementById('notifyPreparerSelect');
        while (sel.options.length > 1) sel.remove(1);
        preparers.forEach(p => {
            const opt = document.createElement('option');
            opt.value = p.name;
            opt.textContent = p.name;
            sel.appendChild(opt);
        });
        sel.value = '';
        sel.classList.remove('is-invalid');
        new bootstrap.Modal(document.getElementById('notifyAssignModal')).show();
    });

    document.getElementById('notifyAssignBtn').addEventListener('click', async function () {
        const sel      = document.getElementById('notifyPreparerSelect');
        const errEl    = document.getElementById('notifyAssignError');
        const preparer = sel.value;
        errEl.classList.add('d-none');
        if (!preparer) { sel.classList.add('is-invalid'); return; }
        sel.classList.remove('is-invalid');
        const actingName = getActiveSenderName();
        if (!actingName) {
            errEl.textContent = 'Please select an acting member (Caller, Tax Preparer, or Manager) in the Acting as section before assigning.';
            errEl.classList.remove('d-none');
            return;
        }
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="me-4"></iconify-icon>Assigning…';
        try {
            const res = await fetch('/api/itr-filings/' + filingId, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    preparer,
                    assignedBy: actingName,
                    selectedIncomeHeads: filingData.selectedIncomeHeads,
                    incomeData: filingData.incomeData,
                }),
            });
            if (!res.ok) throw new Error();
            filingData = await res.json();
            // Post info-request FIRST, then render so Activity Log is current
            await fetch('/api/itr-filings/' + filingId + '/info-requests', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'preparer_assigned',
                    message: 'Tax Preparer Assigned (' + preparer + ')',
                    senderName: actingName,
                    senderRole: activeRole || 'caller'
                })
            });
            renderTracker(filingData);
            renderFilingInfo(filingData);
            renderAssignSection(filingData);
            const m = bootstrap.Modal.getInstance(document.getElementById('notifyAssignModal'));
            if (m) m.hide();
            document.getElementById('notifyPreparerChk').checked = false;
        } catch (_) {
            errEl.textContent = 'Failed to assign Tax Preparer. Please try again.';
            errEl.classList.remove('d-none');
        }
        this.disabled = false;
        this.innerHTML = '<iconify-icon icon="lucide:user-check" class="text-sm"></iconify-icon>Assign';
    });

    // ── Reassignments ─────────────────────────────────────────────────
    let allReassignments = [];

    async function loadReassignments() {
        const res = await fetch('/api/itr-filings/' + filingId + '/reassignments');
        if (!res.ok) return;
        allReassignments = await res.json();
        renderActivityLog();
    }

    // ── Info Requests ─────────────────────────────────────────────────
    let allInfoRequests = [];

    async function loadInfoRequests() {
        const res = await fetch('/api/itr-filings/' + filingId + '/info-requests');
        if (!res.ok) return;
        const items = await res.json();
        renderInfoRequests(items);
    }

    function renderInfoRequests(items) {
        allInfoRequests = items;
        renderActivityLog();
    }

    // ── Activity Log ──────────────────────────────────────────────────
    function singleFileHtml(f) {
        if (!f || !f.fileData || !f.fileName) return '';
        const isImg = f.fileMimeType && f.fileMimeType.startsWith('image/');
        const kb    = f.fileSize ? (f.fileSize / 1024).toFixed(1) + ' KB' : '';
        if (isImg) {
            return `<div class="mt-6 position-relative d-inline-block" style="max-width:100%;">
                <img src="${escHtml(f.fileData)}" alt="${escHtml(f.fileName)}"
                     class="radius-8 border activity-log-img"
                     style="max-width:100%;max-height:180px;object-fit:contain;display:block;cursor:zoom-in;">
                <a href="${escHtml(f.fileData)}" download="${escHtml(f.fileName)}"
                   class="position-absolute d-flex align-items-center justify-content-center radius-6"
                   style="top:6px;left:6px;width:26px;height:26px;background:rgba(0,0,0,.45);color:#fff;text-decoration:none;backdrop-filter:blur(2px);"
                   title="Download image">
                    <iconify-icon icon="lucide:download" style="font-size:.75rem;"></iconify-icon>
                </a>
            </div>`;
        }
        let iconName = 'lucide:file';
        if (f.fileMimeType === 'application/pdf') iconName = 'lucide:file-text';
        else if (f.fileMimeType && (f.fileMimeType.includes('word') || f.fileMimeType.includes('document'))) iconName = 'lucide:file-type-2';
        return `<div class="mt-6 d-inline-flex align-items-center gap-8 border radius-8 px-10 py-6 bg-light">
            <iconify-icon icon="${iconName}" class="text-primary-600 text-sm"></iconify-icon>
            <span class="text-xs fw-medium">${escHtml(f.fileName)}</span>
            ${kb ? `<span class="text-secondary-light text-xs">${kb}</span>` : ''}
            <a href="${escHtml(f.fileData)}" download="${escHtml(f.fileName)}"
               class="d-flex align-items-center justify-content-center ms-4 radius-4"
               style="width:20px;height:20px;background:rgba(99,102,241,.1);color:#6366f1;text-decoration:none;"
               title="Download">
                <iconify-icon icon="lucide:download" style="font-size:.7rem;"></iconify-icon>
            </a>
        </div>`;
    }

    function activityFileHtml(e) {
        const fileList = Array.isArray(e.files) && e.files.length ? e.files : [];
        if (!fileList.length) return '';
        return `<div class="mt-6 d-flex flex-wrap gap-8">${fileList.map(singleFileHtml).join('')}</div>`;
    }

    function renderActivityLog() {
        const events = [];
        for (const r of allInfoRequests) {
            events.push({ type: r.type || 'request', timestamp: r.timestamp, message: r.message,
                senderName: r.senderName, senderRole: r.senderRole, files: r.files || [] });
        }
        for (const est of estimatesStored) {
            if (est.preparedAt) {
                events.push({ type: est.type || 'estimate', timestamp: est.preparedAt,
                    remarks: est.remarks, senderName: est.senderName, senderRole: est.senderRole,
                    files: est.files || [] });
            }
        }
        for (const rv of allReassignments) {
            events.push({ type: '__reassign__', timestamp: rv.timestamp,
                role: rv.role, fromName: rv.fromName, toName: rv.toName, remarks: rv.remarks });
        }
        events.sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp));

        // Prepend synthetic "filing opened" event from statusHistory[0]
        const openedEntry = filingData.statusHistory && filingData.statusHistory[0];
        if (openedEntry) {
            events.unshift({
                type: '__opened__',
                timestamp: openedEntry.timestamp,
                callerName: openedEntry.updatedBy || (filingData.client && filingData.client.caller) || 'Caller'
            });
        }

        const section = document.getElementById('activityLogSection');
        const items   = document.getElementById('activityLogItems');
        // Always show the action history section
        section.classList.remove('d-none');

        items.innerHTML = events.map((e, idx) => {
            // ── Filing opened banner (first entry, always pinned) ────────
            if (e.type === '__opened__') {
                const ts = fmtTs(e.timestamp);
                return `<div style="display:flex;align-items:center;gap:10px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:9px 14px;margin:0 0 10px;">
                    <span style="width:28px;height:28px;border-radius:6px;background:#dbeafe;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <iconify-icon icon="lucide:folder-open" style="font-size:1rem;color:#2563eb;"></iconify-icon>
                    </span>
                    <span style="font-size:.78rem;color:#1d4ed8;flex:1;">Filing opened by <strong>${escHtml(e.callerName)}</strong></span>
                    <span style="font-size:.7rem;color:#60a5fa;white-space:nowrap;flex-shrink:0;">${ts}</span>
                </div>`;
            }

            // ── Preparer assignment system banner ───────────────────────
            if (e.type === 'preparer_assigned') {
                const ts = fmtTs(e.timestamp);
                const byHtml = (e.senderName && e.senderName !== 'System')
                    ? ` by <strong>${escHtml(e.senderName)}</strong>`
                    : '';
                return `<div style="display:flex;align-items:center;gap:10px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:9px 14px;margin:6px 0;">
                    <span style="width:28px;height:28px;border-radius:6px;background:#dcfce7;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <iconify-icon icon="lucide:user-check" style="font-size:1rem;color:#16a34a;"></iconify-icon>
                    </span>
                    <span style="font-size:.78rem;color:#15803d;flex:1;">${escHtml(e.message)}${byHtml}</span>
                    <span style="font-size:.7rem;color:#4ade80;white-space:nowrap;flex-shrink:0;">${ts}</span>
                </div>`;
            }

            // ── Notify Tax Preparer banner ──────────────────────────────
            if (e.type === 'notify_preparer') {
                const ts = fmtTs(e.timestamp);
                const byHtml = (e.senderName && e.senderName !== 'System')
                    ? ` by <strong>${escHtml(e.senderName)}</strong>`
                    : '';
                return `<div style="display:flex;align-items:center;gap:10px;background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:9px 14px;margin:6px 0;">
                    <span style="width:28px;height:28px;border-radius:6px;background:#ffedd5;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <iconify-icon icon="lucide:bell" style="font-size:1rem;color:#ea580c;"></iconify-icon>
                    </span>
                    <span style="font-size:.78rem;color:#9a3412;flex:1;">${escHtml(e.message)}${byHtml}</span>
                    <span style="font-size:.7rem;color:#fb923c;white-space:nowrap;flex-shrink:0;">${ts}</span>
                </div>`;
            }

            // ── Escalate to Manager banner ──────────────────────────────
            if (e.type === 'Escalate to Manager') {
                const ts = fmtTs(e.timestamp);
                const senderName = e.senderName ? escHtml(e.senderName) : 'Caller';
                return `<div style="display:flex;align-items:center;gap:10px;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:8px;padding:9px 14px;margin:6px 0;">
                    <span style="width:28px;height:28px;border-radius:6px;background:#ede9fe;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <iconify-icon icon="lucide:arrow-up-right" style="font-size:1rem;color:#7c3aed;"></iconify-icon>
                    </span>
                    <span style="font-size:.78rem;color:#5b21b6;flex:1;">Escalated to <strong>Manager</strong> by <strong>${senderName}</strong></span>
                    <span style="font-size:.7rem;color:#a78bfa;white-space:nowrap;flex-shrink:0;">${ts}</span>
                </div>`;
            }

            // ── Reassignment system banner ──────────────────────────────
            if (e.type === '__reassign__') {
                const roleLabel = e.role === 'caller' ? 'Caller' : e.role === 'manager' ? 'Manager' : 'Tax Preparer';
                const icon      = e.role === 'caller' ? 'lucide:phone' : e.role === 'manager' ? 'lucide:shield' : 'lucide:file-check';
                const bgColor   = e.role === 'caller' ? '#fffbeb' : e.role === 'manager' ? '#f5f3ff' : '#eff6ff';
                const bdColor   = e.role === 'caller' ? '#fde68a' : e.role === 'manager' ? '#ddd6fe' : '#bfdbfe';
                const iconBg    = e.role === 'caller' ? '#fef3c7' : e.role === 'manager' ? '#ede9fe' : '#dbeafe';
                const iconColor = e.role === 'caller' ? '#b45309' : e.role === 'manager' ? '#6d28d9' : '#2563eb';
                const txtColor  = e.role === 'caller' ? '#92400e' : e.role === 'manager' ? '#5b21b6' : '#1d4ed8';
                const tsColor   = e.role === 'caller' ? '#fbbf24' : e.role === 'manager' ? '#a78bfa' : '#60a5fa';
                const ts        = fmtTs(e.timestamp);
                const remarksHtml = e.remarks
                    ? `<span style="opacity:.7;"> &mdash; ${escHtml(e.remarks)}</span>`
                    : '';
                return `<div style="display:flex;align-items:center;gap:10px;background:${bgColor};border:1px solid ${bdColor};border-radius:8px;padding:9px 14px;margin:6px 0;">
                    <span style="width:28px;height:28px;border-radius:6px;background:${iconBg};display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <iconify-icon icon="${icon}" style="font-size:1rem;color:${iconColor};"></iconify-icon>
                    </span>
                    <span style="font-size:.78rem;color:${txtColor};flex:1;"><strong>${roleLabel}</strong> ${(!e.fromName || e.fromName === '—') ? 'assigned' : 'reassigned'}: <strong>${escHtml(e.fromName)}</strong> &rarr; <strong>${escHtml(e.toName)}</strong>${e.byName ? ` by <strong>${escHtml(e.byName)}</strong>` : ''}${remarksHtml}</span>
                    <span style="font-size:.7rem;color:${tsColor};white-space:nowrap;flex-shrink:0;">${ts}</span>
                </div>`;
            }

            const isSubmission = e.type === 'submission';
            const isEstimate   = e.type === 'estimate' || e.type === 'revised_estimate';
            const contentText  = isEstimate ? e.remarks : e.message;
            const isLast       = idx === events.length - 1;

            const divider = !isLast
                ? `<div style="display:flex;align-items:center;gap:8px;margin:12px 0 0;">
                       <div style="flex:1;height:1px;background:linear-gradient(to right,transparent,#e2e8f0);"></div>
                       <div style="flex:1;height:1px;background:linear-gradient(to left,transparent,#e2e8f0);"></div>
                   </div>`
                : '';

            // Caller action types → right-aligned
            const CALLER_TYPES = ['submission','move_to_filing','bank_confirmed','bank_details_changed','req_revised_estimate','estimate_sent'];
            const isRight = CALLER_TYPES.includes(e.type);

            // Action metadata (icon + label) per action type
            const ACTION_META = {
                request:              { icon: 'lucide:clipboard-list',  label: 'Info Request' },
                estimate:             { icon: 'lucide:check-circle-2',  label: 'Estimate Prepared' },
                bank_confirmation:    { icon: 'lucide:landmark',        label: 'Req Bank Confirmation' },
                e_verify:             { icon: 'lucide:shield-check',    label: 'E-Verify' },
                send_json:            { icon: 'lucide:file-json-2',     label: 'Send Json' },
                filed:                { icon: 'lucide:file-check-2',    label: 'Filed' },
                refiled:              { icon: 'lucide:refresh-ccw',     label: 'Refiled' },
                submission:           { icon: 'lucide:inbox',           label: 'Info Submitted' },
                move_to_filing:       { icon: 'lucide:folder-open',     label: 'Move to Filing' },
                bank_confirmed:       { icon: 'lucide:check-circle',    label: 'Bank Confirmed' },
                bank_details_changed:  { icon: 'lucide:pencil',          label: 'Bank Details Changed' },
                revised_estimate:      { icon: 'lucide:file-check',      label: 'Revised Estimate Prepared' },
                req_revised_estimate:  { icon: 'lucide:file-edit',       label: 'Req Revised Estimate' },
                estimate_sent:         { icon: 'lucide:send',             label: 'Estimate Sent to Client' },
                filing_error:              { icon: 'lucide:alert-triangle',   label: 'Filing Error' },
                others:                    { icon: 'lucide:more-horizontal',  label: 'Others' },
                'Client Handled':          { icon: 'lucide:user-round-check', label: 'Client Handled' },
                'Payment Approved':        { icon: 'lucide:circle-dollar-sign', label: 'Payment Approved' },
                'Escalation Closed':       { icon: 'lucide:check-circle-2',  label: 'Escalation Closed' },
            };
            const meta = ACTION_META[e.type] || { icon: 'lucide:activity', label: e.type };

            // Resolve role for badge/theme (drives role label and card alignment)
            const role = e.senderRole || (isRight ? 'caller' : 'preparer');

            const ROLE_THEME = {
                preparer: { roleLabel: 'Tax Preparer', roleColor: '#2563eb' },
                caller:   { roleLabel: 'Caller',       roleColor: '#b45309' },
                manager:  { roleLabel: 'Manager',      roleColor: '#6d28d9' },
            };
            const rt = ROLE_THEME[role] || ROLE_THEME.preparer;

            // ── Action chip color: prefer s2Options color for this action type ──
            // s2Options is available in closure (loaded at filing init)
            const s2Match  = s2Options.find(o => o.name === e.type);
            const chipHex  = s2Match && s2Match.color ? s2Match.color : null;

            // Derive light background + border from chipHex or fall back to role color
            function hexToChipStyle(hex, fallback) {
                if (!hex) return { bg: '#f1f5f9', border: '#cbd5e1', text: fallback };
                // Parse hex → build 15%-opacity bg + 40%-opacity border using currentColor trick
                const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
                return {
                    bg:     `rgba(${r},${g},${b},0.1)`,
                    border: `rgba(${r},${g},${b},0.35)`,
                    text:   hex,
                };
            }
            const chipStyle  = hexToChipStyle(chipHex, rt.roleColor);
            // Left border of the card uses the same action color when available, else role color
            const accentColor = chipHex || rt.roleColor;

            // Action chip (colored pill at top of bubble — uses s2 color)
            const actionChip = `<span style="display:inline-flex;align-items:center;gap:5px;background:${chipStyle.bg};color:${chipStyle.text};border:1px solid ${chipStyle.border};border-radius:6px;padding:3px 10px;font-size:.72rem;font-weight:600;margin-bottom:10px;">
                <iconify-icon icon="${meta.icon}" style="font-size:.75rem;"></iconify-icon>${meta.label}
            </span>`;

            // Role + name header (simple, dot-colored by role)
            const roleDot = `<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${rt.roleColor};flex-shrink:0;"></span>`;
            const nameStr = e.senderName ? `<span style="font-size:.78rem;font-weight:600;color:#1e293b;">${escHtml(e.senderName)}</span>` : '';
            const roleStr = `<span style="font-size:.72rem;color:${rt.roleColor};font-weight:500;">${rt.roleLabel}</span>`;
            const tsStr   = `<span style="font-size:.7rem;color:#94a3b8;margin-left:auto;">·&nbsp;${escHtml(fmtTs(e.timestamp))}</span>`;

            const cardBg    = isRight ? '#f0f9ff' : '#f8fafc';
            const cardAlign = isRight ? 'margin-left:auto;' : '';

            return `
            <div style="margin-bottom:${isLast?'0':'20px'};">
                <div style="max-width:82%;${cardAlign}">
                    <div style="display:flex;align-items:center;gap:7px;margin-bottom:7px;flex-wrap:wrap;">
                        ${roleDot}${roleStr}${nameStr}${tsStr}
                    </div>
                    <div style="background:${cardBg};border-left:3px solid ${accentColor};border-radius:0 8px 8px 0;padding:14px 16px;box-shadow:0 1px 3px rgba(0,0,0,.06);">
                        ${actionChip}
                        ${contentText ? `<div style="font-size:.82rem;color:#1e293b;white-space:pre-wrap;line-height:1.6;">${escHtml(contentText)}</div>` : ''}
                        ${activityFileHtml(e)}
                    </div>
                </div>
                ${divider}
            </div>`;
        }).join('');
    }

    // ── Activity log image click → lightbox ──
    document.getElementById('activityLogItems').addEventListener('click', function (ev) {
        const img = ev.target.closest('.activity-log-img');
        if (!img) return;
        document.getElementById('estimateLightboxImg').src = img.src;
        document.getElementById('estimateLightbox').classList.remove('d-none');
    });

    // ── Compose Action ─────────────────────────────────────────────
    let estimatesStored  = [];    // append-only list of all estimate submissions
    let actionAttachments = [];   // array of {id, fileName, fileSize, fileMimeType, fileData}
    let _attachIdSeq     = 0;
    let activeRole       = null;
    let s2Options        = [];    // populated from /api/itr-status2

    async function loadEstimate() {
        const res = await fetch('/api/itr-filings/' + filingId + '/estimate');
        if (!res.ok) return;
        const data = await res.json();
        if (Array.isArray(data) && data.length) { estimatesStored = data; renderActivityLog(); }
        updateEstimateButtonLabel();
    }

    function updateEstimateButtonLabel() { updateEstimateOptionLabel(); }
    function updateEstimateOptionLabel() {
        const opt = document.querySelector('#actionDropdown option[value="actionEstimateBtn"]');
        if (opt) opt.textContent = estimatesStored.length > 0 ? 'Revised Estimate Prepared' : 'Estimate Prepared';
    }

    function getFileIcon(mime) {
        if (!mime) return 'lucide:file';
        if (mime.startsWith('image/')) return 'lucide:image';
        if (mime === 'application/pdf') return 'lucide:file-text';
        if (mime.includes('word') || mime.includes('document')) return 'lucide:file-type-2';
        return 'lucide:file';
    }

    let _uploadModal = null;
    function getUploadModal() {
        if (!_uploadModal) _uploadModal = new bootstrap.Modal(document.getElementById('uploadProgressModal'));
        return _uploadModal;
    }

    function setActionUploadProgress(pct, label) {
        const bar   = document.getElementById('uploadProgressBarModal');
        const title = document.getElementById('uploadProgressTitle');
        const sub   = document.getElementById('uploadProgressSub');
        const pctEl = document.getElementById('uploadProgressPctModal');
        const icon  = document.getElementById('uploadProgressIcon');

        if (pct === null) {
            if (bar)   bar.style.width = '100%';
            if (pctEl) pctEl.textContent = '100%';
            if (title) title.textContent = 'Done!';
            if (sub)   sub.textContent   = 'File ready.';
            if (icon)  { icon.setAttribute('icon', 'lucide:check-circle'); icon.style.color = '#16a34a'; }
            document.getElementById('uploadProgressModal')
                .closest('.modal') || document.getElementById('uploadProgressModal');
            setTimeout(() => getUploadModal().hide(), 600);
            return;
        }

        if (pct <= 5) {
            if (bar)   bar.style.width = '0%';
            if (pctEl) pctEl.textContent = '0%';
            if (icon)  { icon.setAttribute('icon', 'lucide:upload-cloud'); icon.style.color = '#2563eb'; }
            if (title) title.textContent = label || 'Processing file…';
            if (sub)   sub.textContent   = 'Reading your file, please wait.';
            getUploadModal().show();
        }

        bar.style.width = pct + '%';
        if (pctEl) pctEl.textContent = pct + '%';
        if (title && pct > 5) title.textContent = label || 'Reading…';
    }

    function addAttachment(att) {
        att.id = ++_attachIdSeq;
        actionAttachments.push(att);
        renderAttachmentsList();
    }

    function removeAttachment(id) {
        actionAttachments = actionAttachments.filter(a => a.id !== id);
        renderAttachmentsList();
    }

    function renderAttachmentsList() {
        const wrap = document.getElementById('attachmentsList');
        if (!actionAttachments.length) { wrap.innerHTML = ''; return; }
        wrap.innerHTML = '<div class="d-flex flex-wrap gap-8">' +
            actionAttachments.map(att => {
                const isImg = att.fileMimeType && att.fileMimeType.startsWith('image/');
                const kb    = att.fileSize ? (att.fileSize / 1024).toFixed(1) + ' KB' : '';
                const rmBtn = `<button type="button" onclick="removeAttachment(${att.id})"
                    class="btn p-0 flex-shrink-0 d-flex align-items-center justify-content-center text-danger-600 radius-4"
                    style="width:18px;height:18px;background:rgba(239,68,68,.10);margin-left:4px;" title="Remove">
                    <iconify-icon icon="lucide:x" style="font-size:.6rem;"></iconify-icon></button>`;
                if (isImg) {
                    return `<div class="d-inline-flex align-items-center gap-6 border radius-8 px-8 py-6 bg-light" style="max-width:220px;">
                        <img src="${escHtml(att.fileData)}" alt="${escHtml(att.fileName)}"
                             class="radius-4 attach-thumb flex-shrink-0"
                             style="width:36px;height:28px;object-fit:cover;cursor:zoom-in;"
                             data-src="${escHtml(att.fileData)}">
                        <span class="text-xs fw-medium text-truncate flex-grow-1">${escHtml(att.fileName)}</span>
                        ${kb ? `<span class="text-secondary-light" style="font-size:.62rem;white-space:nowrap;">${kb}</span>` : ''}
                        ${rmBtn}
                    </div>`;
                }
                const icon = getFileIcon(att.fileMimeType);
                return `<div class="d-inline-flex align-items-center gap-6 border radius-8 px-8 py-6 bg-light" style="max-width:220px;">
                    <iconify-icon icon="${icon}" class="text-primary-600 flex-shrink-0" style="font-size:1rem;"></iconify-icon>
                    <span class="text-xs fw-medium text-truncate flex-grow-1">${escHtml(att.fileName)}</span>
                    ${kb ? `<span class="text-secondary-light" style="font-size:.62rem;white-space:nowrap;">${kb}</span>` : ''}
                    ${rmBtn}
                </div>`;
            }).join('') + '</div>';
    }

    // Lightbox for attachment thumbnails
    document.getElementById('attachmentsList').addEventListener('click', function (ev) {
        const thumb = ev.target.closest('.attach-thumb');
        if (!thumb) return;
        document.getElementById('estimateLightboxImg').src = thumb.dataset.src;
        document.getElementById('estimateLightbox').classList.remove('d-none');
    });

    function clearActionForm() {
        document.getElementById('actionText').value = '';
        document.getElementById('actionFile').value = '';
        actionAttachments = [];
        renderAttachmentsList();
        setActionUploadProgress(null);
        document.getElementById('actionDropdown').value = '';
        document.getElementById('notifyPreparerChk').checked = false;
        // Auto-close the Update modal if it was used to submit
        const _tuModal = bootstrap.Modal.getInstance(document.getElementById('trackerUpdateModal'));
        if (_tuModal) _tuModal.hide();
    }

    // ── Tracker Update Modal — DOM-move compose widget ────────────────
    (function () {
        const modalEl  = document.getElementById('trackerUpdateModal');
        const widget   = document.getElementById('composeWidget');
        const mount    = document.getElementById('composeWidgetMount');
        const home     = document.getElementById('composeWidgetHome');

        // Open modal
        document.getElementById('trackerUpdateBtn').addEventListener('click', function () {
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        });

        // Move widget INTO modal before it becomes visible
        modalEl.addEventListener('show.bs.modal', function () {
            mount.appendChild(widget);
        });

        // Move widget BACK to Action History when modal closes
        modalEl.addEventListener('hidden.bs.modal', function () {
            home.appendChild(widget);
        });
    })();

    // ── Load employees into dropdowns ──
    async function loadEmployeeDropdowns() {
        try {
            const res = await fetch('/api/employees');
            if (!res.ok) return;
            const employees = await res.json();
            const byRole = { 'Tax Preparer': [], 'Caller': [], 'Manager': [] };
            employees.forEach(e => { if (byRole[e.designation]) byRole[e.designation].push(e); });
            const fill = (id, role) => {
                const sel = document.getElementById(id);
                while (sel.options.length > 1) sel.remove(1);
                byRole[role].forEach(e => {
                    const opt = document.createElement('option');
                    opt.value = e.name; opt.textContent = e.name;
                    sel.appendChild(opt);
                });
            };
            fill('roleTaxPreparer', 'Tax Preparer');
            fill('roleCaller', 'Caller');
            fill('roleManager', 'Manager');
        } catch (_) {}
    }

    function getPreparerOpts() {
        return s2Options.filter(o => o.role === 'preparer').map(o => ({ id: o.id, label: o.name }));
    }
    function getCallerOpts() {
        return s2Options.filter(o => o.role === 'caller').map(o => ({ id: o.id, label: o.name }));
    }
    function getCommonOpts() {
        return s2Options.filter(o => o.role === 'common').map(o => ({ id: o.id, label: o.name }));
    }
    function getManagerOpts() {
        return s2Options.filter(o => o.role === 'manager').map(o => ({ id: o.id, label: o.name }));
    }

    function buildOption(opt) {
        const el = document.createElement('option');
        el.value = opt.id;
        el.textContent = opt.label;
        return el;
    }

    function updateActionButtons(role) {
        const sel  = document.getElementById('actionDropdown');

        if (!role) {
            sel.innerHTML = '<option value="">— Select a role first —</option>';
            sel.disabled = true;
            return;
        }
        sel.disabled = false;
        sel.innerHTML = '<option value="">— Select action —</option>';

        const preparerOpts = getPreparerOpts();
        const callerOpts   = getCallerOpts();
        const commonOpts   = getCommonOpts();
