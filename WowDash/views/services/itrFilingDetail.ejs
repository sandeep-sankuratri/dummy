<%
var copySvg = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
var copyBtn = '<button type="button" class="copy-btn" title="Copy" style="border:none;background:transparent;padding:0;color:#cbd5e1;line-height:1;flex-shrink:0;cursor:pointer;display:inline-flex;align-items:center;">' + copySvg + '</button>';
%>
<style>
/* ── Compact progress tracker ── */
.tracker-wrap { overflow-x: auto; padding: 8px 0 4px; }
.tracker { display: flex; align-items: flex-start; min-width: max-content; gap: 0; }
.tracker-step { display: flex; flex-direction: column; align-items: center; position: relative; flex: 0 0 auto; width: 148px; }
.tracker-step:not(:last-child) .tracker-line { position: absolute; top: 16px; left: calc(50% + 19px); width: calc(100% - 38px); height: 2px; background: #e2e8f0; border-radius: 2px; z-index: 0; }
.tracker-step.t-done:not(:last-child) .tracker-line { background: #17a248; }
.tracker-circle { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 1; border: 2px solid #e2e8f0; background: #fff; color: #94a3b8; font-size: 14px; position: relative; flex-shrink: 0; }
.tracker-step.t-done .tracker-circle { border-color: #17a248; background: #17a248; color: #fff; }
.tracker-step.t-active .tracker-circle { border-color: #0066ff; background: #0066ff; color: #fff; box-shadow: 0 0 0 4px rgba(0,102,255,.13); }
.tracker-label { font-size: .67rem; font-weight: 600; margin-top: 8px; text-align: center; color: #64748b; word-break: break-word; max-width: 132px; line-height: 1.3; }
.tracker-step.t-done .tracker-label { color: #17a248; }
.tracker-step.t-active .tracker-label { color: #0066ff; }
.tracker-meta { margin-top: 5px; padding-top: 5px; border-top: 1px solid #f1f5f9; width: 80%; display: flex; flex-direction: column; align-items: center; gap: 1px; }
.tracker-step.t-done .tracker-meta { border-top-color: #dcfce7; }
.tracker-step.t-active .tracker-meta { border-top-color: #dbeafe; }
.tracker-by { font-size: .6rem; color: #94a3b8; text-align: center; max-width: 132px; word-break: break-word; line-height: 1.3; }
.tracker-note { font-size: .6rem; color: #94a3b8; text-align: center; max-width: 132px; word-break: break-word; line-height: 1.3; }
.tracker-ts { font-size: .59rem; color: #94a3b8; text-align: center; margin-top: 4px; }
/* ── Income / doc styles ── */
.income-chip { cursor:pointer; border:1.5px solid #e2e8f0; border-radius:20px; padding:4px 14px; font-size:.75rem; font-weight:600; color:#64748b; background:#fff; user-select:none; transition:all .15s; display:inline-flex; align-items:center; gap:5px; }
.income-chip.selected { border-color:#0066ff; background:#e8f0fe; color:#2563eb; }
.income-chip .chip-check { font-size:.7rem; }
.income-head-section { border:1.5px solid #e2e8f0; border-left:4px solid var(--section-color,#0066ff); border-radius:10px; overflow:hidden; }
.doc-item { background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:8px 12px; }
.btn-purple { background:#6d28d9; color:#fff; border-color:#6d28d9; }
.btn-purple:hover, .btn-purple:focus { background:#5b21b6; border-color:#5b21b6; color:#fff; }
</style>


<!-- Loading / Error -->
<div id="loadingState" class="card p-40 text-center text-secondary-light mb-24">
    <iconify-icon icon="svg-spinners:ring-resize" class="text-4xl mb-12"></iconify-icon>
    <p class="mb-0 text-sm">Loading filing details...</p>
</div>
<div id="errorState" class="alert alert-danger d-none">Filing not found. <a href="/services/itr-individual" class="alert-link">Back to list</a></div>

<div id="mainContent" class="d-none">

    <!-- ════════════════════════════════════════════════ -->
    <!--  1. PROGRESS TRACKER                            -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="card radius-12 border mb-20 p-16">

        <!-- Header row -->
        <div class="d-flex align-items-center gap-10 mb-12 flex-wrap">
            <iconify-icon icon="lucide:git-branch" class="text-primary-600 text-sm flex-shrink-0"></iconify-icon>
            <span class="fw-semibold text-sm text-primary-light">Filing Progress</span>
            <span id="tracker_currentBadge"
                  style="font-size:.68rem;font-weight:600;color:#2563eb;background:#e8f0fe;white-space:nowrap;flex-shrink:0;padding:2px 8px;border-radius:4px;">Loading…</span>
            <button type="button" id="trackerUpdateBtn"
                    class="btn btn-primary text-xs radius-8 d-inline-flex align-items-center gap-6 ms-auto"
                    style="padding:5px 14px;">
                <iconify-icon icon="lucide:pencil-line" style="font-size:.85rem;"></iconify-icon>
                Update
            </button>
        </div>

        <!-- Compact timeline -->
        <div class="tracker-wrap">
            <div class="tracker" id="progressTracker"></div>
        </div>
    </div>

    <!-- ════ TWO-COLUMN LAYOUT ════ -->
    <div class="row g-20">

    <!-- ── LEFT COLUMN (75%) ─────────────────────────── -->
    <div class="col-lg-8 d-flex flex-column gap-20">

    <!-- ════════════════════════════════════════════════ -->
    <!--  2. CLIENT DETAILS CARD                         -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="card radius-12 border p-0">
        <div class="card-header border-bottom bg-base py-14 px-20 d-flex align-items-center justify-content-between flex-wrap gap-10">
            <h6 class="fw-semibold mb-0 d-flex align-items-center gap-8 text-sm">
                <iconify-icon icon="lucide:user" class="text-primary-600 text-md"></iconify-icon>
                Client Information
            </h6>
            <div id="clientViewActions">
                <button id="editClientBtn" class="btn btn-outline-primary radius-8 d-flex align-items-center gap-6 text-xs" style="padding:5px 12px;" data-testid="button-edit-client">
                    <iconify-icon icon="lucide:edit" class="text-sm"></iconify-icon>Edit
                </button>
            </div>
            <div id="clientEditActions" class="d-none gap-8">
                <button id="saveClientBtn" class="btn btn-primary radius-8 d-flex align-items-center gap-6 text-xs" style="padding:5px 12px;">
                    <iconify-icon icon="lucide:save" class="text-sm"></iconify-icon>Save
                </button>
                <button id="cancelClientBtn" class="border border-danger-600 bg-hover-danger-200 text-danger-600 radius-8 d-flex align-items-center gap-6 text-xs" style="padding:5px 12px;line-height:1;">
                    <iconify-icon icon="lucide:x" style="font-size:.85rem;vertical-align:middle;"></iconify-icon>Cancel
                </button>
            </div>
        </div>
        <div class="card-body p-24">
            <div id="clientError" class="alert alert-danger d-none mb-16"></div>

            <!-- Client banner -->
            <div class="d-flex align-items-center gap-12 mb-16">
                <div id="c_avatar" class="w-32-px h-32-px bg-primary-600 text-white d-flex align-items-center justify-content-center rounded-circle flex-shrink-0 fw-semibold text-xs">?</div>
                <span class="fw-semibold text-sm" id="c_name_banner">—</span>
                <a id="c_profileLink" href="#" class="text-primary-600 text-xs ms-2">View Full Profile ↗</a>
            </div>

            <div class="client-info-grid">

                <!-- Row 1 -->
                <div class="row g-0 border-bottom py-10">
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Full Name</div>
                        <div id="v_c_name" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_name" type="text" class="form-control form-control-sm radius-6 d-none" placeholder="Full name">
                    </div>
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Email</div>
                        <div id="v_c_email" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_email" type="email" class="form-control form-control-sm radius-6 d-none" placeholder="Email address">
                    </div>
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Mobile</div>
                        <div id="v_c_mobile" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_mobile" type="text" class="form-control form-control-sm radius-6 d-none" placeholder="Mobile">
                    </div>
                </div>

                <!-- Row 2 -->
                <div class="row g-0 border-bottom py-10">
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Alternate Mobile</div>
                        <div id="v_c_altMobile" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_altMobile" type="text" class="form-control form-control-sm radius-6 d-none" placeholder="Alternate mobile">
                    </div>
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">PAN</div>
                        <div id="v_c_pan" class="fw-bold text-sm d-flex align-items-center gap-4" style="letter-spacing:.06em"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_pan" type="text" class="form-control form-control-sm radius-6 d-none" placeholder="PAN" maxlength="10" style="text-transform:uppercase">
                    </div>
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Date of Birth</div>
                        <div id="v_c_dob" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_dob" type="date" class="form-control form-control-sm radius-6 d-none">
                    </div>
                </div>

                <!-- Row 3 -->
                <div class="row g-0 border-bottom py-10">
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Aadhar No</div>
                        <div id="v_c_aadhar" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <input id="e_c_aadhar" type="text" class="form-control form-control-sm radius-6 d-none" placeholder="Aadhar" maxlength="12">
                    </div>
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Caller</div>
                        <div id="v_c_caller" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <select id="e_c_caller" class="form-control form-control-sm radius-6 form-select d-none"></select>
                    </div>
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">Source</div>
                        <div id="v_c_source" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <select id="e_c_source" class="form-control form-control-sm radius-6 form-select d-none"></select>
                    </div>
                </div>

                <!-- Row 4: ITR Password -->
                <div class="row g-0 border-bottom py-10">
                    <div class="col-md-4 col-sm-6 px-8">
                        <div class="text-secondary-light text-xs mb-4">ITR Password</div>
                        <div class="d-flex align-items-center gap-6">
                            <span id="v_c_itrPassword" class="fw-medium text-sm">—</span>
                            <button id="c_itrToggleBtn" type="button" class="border-0 bg-transparent text-secondary-light p-0 d-none" onclick="toggleClientItrPassword()" title="Show / Hide">
                                <iconify-icon icon="iconamoon:eye-light" id="c_itr_eye" class="text-md"></iconify-icon>
                            </button>
                            <button type="button" id="c_itrCopyBtn" class="copy-btn d-none" title="Copy password" style="border:none;background:transparent;padding:0;color:#cbd5e1;line-height:1;flex-shrink:0;cursor:pointer;"><%- copySvg %></button>
                        </div>
                        <div class="position-relative d-none" id="e_c_itrPasswordWrap">
                            <input type="password" id="e_c_itrPassword" class="form-control form-control-sm radius-6 pe-32" placeholder="ITR password">
                            <button type="button" class="position-absolute end-0 top-50 translate-middle-y me-8 border-0 bg-transparent text-secondary-light p-0" onclick="toggleClientEditPass()">
                                <iconify-icon icon="iconamoon:eye-light" id="c_e_itr_eye" class="text-md"></iconify-icon>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Row 5: Remarks -->
                <div class="row g-0 py-10">
                    <div class="col-12 px-8">
                        <div class="text-secondary-light text-xs mb-4">Remarks</div>
                        <div id="v_c_remarks" class="fw-medium text-sm d-flex align-items-center gap-4"><span class="copy-val">—</span><%- copyBtn %></div>
                        <textarea id="e_c_remarks" class="form-control form-control-sm radius-6 d-none" rows="2" placeholder="Remarks..."></textarea>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════ -->
    <!--  3. INCOME DETAILS CARD                         -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="card radius-12 border p-0">
        <div class="card-header border-bottom bg-base py-14 px-20 d-flex align-items-center gap-8">
            <h6 class="fw-semibold mb-0 d-flex align-items-center gap-8 text-sm">
                <iconify-icon icon="lucide:indian-rupee" class="text-success-600 text-md"></iconify-icon>
                Income Details
            </h6>
        </div>
        <div class="card-body p-20">
            <div id="incomeError" class="alert alert-danger d-none mb-12"></div>

            <div class="d-flex flex-wrap gap-8 mb-20" id="incomeHeadSelector"></div>

            <div id="incomeHeadSections"></div>

            <!-- Income Notes -->
            <div class="mt-16 pt-16 border-top">
                <div class="d-flex align-items-center gap-6 mb-8">
                    <label class="text-xs fw-semibold text-secondary-light mb-0" style="letter-spacing:.03em;text-transform:uppercase;" for="incomeNotesArea">Notes</label>
                    <span id="incomeNotesSaveStatus" class="text-xs text-secondary-light ms-auto d-none" style="font-style:italic;"></span>
                </div>
                <textarea id="incomeNotesArea" rows="3" class="form-control radius-8 text-sm w-100"
                          placeholder="Add any notes or remarks about the income details…"
                          style="resize:vertical;min-height:72px;"
                          data-testid="textarea-income-notes"></textarea>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════ -->
    <!--  4. DEDUCTIONS CARD                             -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="card radius-12 border p-0">
        <div class="card-header border-bottom bg-base py-14 px-20 d-flex align-items-center gap-8">
            <h6 class="fw-semibold mb-0 d-flex align-items-center gap-8 text-sm">
                <iconify-icon icon="lucide:receipt-text" class="text-warning-600 text-md"></iconify-icon>
                Deductions
            </h6>
        </div>
        <div class="card-body p-20">
            <div class="row g-16">
                <!-- Left: Notes textarea -->
                <div class="col-md-6">
                    <div class="d-flex align-items-center justify-content-between mb-6" style="min-height:28px;">
                        <label class="form-label text-secondary-light text-xs mb-0" style="white-space:nowrap;">Notes / Remarks</label>
                        <span id="deductionSaved" class="text-success-600 d-none" style="font-size:.68rem;">Saved</span>
                    </div>
                    <textarea id="deductionNotes" class="form-control radius-8 text-sm" rows="7"
                        placeholder="Enter deduction details, exemptions, 80C, 80D, HRA, etc..."
                        style="resize:vertical;"></textarea>
                </div>
                <!-- Right: Document upload -->
                <div class="col-md-6">
                    <div class="d-flex align-items-center justify-content-between mb-6" style="min-height:28px;">
                        <div class="d-flex align-items-center gap-6">
                            <label class="form-label text-secondary-light text-xs mb-0">Supporting Documents</label>
                            <span id="deductionDocCount" class="badge text-xs px-6 py-2 radius-6" style="background:#f1f5f9;color:#64748b;">0 docs</span>
                        </div>
                        <label class="btn btn-sm radius-6 px-10 py-4 d-flex align-items-center gap-1 mb-0 text-xs" style="cursor:pointer;background:#e8f0fe;color:#2563eb;border:none;">
                            <iconify-icon icon="lucide:upload-cloud" class="text-xs"></iconify-icon>Upload
                            <input type="file" class="d-none" id="deductionDocUpload" multiple
                                accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx">
                        </label>
                    </div>
                    <div id="deductionDocList" class="d-flex flex-column gap-6" style="min-height:120px;">
                        <p class="text-secondary-light mb-0" style="font-size:.72rem">No documents uploaded yet.</p>
                    </div>
                    <div id="deductionPendingPanel" class="d-none mt-8" style="border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;">
                        <div class="px-14 py-8" style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                            <span class="text-xs fw-semibold text-secondary-light" style="letter-spacing:.03em;text-transform:uppercase;">Ready to upload</span>
                        </div>
                        <div class="px-14 py-10">
                            <div id="deductionPendingList" class="d-flex flex-column gap-6"></div>
                            <button id="deductionDoUploadBtn" class="btn btn-sm btn-primary radius-6 mt-10 text-xs px-12" style="height:28px;">Upload</button>
                        </div>
                    </div>
                    <div id="deductionUploadProgress" class="d-none mt-6">
                        <div class="text-xs fw-semibold text-secondary-light mb-8" style="letter-spacing:.03em;text-transform:uppercase;">Uploading…</div>
                        <div id="deductionProgList" class="d-flex flex-column gap-6"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════ -->
    <!--  ASSIGN TAX PREPARER SECTION                    -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="d-none mt-20" id="assignPreparerSection">

            <!-- Image lightbox overlay -->
            <div id="estimateLightbox"
                 class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                 style="background:rgba(0,0,0,.88);z-index:9999;">
                <button type="button" id="estimateLightboxClose"
                        class="btn-close btn-close-white position-absolute"
                        style="top:20px;right:24px;font-size:1.3rem;"></button>
                <img id="estimateLightboxImg" src="" alt=""
                     style="max-width:90vw;max-height:90vh;border-radius:8px;box-shadow:0 8px 40px rgba(0,0,0,.6);">
            </div>

            <!-- Upload progress modal -->
            <div class="modal fade" id="uploadProgressModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-sm modal-dialog-centered">
                    <div class="modal-content radius-12 border-0 shadow-lg">
                        <div class="modal-body p-28 text-center">
                            <div class="mb-12 d-flex align-items-center justify-content-center"
                                 style="width:56px;height:56px;border-radius:50%;background:#eff6ff;margin:0 auto;">
                                <iconify-icon id="uploadProgressIcon" icon="lucide:upload-cloud"
                                              style="font-size:1.6rem;color:#2563eb;"></iconify-icon>
                            </div>
                            <h6 class="fw-semibold text-sm mb-4" id="uploadProgressTitle">Processing file…</h6>
                            <p class="text-xs text-secondary-light mb-16" id="uploadProgressSub">Reading your file, please wait.</p>
                            <div class="w-100 radius-6 bg-neutral-200 mb-8" style="height:8px;">
                                <div id="uploadProgressBarModal"
                                     class="radius-6 bg-primary-600"
                                     style="height:8px;width:0%;transition:width .12s ease;"></div>
                            </div>
                            <span id="uploadProgressPctModal" class="text-xs fw-bold text-primary-600">0%</span>
                        </div>
                    </div>
                </div>
            </div>

    </div><!-- /assignPreparerSection -->

    <!-- ── Action History + Compose (unified card) ── -->
    <div id="activityLogSection" class="d-none mt-20">
                <div class="card radius-12 border p-0">
                    <!-- Card header -->
                    <div class="card-header border-bottom bg-base py-14 px-20">
                        <h6 class="fw-semibold mb-0 d-flex align-items-center gap-8 text-sm">
                            <iconify-icon icon="lucide:activity" class="text-primary-600 text-md"></iconify-icon>
                            Action History
                        </h6>
                    </div>
                    <div class="card-body p-20">

                        <!-- History items -->
                        <div id="activityLogItems" style="margin-bottom:28px;"></div>

                        <!-- Compose section -->
                        <div class="border-top pt-16 mt-0">
                            <!-- Home anchor — compose widget returns here when modal closes -->
                            <div id="composeWidgetHome">

                            <!-- Compose card wrapper (moveable widget) -->
                            <div id="composeWidget" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:16px 18px;">
                                <div class="row g-3" style="align-items:stretch;">

                                    <!-- Col 1: Acting as -->
                                    <div class="col-lg-3" style="display:flex;flex-direction:column;">
                                        <p class="text-xs fw-semibold text-secondary-light mb-10 d-flex align-items-center gap-6">
                                            <iconify-icon icon="lucide:users" style="font-size:.85rem;"></iconify-icon>
                                            Acting as
                                        </p>
                                        <div style="display:flex;flex-direction:column;gap:8px;flex:1;">
                                            <div class="d-flex align-items-center gap-8">
                                                <span style="width:28px;height:28px;border-radius:6px;background:#dbeafe;flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;">
                                                    <iconify-icon icon="lucide:file-check" style="font-size:.8rem;color:#2563eb;"></iconify-icon>
                                                </span>
                                                <select id="roleTaxPreparer" class="form-select form-select-sm text-xs flex-fill radius-6" style="border-color:#bfdbfe;background:#fff;">
                                                    <option value="">Tax Preparer</option>
                                                </select>
                                            </div>
                                            <div class="d-flex align-items-center gap-8">
                                                <span style="width:28px;height:28px;border-radius:6px;background:#fef3c7;flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;">
                                                    <iconify-icon icon="lucide:phone" style="font-size:.8rem;color:#b45309;"></iconify-icon>
                                                </span>
                                                <select id="roleCaller" class="form-select form-select-sm text-xs flex-fill radius-6" style="border-color:#fde68a;background:#fff;">
                                                    <option value="">Caller</option>
                                                </select>
                                            </div>
                                            <div class="d-flex align-items-center gap-8">
