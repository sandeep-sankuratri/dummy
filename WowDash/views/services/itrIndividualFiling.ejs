        <div class="modal-content radius-16 bg-base">
            <div class="modal-header px-24 py-16 border-bottom">
                <div>
                    <h5 class="modal-title fw-semibold mb-2">Assign Client to ITR Individual Filing</h5>
                    <div class="d-flex align-items-center gap-8 mt-4">
                        <span id="step1Crumb" class="badge bg-primary-600 text-white text-xs px-10 py-4 radius-8">Step 1: Select Client</span>
                        <iconify-icon icon="ep:arrow-right" class="text-secondary-light text-xs"></iconify-icon>
                        <span id="step2Crumb" class="badge bg-neutral-200 text-secondary-light text-xs px-10 py-4 radius-8">Step 2: Select FY</span>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-24">
