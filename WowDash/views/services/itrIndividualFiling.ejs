<!-- ══════════════════ MAIN CARD ══════════════════ -->
<div class="card h-100 p-0 radius-12">

    <!-- Card Header -->
    <div id="filterPanelAnchor" class="card-header border-bottom bg-base py-12 px-20">

        <!-- Toolbar -->
        <div class="d-flex align-items-center gap-8 flex-wrap">

            <!-- Page size -->
            <div class="csel-wrap" style="width:66px;">
                <select id="pageSizeSelect">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
                <div class="csel-face">
                    <span id="pageSizeFaceLabel">10</span>
                    <iconify-icon icon="lucide:chevron-down" class="csel-arrow"></iconify-icon>
                </div>
            </div>

            <!-- Search -->
            <form class="navbar-search mb-0" onsubmit="return false;">
                <input type="text" id="searchInput" class="bg-base" placeholder="Search name, PAN, mobile…"
                    style="height:34px;padding-left:32px;font-size:.75rem;min-width:200px;">
                <iconify-icon icon="ion:search-outline" class="icon" style="font-size:.85rem;top:50%;transform:translateY(-50%);"></iconify-icon>
            </form>

            <!-- Filter toggle -->
            <button type="button" id="filterToggleBtn"
                class="btn border text-xs radius-8 d-inline-flex align-items-center"
                style="height:34px;padding:0 12px;white-space:nowrap;gap:5px;border-color:#6366f1!important;color:#6366f1;">
                <iconify-icon icon="lucide:sliders-horizontal" style="font-size:.85rem;line-height:1;display:flex;"></iconify-icon>Filters
                <span id="filterBadge" class="d-none">0</span>
            </button>

            <!-- Clear all -->
            <button type="button" id="clearFiltersBtn"
                class="btn border border-secondary-light text-secondary-light text-xs radius-8 d-none d-inline-flex align-items-center gap-4"
                style="height:34px;padding:0 10px;white-space:nowrap;">
                <iconify-icon icon="lucide:x" style="font-size:.7rem;"></iconify-icon>Clear Filters
                <span id="clearFiltersCount"
                    style="display:inline-flex;align-items:center;justify-content:center;min-width:16px;height:16px;border-radius:20px;background:#94a3b8;color:#fff;font-size:.6rem;font-weight:700;padding:0 4px;"></span>
            </button>

            <!-- Right: export + assign -->
            <div class="ms-auto d-flex align-items-center gap-6 flex-shrink-0">
                <button type="button" id="exportCsvBtn" title="Export CSV"
                    class="btn btn-outline-secondary-600 text-xs radius-8 d-inline-flex align-items-center gap-4"
                    style="height:34px;padding:0 12px;white-space:nowrap;">
                    <iconify-icon icon="lucide:file-spreadsheet" style="font-size:.85rem;"></iconify-icon>CSV
                </button>
                <button type="button" id="exportPdfBtn" title="Export PDF"
                    class="btn btn-outline-secondary-600 text-xs radius-8 d-inline-flex align-items-center gap-4"
                    style="height:34px;padding:0 12px;white-space:nowrap;">
                    <iconify-icon icon="lucide:file-text" style="font-size:.85rem;"></iconify-icon>PDF
                </button>
                <button type="button" id="openAssignBtn" class="d-none" aria-hidden="true"></button>
            </div>
        </div>

        <!-- ── Filter Panel (floating popup) ── -->
        <div id="filterPanel" class="d-none">
            <div class="fp-header">
                <div class="fp-header-title">
                    <iconify-icon icon="lucide:sliders-horizontal" style="font-size:.85rem;color:#6366f1;"></iconify-icon>
                    Filter Filings
                </div>
                <button type="button" id="fpCloseBtn" style="background:none;border:none;cursor:pointer;color:#94a3b8;font-size:1rem;line-height:1;padding:2px;">
                    <iconify-icon icon="lucide:x"></iconify-icon>
                </button>
            </div>

            <div class="fp-body">
                <!-- Row 1: Date, FY, Filing Status, Filing Type -->
                <div class="fp-section-title">Date &amp; Period &nbsp;·&nbsp; Return Details &nbsp;·&nbsp; Team &nbsp;·&nbsp; Financials</div>
                <div class="row g-8 mb-8">
                    <div class="col-3">
                        <div class="fp-label">Date From</div>
                        <input type="date" id="filterDateFrom" class="fp-input">
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Date To</div>
                        <input type="date" id="filterDateTo" class="fp-input">
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Financial Year</div>
                        <select id="filterFY" class="fp-select"><option value="">All FY</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Filing Status</div>
                        <select id="filterStatus" class="fp-select"><option value="">All Statuses</option></select>
                    </div>
                </div>
                <div class="row g-8 mb-8">
                    <div class="col-3">
                        <div class="fp-label">Filing Type</div>
                        <select id="filterFilingType" class="fp-select"><option value="">All Types</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">ITR Type</div>
                        <select id="filterItrType" class="fp-select"><option value="">All ITR Types</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Return Outcome</div>
                        <select id="filterReturnOutcome" class="fp-select"><option value="">All Outcomes</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Payment Status</div>
                        <select id="filterPayStatus" class="fp-select">
                            <option value="">All</option>
                            <option value="Paid">Paid</option>
                            <option value="Partial">Partial</option>
                            <option value="Unpaid">Unpaid</option>
                            <option value="—">Not Set</option>
                        </select>
                    </div>
                </div>
                <div class="row g-8">
                    <div class="col-3">
                        <div class="fp-label">Caller</div>
                        <select id="filterCaller" class="fp-select"><option value="">All Callers</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Tax Preparer</div>
                        <select id="filterPreparer" class="fp-select"><option value="">All Preparers</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Manager</div>
                        <select id="filterManager" class="fp-select"><option value="">All Managers</option></select>
                    </div>
                    <div class="col-3">
                        <div class="fp-label">Pay. Handled By</div>
                        <select id="filterPayHandler" class="fp-select"><option value="">All</option></select>
                    </div>
                </div>
                <div class="row g-8 mt-8">
                    <div class="col-4">
                        <div class="fp-label">Final Fee (₹)</div>
                        <div class="d-flex align-items-center gap-6">
                            <input type="number" id="filterFeeMin" class="fp-input" placeholder="Min" min="0" style="width:50%;">
                            <span class="text-secondary-light text-xs flex-shrink-0">–</span>
                            <input type="number" id="filterFeeMax" class="fp-input" placeholder="Max" min="0" style="width:50%;">
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="fp-label">Paid (₹)</div>
                        <div class="d-flex align-items-center gap-6">
                            <input type="number" id="filterPaidMin" class="fp-input" placeholder="Min" min="0" style="width:50%;">
                            <span class="text-secondary-light text-xs flex-shrink-0">–</span>
                            <input type="number" id="filterPaidMax" class="fp-input" placeholder="Max" min="0" style="width:50%;">
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="fp-label">Balance (₹)</div>
                        <div class="d-flex align-items-center gap-6">
                            <input type="number" id="filterBalMin" class="fp-input" placeholder="Min" min="0" style="width:50%;">
                            <span class="text-secondary-light text-xs flex-shrink-0">–</span>
                            <input type="number" id="filterBalMax" class="fp-input" placeholder="Max" min="0" style="width:50%;">
                        </div>
                    </div>
                </div>
            </div>

            <div class="fp-footer">
                <button type="button" class="fp-clear-btn" id="fpClearBtn">
                    <iconify-icon icon="lucide:rotate-ccw" style="font-size:.75rem;"></iconify-icon>Reset
                </button>
                <button type="button" class="fp-apply-btn" id="fpApplyBtn">
                    <iconify-icon icon="lucide:check" style="font-size:.8rem;"></iconify-icon>Apply Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card-body p-0">
        <div class="table-responsive scroll-sm">
            <table class="table mb-0 itr-table" id="filingsTable">
                <thead>
                    <tr>
                        <th style="width:42px;">#</th>
                        <th>Date</th>
                        <th class="col-client">Client</th>
                        <th>PAN</th>
                        <th>Mobile</th>
                        <th>FY</th>
                        <th class="col-caller">Caller</th>
                        <th class="col-mgr">Manager</th>
                        <th class="col-prep">Preparer</th>
                        <th class="col-divider">Filing Status</th>
                        <th>Filing Type</th>
                        <th>ITR Type</th>
                        <th>Return Outcome</th>
                        <th class="col-divider">Final Fee</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Pay. Status</th>
                        <th>Pay. Handled By</th>
                    </tr>
                </thead>
                <tbody id="filingsTableBody">
                    <tr id="loadingRow"><td colspan="18" class="text-center text-secondary-light py-32">
                        <iconify-icon icon="svg-spinners:ring-resize" style="font-size:1.4rem;color:#6366f1;display:block;margin:0 auto 8px;"></iconify-icon>
                        Loading filings…
                    </td></tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 px-20 py-14 border-top">
            <span id="paginationInfo" class="text-secondary-light text-sm"></span>
            <ul class="pagination d-flex flex-wrap align-items-center gap-2 justify-content-center mb-0" id="paginationList"></ul>
        </div>
    </div>
</div>


<script>
(function () {
    let allFilings = [];
    let filtered = [];
    let currentPage = 1;
    let pageSize = 10;
    let pendingStatusId = null;
    let itrStatuses = [];
    let s2Options = [];       // filing status colours
    let outcomeOptions = [];  // return outcome colours
    let s2Options_fys = [];
    let activeChipField = null;   // 'filingStatus' | 'filingType' | 'returnOutcome' | 'paymentHandledBy' | null
    let activeChipValue = null;   // the specific value being filtered

    // ── Helpers ─────────────────────────────────────────────────────
    function escHtml(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function fmtDate(iso) { if (!iso) return ''; return new Date(iso).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }); }
    function isoDate(iso) { if (!iso) return ''; return iso.slice(0, 10); }

    function hexToRgb(hex) {
        const h = hex.replace('#','');
        const n = parseInt(h.length === 3 ? h.split('').map(c=>c+c).join('') : h, 16);
        return [(n>>16)&255,(n>>8)&255,n&255];
    }

    // Returns true for statuses that should be shown in the Filing Status column.
    function isDisplayableStatus(s) {
        if (!s) return false;
        if (s === 'Opened') return true;
        return s2Options.some(o => o.name === s);
    }

    // Resolve which status to show: if the current status is an assignment/system status,
    // walk the history backwards to find the last displayable status.
    function resolveDisplayStatus(f) {
        if (isDisplayableStatus(f.filingStatus)) return f.filingStatus;
        const history = f.statusHistory || [];
        for (let i = history.length - 1; i >= 0; i--) {
            if (isDisplayableStatus(history[i].status)) return history[i].status;
        }
        return '';
    }

    // Filing status badge — shows dropdown-defined statuses plus "Opened".
    function filingBadge(s) {
        if (!s) return '';
        const opt = s2Options.find(o => o.name === s);
        if (!opt) {
            if (s === 'Opened') return `<span class="pill" style="background:#f1f5f9;color:#475569;">${escHtml(s)}</span>`;
            return '';
        }
        if (opt.color) {
            const [r,g,b] = hexToRgb(opt.color);
            return `<span class="pill" style="background:rgba(${r},${g},${b},0.12);color:${opt.color};">${escHtml(s)}</span>`;
        }
        return `<span class="pill" style="background:#f1f5f9;color:#475569;">${escHtml(s)}</span>`;
    }

    // Filing type — plain text
    function filingTypeText(s) {
        if (!s) return '';
        return `<span class="text-sm">${escHtml(s)}</span>`;
    }

    // ITR type — plain text
    function itrTypeText(s) {
        if (!s) return '';
        return `<span class="text-sm">${escHtml(s)}</span>`;
    }

    // Return outcome badge (uses outcomeOptions colors, no dot)
    function outcomeBadge(s) {
        if (!s) return '';
        const opt = outcomeOptions.find(o => o.name === s);
        if (opt && opt.color) {
            const [r,g,b] = hexToRgb(opt.color);
            return `<span class="pill" style="background:rgba(${r},${g},${b},0.12);color:${opt.color};">${escHtml(s)}</span>`;
        }
        return `<span class="pill" style="background:#f1f5f9;color:#475569;">${escHtml(s)}</span>`;
    }

    const payColors = { 'Paid': '#22C55E', 'Partial': '#F59E0B', 'Unpaid': '#EF4444' };
    function payBadge(s) {
        if (!s || s === '—') return '';
        const color = payColors[s];
        if (color) {
            const [r,g,b] = hexToRgb(color);
            return `<span class="pill" style="background:rgba(${r},${g},${b},0.1);color:${color};">${escHtml(s)}</span>`;
        }
        return `<span class="pill" style="background:#f1f5f9;color:#475569;">${escHtml(s)}</span>`;
    }

    // Balance cell — highlighted fill if non-zero
    function balanceCell(v, feeSet) {
        if (v == null || !feeSet) return '';
        const n = Number(v);
        const fmt = '₹' + n.toLocaleString('en-IN');
        if (n > 0) return `<span class="bal-cell" style="background:rgba(239,68,68,0.1);color:#DC2626;">${fmt}</span>`;
        if (n < 0) return `<span class="bal-cell" style="background:rgba(34,197,94,0.1);color:#16A34A;">${fmt}</span>`;
        return `<span class="bal-cell" style="background:rgba(100,116,139,0.08);color:#475569;">${fmt}</span>`;
    }

    // ── Populate filter dropdowns ────────────────────────────────────
    function populateFilters() {
        const fys         = [...new Set(allFilings.map(f => f.financialYear).filter(Boolean))].sort().reverse();
        const callers     = [...new Set(allFilings.map(f => f.client?.caller).filter(Boolean))].sort();
        const managers    = [...new Set(allFilings.map(f => f.manager).filter(Boolean))].sort();
        const preparers   = [...new Set(allFilings.map(f => f.preparer).filter(Boolean))].sort();
        const statuses    = [...new Set(allFilings.map(f => f.filingStatus).filter(Boolean))].sort();
        const handlers    = [...new Set(allFilings.map(f => f.paymentHandledBy).filter(Boolean))].sort();
        const itrTypes    = [...new Set(allFilings.map(f => f.itrType).filter(Boolean))].sort();
        const filingTypes = [...new Set(allFilings.map(f => f.filingType).filter(Boolean))].sort();
        const outcomes    = outcomeOptions.map(o => o.name);

        // Returns true if at least one filing has a blank value for this field
        const anyEmpty = fn => allFilings.some(f => !fn(f));

        function fill(id, vals, defaultLabel, showEmpty) {
            const sel = document.getElementById(id);
            if (!sel) return;
            const cur = sel.value;
            sel.innerHTML = `<option value="">${defaultLabel}</option>` +
                vals.map(v => `<option value="${escHtml(v)}">${escHtml(v)}</option>`).join('') +
                (showEmpty ? `<option value="__empty__">(Empty)</option>` : '');
            if (cur) sel.value = cur;
        }
        fill('filterFY',            fys,         'All FY');
        fill('filterCaller',        callers,     'All Callers',   anyEmpty(f => f.client?.caller));
        fill('filterManager',       managers,    'All Managers',  anyEmpty(f => f.manager));
        fill('filterPreparer',      preparers,   'All Preparers', anyEmpty(f => f.preparer));
        fill('filterStatus',        statuses,    'All Statuses',  anyEmpty(f => f.filingStatus));
        fill('filterPayHandler',    handlers,    'All',           anyEmpty(f => f.paymentHandledBy));
        fill('filterItrType',       itrTypes,    'All ITR Types', anyEmpty(f => f.itrType));
        fill('filterFilingType',    filingTypes, 'All Types',     anyEmpty(f => f.filingType));
        fill('filterReturnOutcome', outcomes,    'All Outcomes',  anyEmpty(f => f.returnOutcome));
    }

    // ── Fetch filings + colours ──────────────────────────────────────
    async function loadFilings() {
        try {
            const [filingsRes, s2Res, outcomeRes] = await Promise.all([
                fetch('/api/itr-filings'),
                fetch('/api/itr-status2'),
                fetch('/api/return-outcomes'),
            ]);
            allFilings     = await filingsRes.json();
            s2Options      = await s2Res.json();
            outcomeOptions = await outcomeRes.json();
            populateFilters();
            buildNavChips();
            applyFilter();
        } catch (e) {
            document.getElementById('loadingRow').innerHTML =
                '<td colspan="18" class="text-center text-danger-600 py-20">Failed to load data.</td>';
        }
    }

    // ── Dynamic navbar chips ─────────────────────────────────────────
    function buildNavChips() {
        const container = document.getElementById('itrNavChips');
        if (!container) return;

        // Count distinct non-empty values per field across all filings
        function countBy(fn) {
            const map = new Map();
            allFilings.forEach(f => {
                const v = fn(f);
                if (v) map.set(v, (map.get(v) || 0) + 1);
            });
            return [...map.entries()].sort((a, b) => b[1] - a[1]);
        }

        const statusEntries  = countBy(f => resolveDisplayStatus(f));
        const typeEntries    = countBy(f => f.filingType   || '');
        const outcomeEntries = countBy(f => f.returnOutcome || '');
        const handlerEntries = countBy(f => f.paymentHandledBy || '');

        // Badge colour per field/value
        function badgeStyle(field, value) {
            if (field === 'filingStatus') {
                if (value === 'Opened') return 'background:#f1f5f9;color:#475569;';
                const opt = s2Options.find(o => o.name === value);
                if (opt && opt.color) {
                    const [r,g,b] = hexToRgb(opt.color);
                    return `background:rgba(${r},${g},${b},0.18);color:${opt.color};`;
                }
                return 'background:#f1f5f9;color:#475569;';
            }
            if (field === 'returnOutcome') {
                const opt = outcomeOptions.find(o => o.name === value);
                if (opt && opt.color) {
                    const [r,g,b] = hexToRgb(opt.color);
                    return `background:rgba(${r},${g},${b},0.18);color:${opt.color};`;
                }
                return 'background:#fef3c7;color:#92400e;';
            }
            if (field === 'filingType')       return 'background:#eff6ff;color:#1d4ed8;';
            if (field === 'paymentHandledBy') return 'background:#f5f3ff;color:#6d28d9;';
            return 'background:#f1f5f9;color:#475569;';
        }

        function chipHtml(field, value, count) {
            const active = (activeChipField === field && activeChipValue === value) ? ' chip-active' : '';
            const style  = badgeStyle(field, value);
            return `<button class="itr-chip${active}" data-field="${escHtml(field)}" data-value="${escHtml(value)}">
                <span class="chip-label">${escHtml(value)}</span>
                <span class="chip-badge" style="${style}">${count}</span>
            </button>`;
        }

        function divider() { return '<div class="chip-divider"></div>'; }

        let html = '';

        // Total chip (clears chip filter)
        const totalActive = !activeChipField ? ' chip-active' : '';
        html += `<button class="itr-chip${totalActive}" data-field="total" data-value="">
            <span class="chip-label">Total</span>
            <span class="chip-badge">${allFilings.length}</span>
        </button>`;

        if (statusEntries.length)  { html += divider(); statusEntries.forEach(([v,c])  => { html += chipHtml('filingStatus',     v, c); }); }
        if (typeEntries.length)    { html += divider(); typeEntries.forEach(([v,c])    => { html += chipHtml('filingType',       v, c); }); }
        if (outcomeEntries.length) { html += divider(); outcomeEntries.forEach(([v,c]) => { html += chipHtml('returnOutcome',    v, c); }); }
        if (handlerEntries.length) { html += divider(); handlerEntries.forEach(([v,c]) => { html += chipHtml('paymentHandledBy', v, c); }); }

        container.innerHTML = html;
    }

    window.chipFilter = function(field, value) {
        if (field === 'total' || (activeChipField === field && activeChipValue === value)) {
            activeChipField = null;
            activeChipValue = null;
        } else {
            activeChipField = field;
            activeChipValue = value;
        }
        buildNavChips();
        applyFilter();
    };

    // ── Filter + render ──────────────────────────────────────────────
    function applyFilter() {
        const q             = document.getElementById('searchInput').value.trim().toLowerCase();
        const dateFrom      = document.getElementById('filterDateFrom').value;
        const dateTo        = document.getElementById('filterDateTo').value;
        const fy            = document.getElementById('filterFY').value;
        const caller        = document.getElementById('filterCaller').value;
        const manager       = document.getElementById('filterManager').value;
        const preparer      = document.getElementById('filterPreparer').value;
        const status        = document.getElementById('filterStatus').value;
        const filingType    = document.getElementById('filterFilingType').value;
        const itrType       = document.getElementById('filterItrType').value;
        const returnOutcome = document.getElementById('filterReturnOutcome').value;
        const payStatus     = document.getElementById('filterPayStatus').value;
        const payHandler    = document.getElementById('filterPayHandler').value;
        const feeMin        = document.getElementById('filterFeeMin').value;
        const feeMax        = document.getElementById('filterFeeMax').value;
        const paidMin       = document.getElementById('filterPaidMin').value;
        const paidMax       = document.getElementById('filterPaidMax').value;
        const balMin        = document.getElementById('filterBalMin').value;
        const balMax        = document.getElementById('filterBalMax').value;

        // Badge count (panel filters only, not search)
        const panelFilters = [dateFrom, dateTo, fy, caller, manager, preparer, status,
                              filingType, itrType, returnOutcome,
                              payStatus, payHandler, feeMin, feeMax, paidMin, paidMax, balMin, balMax];
        const activeCount = panelFilters.filter(Boolean).length;
        const badge = document.getElementById('filterBadge');
        if (activeCount > 0) { badge.textContent = activeCount; badge.classList.remove('d-none'); }
        else { badge.classList.add('d-none'); }

        const hasFilter = q || panelFilters.some(Boolean);

        document.getElementById('clearFiltersBtn').classList.toggle('d-none', !hasFilter);

        filtered = allFilings.filter(f => {
            const c = f.client || {};
            if (q && !(
                (c.name  || '').toLowerCase().includes(q) ||
                (c.pan   || '').toLowerCase().includes(q) ||
                (c.mobile|| '').toLowerCase().includes(q) ||
                (f.financialYear || '').toLowerCase().includes(q)
            )) return false;
            if (dateFrom && isoDate(f.assignedDate) < dateFrom) return false;
            if (dateTo   && isoDate(f.assignedDate) > dateTo)   return false;
            if (fy       && f.financialYear !== fy)              return false;
            // Helper: '' = show all, '__empty__' = only blank rows, else exact match
            const mf = (fv, rv) => !fv || (fv === '__empty__' ? !rv : rv === fv);
            if (!mf(caller,        c.caller))             return false;
            if (!mf(manager,       f.manager))            return false;
            if (!mf(preparer,      f.preparer))           return false;
            if (!mf(status,        f.filingStatus))       return false;
            if (!mf(filingType,    f.filingType))         return false;
            if (!mf(itrType,       f.itrType))            return false;
            if (!mf(returnOutcome, f.returnOutcome))      return false;
            if (!mf(payHandler,    f.paymentHandledBy))   return false;
            if (payStatus && (f.paymentStatus || '—') !== payStatus) return false;
            if (feeMin  !== '' && (f.finalFee  ?? -1) < parseFloat(feeMin))  return false;
            if (feeMax  !== '' && (f.finalFee  ?? -1) > parseFloat(feeMax))  return false;
            if (paidMin !== '' && (f.totalPaid ?? -1) < parseFloat(paidMin)) return false;
            if (paidMax !== '' && (f.totalPaid ?? -1) > parseFloat(paidMax)) return false;
            if (balMin  !== '' && (f.balance   ?? -1) < parseFloat(balMin))  return false;
            if (balMax  !== '' && (f.balance   ?? -1) > parseFloat(balMax))  return false;
            // Chip field+value filter
            if (activeChipField && activeChipValue) {
                if (activeChipField === 'filingStatus') {
                    if (resolveDisplayStatus(f) !== activeChipValue) return false;
                } else if (activeChipField === 'filingType') {
                    if ((f.filingType || '') !== activeChipValue) return false;
                } else if (activeChipField === 'returnOutcome') {
                    if ((f.returnOutcome || '') !== activeChipValue) return false;
                } else if (activeChipField === 'paymentHandledBy') {
                    if ((f.paymentHandledBy || '') !== activeChipValue) return false;
                }
            }
            return true;
        });
        const _clearEl = document.getElementById('clearFiltersCount');
        if (_clearEl) { _clearEl.textContent = hasFilter ? filtered.length : ''; _clearEl.style.display = hasFilter ? 'inline-flex' : 'none'; }
        currentPage = 1;
        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById('filingsTableBody');
        const start = (currentPage - 1) * pageSize;
        const slice = filtered.slice(start, start + pageSize);
        if (!slice.length) {
            tbody.innerHTML = '<tr><td colspan="18" class="text-center text-secondary-light py-32">No records found.</td></tr>';
        } else {
            tbody.innerHTML = slice.map((f, i) => {
                const c = f.client || {};
                const feeSet = f.finalFee != null && f.finalFee > 0;
                const fmtINR = v => v != null && feeSet ? '₹' + Number(v).toLocaleString('en-IN') : '';
                return `<tr>
                    <td class="text-secondary-light">${start + i + 1}</td>
                    <td style="white-space:nowrap;">${fmtDate(f.assignedDate)}</td>
                    <td class="col-client"><a href="/services/itr-individual/${escHtml(f.id)}" class="text-primary-600 fw-semibold hover-underline" style="font-size:.8rem;">${escHtml(c.name) || ''}</a></td>
                    <td><span style="font-family:monospace;font-size:.75rem;letter-spacing:.04em;">${escHtml(c.pan) || ''}</span></td>
                    <td>${escHtml(c.mobile) || ''}</td>
                    <td>${f.financialYear ? `<span class="pill" style="background:rgba(99,102,241,.08);color:#6366f1;">${escHtml(f.financialYear)}</span>` : ''}</td>
                    <td class="col-caller">${escHtml(c.caller) || ''}</td>
                    <td class="col-mgr">${escHtml(f.manager) || ''}</td>
                    <td class="col-prep">${escHtml(f.preparer) || ''}</td>
                    <td class="col-divider">${filingBadge(resolveDisplayStatus(f))}</td>
                    <td>${filingTypeText(f.filingType)}</td>
                    <td>${itrTypeText(f.itrType)}</td>
                    <td>${outcomeBadge(f.returnOutcome)}</td>
                    <td class="col-divider text-nowrap" style="font-variant-numeric:tabular-nums;">${fmtINR(f.finalFee)}</td>
                    <td class="text-nowrap" style="font-variant-numeric:tabular-nums;">${fmtINR(f.totalPaid)}</td>
                    <td class="text-nowrap">${balanceCell(f.balance, feeSet)}</td>
                    <td>${payBadge(f.paymentStatus)}</td>
                    <td>${escHtml(f.paymentHandledBy) || ''}</td>
                </tr>`;
            }).join('');
        }
        renderPagination();
    }

    function renderPagination() {
        const total = filtered.length;
        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        const start = Math.min((currentPage - 1) * pageSize + 1, total);
        const end   = Math.min(currentPage * pageSize, total);
        document.getElementById('paginationInfo').textContent = total
            ? `Showing ${start}–${end} of ${total} records` : 'No records';
        let html = '';
        if (totalPages <= 7) {
            for (let p = 1; p <= totalPages; p++) {
                html += `<li class="page-item ${p === currentPage ? 'active' : ''}">
                    <button class="page-link radius-8 px-14 py-7 text-sm fw-medium" data-page="${p}">${p}</button></li>`;
            }
        } else {
            const pages = new Set([1, 2, currentPage - 1, currentPage, currentPage + 1, totalPages - 1, totalPages].filter(p => p >= 1 && p <= totalPages));
            let last = 0;
            [...pages].sort((a,b) => a-b).forEach(p => {
                if (last && p - last > 1) html += `<li class="page-item disabled"><span class="page-link px-10 py-7 text-sm">…</span></li>`;
                html += `<li class="page-item ${p === currentPage ? 'active' : ''}">
                    <button class="page-link radius-8 px-14 py-7 text-sm fw-medium" data-page="${p}">${p}</button></li>`;
                last = p;
            });
        }
        document.getElementById('paginationList').innerHTML = html;
    }

    // ── CSV export ───────────────────────────────────────────────────
    function exportCsv() {
        const cols = ['#','Date','Client Name','PAN','Mobile','FY','Caller','Manager','Preparer',
                      'Filing Status','Filing Type','ITR Type','Return Outcome',
                      'Final Fee','Paid','Balance','Pay. Status','Pay. Handled By'];
        const rows = filtered.map((f, i) => {
            const c = f.client || {};
            const feeSet = f.finalFee != null && f.finalFee > 0;
            const fmtMoney = v => (v != null && feeSet) ? '₹' + Number(v).toLocaleString('en-IN') : '';
            return [i+1, fmtDate(f.assignedDate), c.name||'', c.pan||'', c.mobile||'', f.financialYear||'',
                    c.caller||'', f.manager||'', f.preparer||'',
                    f.filingStatus||'', f.filingType||'', f.itrType||'', f.returnOutcome||'',
                    fmtMoney(f.finalFee), fmtMoney(f.totalPaid), fmtMoney(f.balance),
                    f.paymentStatus||'', f.paymentHandledBy||''];
        });
        const csv = [cols, ...rows].map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
        a.download = 'itr_filings.csv';
        a.click();
    }

    // ── PDF export ───────────────────────────────────────────────────
    function exportPdf() {
        const thead = document.getElementById('itrPrintHead');
        const tbody = document.getElementById('itrPrintBody');
        thead.innerHTML = '<tr><th>#</th><th>Date</th><th>Client Name</th><th>PAN</th><th>Mobile</th><th>FY</th><th>Caller</th><th>Manager</th><th>Preparer</th><th>Filing Status</th><th>Filing Type</th><th>ITR Type</th><th>Return Outcome</th><th>Final Fee</th><th>Paid</th><th>Balance</th><th>Pay. Status</th><th>Pay. Handled By</th></tr>';
        tbody.innerHTML = filtered.map((f, i) => {
            const c = f.client || {};
            const feeSet = f.finalFee != null && f.finalFee > 0;
            const fmtM = v => (v != null && feeSet) ? '₹' + Number(v).toLocaleString('en-IN') : '';
            return `<tr><td>${i+1}</td><td>${fmtDate(f.assignedDate)}</td><td>${escHtml(c.name||'')}</td><td>${escHtml(c.pan||'')}</td><td>${escHtml(c.mobile||'')}</td><td>${escHtml(f.financialYear||'')}</td><td>${escHtml(c.caller||'')}</td><td>${escHtml(f.manager||'')}</td><td>${escHtml(f.preparer||'')}</td><td>${escHtml(f.filingStatus||'')}</td><td>${escHtml(f.filingType||'')}</td><td>${escHtml(f.itrType||'')}</td><td>${escHtml(f.returnOutcome||'')}</td><td>${fmtM(f.finalFee)}</td><td>${fmtM(f.totalPaid)}</td><td>${fmtM(f.balance)}</td><td>${escHtml(f.paymentStatus||'')}</td><td>${escHtml(f.paymentHandledBy||'')}</td></tr>`;
        }).join('');
        document.getElementById('itrPrintArea').style.display = 'block';
        window.print();
        document.getElementById('itrPrintArea').style.display = 'none';
    }

    // ── Update status modal ──────────────────────────────────────────
    async function loadItrStatuses() {
        if (itrStatuses.length) return;
        try { const r = await fetch('/api/itr-statuses'); itrStatuses = await r.json(); } catch (e) { itrStatuses = []; }
    }

    document.addEventListener('click', async function (e) {
        const pg = e.target.closest('[data-page]');
        if (pg) { currentPage = parseInt(pg.dataset.page); renderTable(); }
        const selectClientBtn = e.target.closest('.select-client-btn');
        if (selectClientBtn) { selectClient(selectClientBtn.dataset.id); }
    });

    document.getElementById('confirmStatusBtn').addEventListener('click', async function () {
        const status = document.getElementById('statusSelect').value;
        if (!status) { document.getElementById('statusError').classList.remove('d-none'); return; }
        document.getElementById('statusError').classList.add('d-none');
        this.disabled = true; this.textContent = 'Updating...';
        try {
            const res = await fetch('/api/itr-filings/' + pendingStatusId + '/status', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ filingStatus: status })
            });
            if (!res.ok) throw new Error();
            bootstrap.Modal.getInstance(document.getElementById('updateStatusModal')).hide();
            loadFilings();
        } catch (e) { alert('Failed to update status.'); }
        this.disabled = false; this.textContent = 'Update';
    });

    // ── Filter panel toggle ──────────────────────────────────────────
    const _filterBtn   = document.getElementById('filterToggleBtn');
    const _filterPanel = document.getElementById('filterPanel');

    function openFilterPanel() {
        _filterPanel.classList.remove('d-none');
        _filterBtn.style.background = 'rgba(99,102,241,.08)';
    }
    function closeFilterPanel() {
        _filterPanel.classList.add('d-none');
        _filterBtn.style.background = '';
    }

    _filterBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        if (_filterPanel.classList.contains('d-none')) openFilterPanel();
        else closeFilterPanel();
    });
    document.addEventListener('click', function (e) {
        if (!_filterPanel.classList.contains('d-none') &&
            !_filterPanel.contains(e.target) &&
            !_filterBtn.contains(e.target)) {
            closeFilterPanel();
        }
    });

    // Apply & Close button
    document.getElementById('fpApplyBtn').addEventListener('click', function () {
        applyFilter();
        closeFilterPanel();
    });

    // Close (X) button in panel header
    document.getElementById('fpCloseBtn').addEventListener('click', function (e) {
        e.stopPropagation();
        closeFilterPanel();
    });

    // ── Filter listeners ─────────────────────────────────────────────
    // Search is live
    document.getElementById('searchInput').addEventListener('input', applyFilter);

    // Panel filters update badge count on change but don't apply until Apply is clicked
    const panelFilterIds = [
        'filterDateFrom','filterDateTo','filterFY',
        'filterCaller','filterManager','filterPreparer',
        'filterStatus','filterFilingType','filterItrType','filterReturnOutcome',
        'filterPayStatus','filterPayHandler',
        'filterFeeMin','filterFeeMax','filterPaidMin','filterPaidMax','filterBalMin','filterBalMax'
    ];
    panelFilterIds.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('change', function () { updateBadgeCount(); });
        el.addEventListener('input',  function () { updateBadgeCount(); });
    });

    function updateBadgeCount() {
        const vals = panelFilterIds.map(id => {
            const el = document.getElementById(id);
            return el ? el.value : '';
        });
        const count = vals.filter(Boolean).length;
        const badge = document.getElementById('filterBadge');
        if (count > 0) { badge.textContent = count; badge.classList.remove('d-none'); }
        else { badge.classList.add('d-none'); }
    }

    // Page size
    document.getElementById('pageSizeSelect').addEventListener('change', function() {
        pageSize = parseInt(this.value);
        const lbl = document.getElementById('pageSizeFaceLabel');
        if (lbl) lbl.textContent = this.value;
        applyFilter();
    });

    // Clear all (toolbar button)
    document.getElementById('clearFiltersBtn').addEventListener('click', function() {
        document.getElementById('searchInput').value = '';
        panelFilterIds.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        applyFilter();
    });

    // Reset inside filter panel
    document.getElementById('fpClearBtn').addEventListener('click', function () {
        panelFilterIds.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        updateBadgeCount();
        applyFilter();
    });

    document.getElementById('exportCsvBtn').addEventListener('click', exportCsv);
    document.getElementById('exportPdfBtn').addEventListener('click', exportPdf);

    // ── Assign Client modal ──────────────────────────────────────────
    let allClients = [];
    let selectedClientId = null;
    let fys = [];

    async function openAssignModal() {
        selectedClientId = null;
        goToStep1();
        new bootstrap.Modal(document.getElementById('assignClientModal')).show();
        if (!allClients.length) {
            try { const r = await fetch('/api/clients'); allClients = (await r.json()).filter(c => c.status === 'Active'); }
            catch (e) { allClients = []; }
        }
        if (!fys.length) {
            try { const r = await fetch('/api/financial-years'); fys = await r.json(); } catch (e) { fys = []; }
        }
        renderClientList('');
    }

    function renderClientList(q) {
        const tbody = document.getElementById('clientListBody');
        const rows = allClients.filter(c => !q ||
            (c.name||'').toLowerCase().includes(q) ||
            (c.pan ||'').toLowerCase().includes(q) ||
            (c.mobile||'').toLowerCase().includes(q));
        if (!rows.length) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center text-secondary-light py-20">No active clients found.</td></tr>';
        } else {
            tbody.innerHTML = rows.map(c => {
                const sel = c.id === selectedClientId;
                return `<tr class="${sel ? 'table-primary' : ''}">
                    <td class="fw-medium">${escHtml(c.name)}</td>
                    <td>${escHtml(c.pan)}</td>
                    <td>${escHtml(c.mobile)}</td>
                    <td class="text-center">
                        <button type="button" class="btn ${sel ? 'btn-primary' : 'btn-outline-primary-600'} btn-sm radius-8 px-12 py-6 text-xs select-client-btn d-inline-flex align-items-center gap-1" data-id="${c.id}">
                            ${sel ? '<iconify-icon icon="lucide:check" class="text-sm"></iconify-icon>Selected' : 'Select'}
                        </button>
                    </td>
                </tr>`;
            }).join('');
        }
    }

    function selectClient(id) {
        selectedClientId = id;
        document.getElementById('step1Error').classList.add('d-none');
        renderClientList(document.getElementById('clientSearch').value.trim().toLowerCase());
    }

    function goToStep1() {
        document.getElementById('step1Panel').classList.remove('d-none');
        document.getElementById('step2Panel').classList.add('d-none');
        document.getElementById('nextStepBtn').classList.remove('d-none');
        document.getElementById('assignServiceBtn').classList.add('d-none');
        document.getElementById('backToStep1Btn').classList.add('d-none');
        document.getElementById('step1Crumb').className = 'badge bg-primary-600 text-white text-xs px-10 py-4 radius-8';
        document.getElementById('step2Crumb').className = 'badge bg-neutral-200 text-secondary-light text-xs px-10 py-4 radius-8';
        if (document.getElementById('clientSearch')) document.getElementById('clientSearch').value = '';
    }

    function goToStep2() {
        const client = allClients.find(c => c.id === selectedClientId);
        if (!client) return;
        document.getElementById('step1Panel').classList.add('d-none');
        document.getElementById('step2Panel').classList.remove('d-none');
        document.getElementById('nextStepBtn').classList.add('d-none');
        document.getElementById('assignServiceBtn').classList.remove('d-none');
        document.getElementById('backToStep1Btn').classList.remove('d-none');
        document.getElementById('step1Crumb').className = 'badge bg-success-600 text-white text-xs px-10 py-4 radius-8';
        document.getElementById('step2Crumb').className = 'badge bg-primary-600 text-white text-xs px-10 py-4 radius-8';
        const initials = client.name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
        document.getElementById('s2_avatar').textContent = initials;
        document.getElementById('s2_name').textContent = client.name;
        document.getElementById('s2_pan').textContent = client.pan;
        document.getElementById('s2_mobile').textContent = client.mobile;
        const fyEl = document.getElementById('fySelect');
        fyEl.innerHTML = '<option value="">Select financial year...</option>';
        fys.forEach(f => { const o = document.createElement('option'); o.value = f.name; o.textContent = f.name; fyEl.appendChild(o); });
        document.getElementById('step2Error').classList.add('d-none');
    }

    document.getElementById('openAssignBtn').addEventListener('click', openAssignModal);
    window.openAssignModal = openAssignModal;

    // Delegated chip click handler (chips are dynamically rendered)
    const _navChips = document.getElementById('itrNavChips');
    if (_navChips) {
        _navChips.addEventListener('click', function(e) {
            const btn = e.target.closest('.itr-chip');
            if (btn) window.chipFilter(btn.dataset.field, btn.dataset.value);
        });
    }
    document.getElementById('clientSearch').addEventListener('input', function () { renderClientList(this.value.trim().toLowerCase()); });
    document.getElementById('nextStepBtn').addEventListener('click', function () {
        if (!selectedClientId) { document.getElementById('step1Error').classList.remove('d-none'); return; }
        goToStep2();
    });
    document.getElementById('backToStep1Btn').addEventListener('click', goToStep1);

    document.getElementById('assignServiceBtn').addEventListener('click', async function () {
        const fy = document.getElementById('fySelect').value;
        const errEl = document.getElementById('step2Error');
        if (!fy) { errEl.textContent = 'Please select a Financial Year.'; errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');
        this.disabled = true;
        this.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize" class="text-md"></iconify-icon>Assigning...';
        try {
            const res = await fetch('/api/itr-filings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ clientId: selectedClientId, financialYear: fy, preparer: "" })
            });
            const data = await res.json();
            if (res.status === 409) { errEl.textContent = data.message; errEl.classList.remove('d-none'); return; }
            if (!res.ok) { errEl.textContent = data.message || 'Failed to assign.'; errEl.classList.remove('d-none'); return; }
            bootstrap.Modal.getInstance(document.getElementById('assignClientModal')).hide();
            window.location.href = '/services/itr-individual/' + data.id;
        } catch (e) {
            errEl.textContent = 'Network error. Please try again.'; errEl.classList.remove('d-none');
        } finally {
            this.disabled = false;
            this.innerHTML = '<iconify-icon icon="lucide:check-circle" class="text-md"></iconify-icon>Assign Service';
        }
    });

    loadFilings();
})();
</script>
