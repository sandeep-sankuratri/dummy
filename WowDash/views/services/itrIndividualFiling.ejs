<style>
@media print {
    body * { visibility: hidden; }
    #itrPrintArea, #itrPrintArea * { visibility: visible; }
    #itrPrintArea { position: absolute; top: 0; left: 0; width: 100%; }
    #itrPrintArea table { width: 100%; border-collapse: collapse; font-size: 11px; }
    #itrPrintArea th, #itrPrintArea td { border: 1px solid #ccc; padding: 6px 8px; text-align: left; }
    #itrPrintArea th { background: #f1f5f9; }
}
/* Page size custom select */
.csel-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 34px;
}
.csel-wrap select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 2;
    font-size: .75rem;
}
.csel-face {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    height: 34px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 0 10px;
    font-size: .75rem;
    background: var(--bg-base, #fff);
    color: inherit;
    white-space: nowrap;
    pointer-events: none;
    width: 100%;
}
.csel-face .csel-arrow { font-size: .65rem; flex-shrink: 0; opacity: .55; }
.csel-wrap select:focus + .csel-face { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.15); }
/* Filter panel inputs */
.fp-input {
    height: 32px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 0 10px;
    font-size: .75rem;
    background: var(--bg-base, #fff);
    color: inherit;
    outline: none;
    width: 100%;
}
.fp-input:focus { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.15); }
.fp-select {
    height: 32px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 0 8px;
    font-size: .75rem;
    background: var(--bg-base, #fff);
    color: inherit;
    outline: none;
    width: 100%;
    cursor: pointer;
    appearance: auto;
}
.fp-select:focus { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.15); }
.fp-label { font-size: .7rem; font-weight: 600; color: #64748b; margin-bottom: 4px; letter-spacing: .02em; }
.fp-section-title {
    font-size: .65rem;
    font-weight: 700;
    color: #94a3b8;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom: 1px solid #f1f5f9;
}
/* Filter badge */
#filterBadge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 16px;
    height: 16px;
    border-radius: 20px;
    background: #6366f1;
    color: #fff;
    font-size: .6rem;
    font-weight: 700;
    line-height: 1;
    margin-left: 2px;
    padding: 0 4px;
}
/* Filter panel – floating popup */
#filterPanelAnchor { position: relative; }
#filterPanel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    width: min(960px, calc(100vw - 260px));
    z-index: 300;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    background: var(--bg-base, #fff);
    box-shadow: 0 12px 40px rgba(0,0,0,.14);
    overflow: hidden;
}
.fp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 18px 10px;
    border-bottom: 1px solid #f1f5f9;
    background: #f8fafc;
}
.fp-header-title {
    font-size: .78rem;
    font-weight: 700;
    color: #334155;
    display: flex;
    align-items: center;
    gap: 6px;
}
.fp-body { padding: 12px 18px 10px; }
.fp-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    padding: 10px 18px;
    border-top: 1px solid #f1f5f9;
    background: #f8fafc;
}
.fp-apply-btn {
    height: 32px;
    padding: 0 18px;
    border-radius: 8px;
    font-size: .75rem;
    font-weight: 600;
    background: #6366f1;
    color: #fff;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: background .15s;
}
.fp-apply-btn:hover { background: #4f46e5; }
.fp-clear-btn {
    height: 32px;
    padding: 0 14px;
    border-radius: 8px;
    font-size: .75rem;
    font-weight: 500;
    background: transparent;
    color: #64748b;
    border: 1px solid #e2e8f0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: all .15s;
}
.fp-clear-btn:hover { background: #f1f5f9; }
/* ensure all panel inputs/selects are vertically centered */
.fp-input, .fp-select { display: flex; align-items: center; }
/* Table improvements */
.itr-table th {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .03em;
    text-transform: uppercase;
    color: #64748b;
    white-space: nowrap;
    padding: 10px 12px;
    border-bottom: 2px solid #e2e8f0;
    background: #f8fafc;
}
.itr-table td {
    font-size: .78rem;
    padding: 10px 12px;
    vertical-align: middle;
    border-bottom: 1px solid #f1f5f9;
}
.itr-table tbody tr:hover td { background: #f8faff; }
.itr-table tbody tr:last-child td { border-bottom: none; }
.col-divider { border-left: 2px solid #e2e8f0 !important; }
.col-client  { min-width: 150px; }
.col-caller  { min-width: 120px; }
.col-mgr     { min-width: 120px; }
.col-prep    { min-width: 120px; }
/* Pill badges */
.pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    padding: 3px 10px;
    white-space: nowrap;
}
.itr-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border: 1.5px solid #e2e8f0;
    border-radius: 20px;
    background: #fff;
    cursor: pointer;
    transition: all .15s ease;
    white-space: nowrap;
    font-size: 0;
}
.itr-chip:hover {
    border-color: #6366f1;
    background: #f5f3ff;
}
.itr-chip.chip-active {
    border-color: #6366f1;
    background: #ede9fe;
}
.itr-chip .chip-label {
    font-size: .72rem;
    font-weight: 600;
    color: #475569;
    letter-spacing: .01em;
}
.itr-chip.chip-active .chip-label { color: #4338ca; }
.chip-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: 20px;
    background: #e2e8f0;
    color: #334155;
    font-size: .68rem;
    font-weight: 700;
}
.itr-chip.chip-active .chip-badge { background: #6366f1; color: #fff; }
.chip-badge-warn { background: #fef3c7; color: #92400e; }
.itr-chip.chip-active .chip-badge-warn { background: #f59e0b; color: #fff; }
.chip-badge-success { background: #dcfce7; color: #166534; }
.itr-chip.chip-active .chip-badge-success { background: #22c55e; color: #fff; }
.chip-divider {
    width: 1px;
    height: 24px;
    background: #e2e8f0;
    margin: 0 2px;
    flex-shrink: 0;
}
#itrNavChips::-webkit-scrollbar { display: none; }
/* Balance fill highlight */
.bal-cell {
    font-weight: 600;
    border-radius: 6px;
    padding: 3px 8px;
    display: inline-block;
    white-space: nowrap;
}
</style>


