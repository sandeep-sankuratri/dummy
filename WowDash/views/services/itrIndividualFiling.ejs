                    <div class="mb-16">
                        <form class="navbar-search w-100 mb-0" onsubmit="return false;" style="display:block!important">
                            <input type="text" id="clientSearch" class="bg-base h-40-px w-100" placeholder="Search by name, PAN or mobile...">
                            <iconify-icon icon="ion:search-outline" class="icon"></iconify-icon>
                        </form>
                    </div>
                    <div class="table-responsive scroll-sm" style="max-height:320px;overflow-y:auto;">
                        <table class="table bordered-table sm-table mb-0">
                            <thead>
                                <tr>
                                    <th>Client Name</th><th>PAN</th><th>Mobile</th><th class="text-center">Select</th>
                                </tr>
                            </thead>
                            <tbody id="clientListBody">
                                <tr><td colspan="4" class="text-center text-secondary-light py-20">Loading...</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div id="step1Error" class="text-danger-600 text-sm mt-8 d-none">Please select a client.</div>
                </div>
                <div id="step2Panel" class="d-none">
                    <div class="d-flex align-items-center gap-16 p-16 bg-primary-light radius-12 mb-20 border">
                        <div class="w-44-px h-44-px bg-primary-600 text-white d-flex align-items-center justify-content-center rounded-circle flex-shrink-0 fw-bold" id="s2_avatar">?</div>
                        <div>
                            <div class="fw-semibold text-primary-light text-sm" id="s2_name">—</div>
                            <div class="text-secondary-light text-xs">PAN: <span id="s2_pan">—</span> &nbsp;|&nbsp; Mobile: <span id="s2_mobile">—</span></div>
                        </div>
                    </div>
                    <div class="row gy-16">
                        <div class="col-12">
                            <label class="form-label fw-semibold text-primary-light text-sm mb-8">Financial Year <span class="text-danger-600">*</span></label>
                            <select id="fySelect" class="form-control radius-8 form-select">
                                <option value="">Select financial year...</option>
                            </select>
                        </div>
                    </div>
                    <div id="step2Error" class="text-danger-600 text-sm mt-12 d-none"></div>
                </div>
            </div>
            <div class="modal-footer px-24 pb-24 border-0 d-flex align-items-center gap-12 flex-nowrap">
                <button type="button" id="backToStep1Btn" class="border border-neutral-400 bg-hover-neutral-200 text-secondary-light text-md px-24 py-11 radius-8 me-auto d-none d-inline-flex align-items-center gap-6">
                    <iconify-icon icon="ep:d-arrow-left" class="text-md"></iconify-icon>Back
                </button>
                <button type="button" class="border border-neutral-400 bg-hover-neutral-200 text-secondary-light text-md px-24 py-11 radius-8" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="nextStepBtn" class="btn btn-primary text-md px-24 py-12 radius-8 d-inline-flex align-items-center gap-6">
                    Next <iconify-icon icon="ep:arrow-right" class="text-md"></iconify-icon>
                </button>
                <button type="button" id="assignServiceBtn" class="btn btn-success text-md px-24 py-12 radius-8 d-none d-inline-flex align-items-center gap-6">
                    <iconify-icon icon="lucide:check-circle" class="text-md"></iconify-icon>Assign Service
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ══════════════════ PRINT AREA ══════════════════ -->
