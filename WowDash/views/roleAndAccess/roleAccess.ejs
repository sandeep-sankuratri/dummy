<!-- ═══════════════════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════════════════ -->
<script>
(function () {
    let allEmployees = [];
    let filteredEmployees = [];
    let currentPage = 1;
    let pageSize = 10;
    let pendingDeactivateId = null;
    let pendingActivateId = null;
    let pendingDeleteId = null;

    // ── Helpers ──────────────────────────────────────────────────
    function getInitials(name) {
        return name.split(' ').map(p => p[0]).join('').toUpperCase().slice(0, 2);
    }

    function formatDate(iso) {
        const d = new Date(iso);
        return d.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function designationBadgeClass(desig) {
        if (desig === 'Manager') return 'bg-primary-100 text-primary-600';
        if (desig === 'Caller') return 'bg-info-100 text-info-600';
        return 'bg-purple-100 text-purple-600';
    }

    function showToast(msg, type) {
        // Simple Bootstrap toast fallback using alert
        const div = document.createElement('div');
        div.className = `alert alert-${type === 'error' ? 'danger' : 'success'} position-fixed top-0 end-0 m-24 z-3 shadow-sm`;
        div.style.cssText = 'min-width:280px;z-index:9999;animation:fadeIn .2s;';
        div.innerHTML = msg;
        document.body.appendChild(div);
        setTimeout(() => div.remove(), 3000);
    }

    // ── Fetch Employees ──────────────────────────────────────────
    async function loadEmployees() {
        try {
            const res = await fetch('/api/employees');
            allEmployees = await res.json();
            applyFilters();
        } catch (e) {
            document.getElementById('loadingRow').innerHTML =
                '<td colspan="7" class="text-center py-24 text-danger-600">Failed to load employees. Please refresh.</td>';
        }
    }

    // ── Filter + Render ──────────────────────────────────────────
    function applyFilters() {
        const search = document.getElementById('searchInput').value.trim().toLowerCase();
        const status = document.getElementById('statusFilter').value;
        filteredEmployees = allEmployees.filter(e => {
            const matchSearch = !search ||
                e.name.toLowerCase().includes(search) ||
                e.email.toLowerCase().includes(search) ||
                e.mobile.toLowerCase().includes(search) ||
                e.designation.toLowerCase().includes(search);
            const matchStatus = !status || e.status === status;
            return matchSearch && matchStatus;
        });
        currentPage = 1;
        renderTable();
        renderPagination();
    }

    function renderTable() {
        const tbody = document.getElementById('employeeTableBody');
        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, filteredEmployees.length);
        const page = filteredEmployees.slice(start, end);

        if (filteredEmployees.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center py-24 text-secondary-light">No employees found.</td></tr>';
            document.getElementById('paginationInfo').textContent = 'Showing 0 to 0 of 0 entries';
            return;
        }

        tbody.innerHTML = page.map((emp, idx) => {
            const sl = String(start + idx + 1).padStart(2, '0');
            const initials = getInitials(emp.name);
            const desigClass = designationBadgeClass(emp.designation);
            const isActive = emp.status === 'Active';
            const statusHtml = isActive
                ? `<span class="bg-success-focus text-success-600 border border-success-main px-16 py-4 radius-4 fw-medium text-sm">Active</span>`
                : `<span class="bg-danger-focus text-danger-600 border border-danger-main px-16 py-4 radius-4 fw-medium text-sm">Inactive</span>`;

            return `<tr>
                <td>${sl}</td>
                <td>
                    <div class="d-flex align-items-center gap-10">
                        <div class="w-36-px h-36-px d-flex justify-content-center align-items-center bg-primary-100 text-primary-600 rounded-circle fw-semibold text-sm flex-shrink-0">${initials}</div>
                        <span class="fw-medium text-primary-light">${escHtml(emp.name)}</span>
                    </div>
                </td>
                <td><span class="text-secondary-light">${escHtml(emp.email)}</span></td>
                <td><span class="text-secondary-light">${escHtml(emp.mobile)}</span></td>
                <td><span class="px-12 py-4 radius-4 fw-medium text-sm ${desigClass}">${escHtml(emp.designation)}</span></td>
                <td class="text-center">${statusHtml}</td>
                <td class="text-center">
                    <div class="d-flex align-items-center gap-10 justify-content-center">
                        <button type="button"
                            class="bg-info-focus text-info-600 bg-hover-info-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="View" onclick="openView('${emp.id}')">
                            <iconify-icon icon="iconamoon:eye-light" class="menu-icon"></iconify-icon>
                        </button>
                        <button type="button"
                            class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="Edit" onclick="openEdit('${emp.id}')">
                            <iconify-icon icon="lucide:edit" class="menu-icon"></iconify-icon>
                        </button>
                        ${isActive
                            ? `<button type="button"
                                class="bg-warning-focus text-warning-600 bg-hover-warning-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                title="Deactivate" onclick="openDeactivate('${emp.id}')">
                                <iconify-icon icon="material-symbols:block" class="menu-icon"></iconify-icon>
                               </button>`
                            : `<button type="button"
                                class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                title="Activate" onclick="openActivate('${emp.id}')">
                                <iconify-icon icon="material-symbols:check-circle-outline" class="menu-icon"></iconify-icon>
                               </button>`
                        }
                        <button type="button"
                            class="bg-danger-focus text-danger-600 bg-hover-danger-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                            title="Delete" onclick="openDelete('${emp.id}')">
                            <iconify-icon icon="fluent:delete-24-regular" class="menu-icon"></iconify-icon>
                        </button>
                    </div>
                </td>
            </tr>`;
        }).join('');

        const infoStart = filteredEmployees.length === 0 ? 0 : start + 1;
        document.getElementById('paginationInfo').textContent =
            `Showing ${infoStart} to ${end} of ${filteredEmployees.length} entries`;
    }

    function renderPagination() {
        const totalPages = Math.ceil(filteredEmployees.length / pageSize);
        const ul = document.getElementById('paginationList');
        if (totalPages <= 1) { ul.innerHTML = ''; return; }
        let html = `<li class="page-item">
            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px text-md ${currentPage === 1 ? 'pe-none opacity-50' : ''}"
               href="javascript:void(0)" onclick="goPage(${currentPage - 1})">
               <iconify-icon icon="ep:d-arrow-left"></iconify-icon></a></li>`;
        for (let p = 1; p <= totalPages; p++) {
            const active = p === currentPage ? 'bg-primary-600 text-white' : 'bg-neutral-200 text-secondary-light';
            html += `<li class="page-item"><a class="page-link ${active} fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px text-md"
                href="javascript:void(0)" onclick="goPage(${p})">${p}</a></li>`;
        }
        html += `<li class="page-item">
            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px text-md ${currentPage === totalPages ? 'pe-none opacity-50' : ''}"
               href="javascript:void(0)" onclick="goPage(${currentPage + 1})">
               <iconify-icon icon="ep:d-arrow-right"></iconify-icon></a></li>`;
        ul.innerHTML = html;
    }

    window.goPage = function(p) {
        const totalPages = Math.ceil(filteredEmployees.length / pageSize);
        if (p < 1 || p > totalPages) return;
        currentPage = p;
        renderTable();
        renderPagination();
    };

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── View Employee ─────────────────────────────────────────────
    window.openView = function(id) {
        const emp = allEmployees.find(e => e.id === id);
        if (!emp) return;
        document.getElementById('view_avatar').textContent = getInitials(emp.name);
        document.getElementById('view_name').textContent = emp.name;
        document.getElementById('view_designation_badge').textContent = emp.designation;
        document.getElementById('view_email').textContent = emp.email;
        document.getElementById('view_mobile').textContent = emp.mobile;
        document.getElementById('view_userId').textContent = emp.userId;
        document.getElementById('view_createdAt').textContent = formatDate(emp.createdAt);
        const sb = document.getElementById('view_status_badge');
        if (emp.status === 'Active') {
            sb.className = 'ms-auto bg-success-focus text-success-600 border border-success-main px-16 py-4 radius-4 fw-medium text-sm';
        } else {
            sb.className = 'ms-auto bg-danger-focus text-danger-600 border border-danger-main px-16 py-4 radius-4 fw-medium text-sm';
        }
        sb.textContent = emp.status;
        const pwEl = document.getElementById('view_password');
        pwEl.dataset.actual = emp.password;
        pwEl.textContent = '••••••••';
        document.getElementById('view_eyeIcon').setAttribute('icon', 'iconamoon:eye-light');
        new bootstrap.Modal(document.getElementById('viewEmployeeModal')).show();
    };

    window.toggleViewPassword = function() {
        const pwEl = document.getElementById('view_password');
        const icon = document.getElementById('view_eyeIcon');
        const isHidden = pwEl.textContent.startsWith('•');
        pwEl.textContent = isHidden ? pwEl.dataset.actual : '••••••••';
        icon.setAttribute('icon', isHidden ? 'iconamoon:eye-off-light' : 'iconamoon:eye-light');
    };

    window.toggleEditPassword = function(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.setAttribute('icon', isPassword ? 'iconamoon:eye-off-light' : 'iconamoon:eye-light');
    };

    // ── Edit Employee ─────────────────────────────────────────────
    window.openEdit = function(id) {
        const emp = allEmployees.find(e => e.id === id);
        if (!emp) return;
        document.getElementById('edit_id').value = emp.id;
        document.getElementById('edit_name').value = emp.name;
        document.getElementById('edit_email').value = emp.email;
        document.getElementById('edit_mobile').value = emp.mobile;
        document.getElementById('edit_userId').value = emp.userId;
        document.getElementById('edit_designation').value = emp.designation;
        document.getElementById('edit_password').value = '';
        document.getElementById('edit_confirmPassword').value = '';
        document.getElementById('edit_password').type = 'password';
        document.getElementById('edit_confirmPassword').type = 'password';
        document.getElementById('edit_eyeIcon1').setAttribute('icon', 'iconamoon:eye-light');
        document.getElementById('edit_eyeIcon2').setAttribute('icon', 'iconamoon:eye-light');
        document.getElementById('editEmployeeError').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('editEmployeeModal')).show();
    };

    document.getElementById('editEmployeeSubmitBtn').addEventListener('click', async function () {
        const id = document.getElementById('edit_id').value;
        const name = document.getElementById('edit_name').value.trim();
        const email = document.getElementById('edit_email').value.trim();
        const mobile = document.getElementById('edit_mobile').value.trim();
        const userId = document.getElementById('edit_userId').value.trim();
        const designation = document.getElementById('edit_designation').value;
        const password = document.getElementById('edit_password').value;
        const confirmPassword = document.getElementById('edit_confirmPassword').value;
        const errEl = document.getElementById('editEmployeeError');

        if (!name || !email || !mobile || !userId || !designation) {
            errEl.textContent = 'All fields are required.';
            errEl.classList.remove('d-none');
            return;
        }
        if (password && password !== confirmPassword) {
            errEl.textContent = 'Passwords do not match.';
            errEl.classList.remove('d-none');
            return;
        }
        errEl.classList.add('d-none');

        const btn = this;
        btn.disabled = true;
        btn.textContent = 'Saving...';

        const payload = { name, email, mobile, userId, designation };
        if (password) payload.password = password;

        try {
            const res = await fetch(`/api/employees/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (!res.ok) throw new Error((await res.json()).message);
            bootstrap.Modal.getInstance(document.getElementById('editEmployeeModal')).hide();
            showToast('Employee updated successfully.', 'success');
            await loadEmployees();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to update employee.';
            errEl.classList.remove('d-none');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Save Changes';
        }
    });

    // ── Add Employee ──────────────────────────────────────────────
    document.getElementById('addEmployeeSubmitBtn').addEventListener('click', async function () {
        const name = document.getElementById('add_name').value.trim();
        const email = document.getElementById('add_email').value.trim();
        const mobile = document.getElementById('add_mobile').value.trim();
        const userId = document.getElementById('add_userId').value.trim();
        const password = document.getElementById('add_password').value;
        const confirmPassword = document.getElementById('add_confirmPassword').value;
        const designation = document.getElementById('add_designation').value;
        const errEl = document.getElementById('addEmployeeError');

        if (!name || !email || !mobile || !userId || !password || !confirmPassword || !designation) {
            errEl.textContent = 'All fields are required.';
            errEl.classList.remove('d-none');
            return;
        }
        if (password !== confirmPassword) {
            errEl.textContent = 'Passwords do not match.';
            errEl.classList.remove('d-none');
            return;
        }
        errEl.classList.add('d-none');

        const btn = this;
        btn.disabled = true;
        btn.textContent = 'Submitting...';

        try {
            const res = await fetch('/api/employees', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, email, mobile, userId, password, designation })
            });
            if (!res.ok) throw new Error((await res.json()).message);
            bootstrap.Modal.getInstance(document.getElementById('addEmployeeModal')).hide();
            document.getElementById('addEmployeeForm').reset();
            showToast('Employee added successfully.', 'success');
            await loadEmployees();
        } catch (e) {
            errEl.textContent = e.message || 'Failed to add employee.';
            errEl.classList.remove('d-none');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Submit';
        }
    });

    // Clear add form errors when modal opens
    document.getElementById('addEmployeeModal').addEventListener('show.bs.modal', function () {
        document.getElementById('addEmployeeError').classList.add('d-none');
        document.getElementById('addEmployeeForm').reset();
    });

    // ── Deactivate ────────────────────────────────────────────────
    window.openDeactivate = function(id) {
        pendingDeactivateId = id;
        new bootstrap.Modal(document.getElementById('deactivateModal')).show();
    };

    document.getElementById('confirmDeactivateBtn').addEventListener('click', async function () {
        if (!pendingDeactivateId) return;
        const btn = this;
        btn.disabled = true;
        btn.textContent = 'Deactivating...';
        try {
            const res = await fetch(`/api/employees/${pendingDeactivateId}/deactivate`, { method: 'PATCH' });
            if (!res.ok) throw new Error('Failed to deactivate');
            bootstrap.Modal.getInstance(document.getElementById('deactivateModal')).hide();
            showToast('Employee deactivated.', 'success');
            await loadEmployees();
        } catch (e) {
            showToast('Failed to deactivate employee.', 'error');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Deactivate';
            pendingDeactivateId = null;
        }
    });

    // ── Activate ──────────────────────────────────────────────────
    window.openActivate = function(id) {
        pendingActivateId = id;
        new bootstrap.Modal(document.getElementById('activateModal')).show();
    };

    document.getElementById('confirmActivateBtn').addEventListener('click', async function () {
        if (!pendingActivateId) return;
        const btn = this;
        btn.disabled = true;
        btn.textContent = 'Activating...';
        try {
            const res = await fetch(`/api/employees/${pendingActivateId}/activate`, { method: 'PATCH' });
            if (!res.ok) throw new Error('Failed to activate');
            bootstrap.Modal.getInstance(document.getElementById('activateModal')).hide();
            showToast('Employee activated.', 'success');
            await loadEmployees();
        } catch (e) {
            showToast('Failed to activate employee.', 'error');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Activate';
            pendingActivateId = null;
        }
    });

    // ── Delete ────────────────────────────────────────────────────
    window.openDelete = function(id) {
        pendingDeleteId = id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    };

    document.getElementById('confirmDeleteBtn').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        const btn = this;
        btn.disabled = true;
        btn.textContent = 'Deleting...';
        try {
            const res = await fetch(`/api/employees/${pendingDeleteId}`, { method: 'DELETE' });
            if (!res.ok) throw new Error('Failed to delete');
            bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
            showToast('Employee deleted.', 'success');
            await loadEmployees();
        } catch (e) {
            showToast('Failed to delete employee.', 'error');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Delete';
            pendingDeleteId = null;
        }
    });

    // ── Filters ───────────────────────────────────────────────────
    document.getElementById('searchInput').addEventListener('input', applyFilters);
    document.getElementById('statusFilter').addEventListener('change', applyFilters);
    document.getElementById('pageSizeSelect').addEventListener('change', function () {
        pageSize = parseInt(this.value);
        applyFilters();
    });

    // ── Init ──────────────────────────────────────────────────────
    loadEmployees();
})();
</script>
